                ['B','L','N',' ',' ',' ',' ',' '],
                ['L',' ','E',' ','A','V','A','T','A','R'],
                [' ',' ',' ',' ',' ',' ',' ','R',' ',' '],
                ['I','N','C','E','P','T','I','O','N',' '],
                [' ',' ',' ',' ',' ',' ',' ','N',' ',' '],
            ],
            clues: {
                across: [
                    { num: 3, row: 3, col: 4, len: 6, clue: "James Cameron's blue aliens on Pandora" },
                    { num: 4, row: 5, col: 0, len: 9, clue: "Dream within a dream (Nolan, 2010)" }
                ],
