            difficulty: "Easy",
            grid: [
                [' ',' ',' ',' ','C',' ',' ',' ',' ',' '],
                [' ',' ',' ',' ','A',' ',' ',' ',' ',' '],
                ['G','H','O','S','T','B','U','S','T','E','R','S'],
                [' ',' ',' ',' ','E',' ',' ',' ',' ',' ',' ',' '],
                [' ','F','E','R','R','I','S',' ',' ',' ',' ',' '],
                [' ',' ',' ',' ','I',' ',' ',' ',' ',' ',' ',' '],
                [' ',' ',' ',' ','N',' ',' ',' ',' ',' ',' ',' '],
                ['B','R','I','D','E','S','M','A','I','D','S',' '],
            ],
            clues: {
                across: [
                    { num: 2, row: 2, col: 0, len: 12, clue: "Who ya gonna call? (1984)" },
                    { num: 4, row: 4, col: 1, len: 6, clue: "___ Bueller's Day Off (1986)" },
                    { num: 5, row: 7, col: 0, len: 11, clue: "Kristen Wiig wedding comedy (2011)" }
                ],
                down: [
                    { num: 1, row: 0, col: 4, len: 4, clue: "Jim ___: The Mask, Ace Ventura (last name)" },
                    { num: 3, row: 2, col: 4, len: 6, clue: "Will Ferrell's \"___\" brand or a comedy tool" }
                ]
            }
        }
    ];

    var currentPuzzle = null;
    var cells = {};
    var selectedCell = null;
    var direction = 'across';
    var timerInterval = null;
    var seconds = 0;
    var hintsUsed = 0;
    var stats = JSON.parse(localStorage.getItem('vidly-crossword-stats') || '{"solved":0,"hints":0,"bestTime":null,"streak":0}');

    function init() {
        var list = document.getElementById('puzzle-list');
        list.innerHTML = '';
        PUZZLES.forEach(function(p, i) {
            var a = document.createElement('a');
            a.href = '#';
            a.className = 'list-group-item puzzle-btn';
            a.innerHTML = '<strong>' + p.name + '</strong> <span class="label label-' +
                (p.difficulty === 'Easy' ? 'success' : p.difficulty === 'Medium' ? 'warning' : 'danger') +
                ' pull-right">' + p.difficulty + '</span>';
            a.onclick = function(e) { e.preventDefault(); loadPuzzle(i); };
            list.appendChild(a);
        });
        updateStats();
    }

    function loadPuzzle(idx) {
        currentPuzzle = idx;
        var p = PUZZLES[idx];
        hintsUsed = 0;
        seconds = 0;
        if (timerInterval) clearInterval(timerInterval);

        document.getElementById('puzzle-title').textContent = p.name;
        document.getElementById('controls').style.display = '';
        document.getElementById('clues-panel').style.display = '';
        document.getElementById('completion-msg').style.display = 'none';

        // highlight selected puzzle
        var btns = document.querySelectorAll('.puzzle-btn');
        btns.forEach(function(b, i) { b.classList.toggle('active', i === idx); });

        // build grid
        var container = document.getElementById('crossword-container');
        var grid = p.grid;
        cells = {};
        var html = '<table>';
        for (var r = 0; r < grid.length; r++) {
            html += '<tr>';
            for (var c = 0; c < grid[r].length; c++) {
                if (grid[r][c] === ' ') {
                    html += '<td><div class="cw-black"></div></td>';
                } else {
                    var num = getCellNumber(p, r, c);
                    var numHtml = num ? '<span class="cw-number">' + num + '</span>' : '';
                    html += '<td><div class="cw-cell-wrap">' + numHtml +
                        '<input type="text" maxlength="1" class="cw-cell" data-r="' + r + '" data-c="' + c +
                        '" id="cell-' + r + '-' + c + '" /></div></td>';
                }
            }
            html += '</tr>';
        }
        html += '</table>';
        container.innerHTML = html;

        // attach events
        var inputs = container.querySelectorAll('.cw-cell');
        inputs.forEach(function(inp) {
            var r = parseInt(inp.dataset.r), c = parseInt(inp.dataset.c);
            cells[r + ',' + c] = inp;
            inp.addEventListener('focus', function() { onCellFocus(r, c); });
            inp.addEventListener('input', function() { onCellInput(r, c); });
            inp.addEventListener('keydown', function(e) { onCellKeydown(e, r, c); });
            inp.addEventListener('click', function() {
                if (selectedCell && selectedCell.r === r && selectedCell.c === c) {
                    direction = direction === 'across' ? 'down' : 'across';
                    highlightWord(r, c);
                }
            });
        });

        // build clues
        buildClueList('across-clues', p.clues.across);
        buildClueList('down-clues', p.clues.down);

        // start timer
        timerInterval = setInterval(function() {
            seconds++;
            document.getElementById('timer').textContent = formatTime(seconds);
        }, 1000);
    }

    function getCellNumber(p, r, c) {
        var all = p.clues.across.concat(p.clues.down);
        for (var i = 0; i < all.length; i++) {
            if (all[i].row === r && all[i].col === c && all[i].clue) return all[i].num;
        }
        return null;
    }

    function buildClueList(id, clues) {
        var ul = document.getElementById(id);
        ul.innerHTML = '';
        clues.forEach(function(c) {
            if (!c.clue) return;
            var li = document.createElement('li');
            li.textContent = c.num + '. ' + c.clue;
            li.dataset.num = c.num;
            li.dataset.row = c.row;
            li.dataset.col = c.col;
            li.onclick = function() {
                direction = id === 'across-clues' ? 'across' : 'down';
                focusCell(c.row, c.col);
            };
            ul.appendChild(li);
        });
    }

    function onCellFocus(r, c) {
        selectedCell = { r: r, c: c };
        highlightWord(r, c);
    }

    function highlightWord(r, c) {
        // clear highlights
        Object.values(cells).forEach(function(inp) {
            inp.classList.remove('active-word');
        });
        document.querySelectorAll('#across-clues li, #down-clues li').forEach(function(li) {
            li.classList.remove('active-clue');
        });

        var p = PUZZLES[currentPuzzle];
        var clueList = direction === 'across' ? p.clues.across : p.clues.down;
        var clue = findClueForCell(clueList, r, c);
        if (!clue) {
            direction = direction === 'across' ? 'down' : 'across';
            clueList = direction === 'across' ? p.clues.across : p.clues.down;
            clue = findClueForCell(clueList, r, c);
        }
        if (!clue) return;

        // highlight cells in word
        for (var i = 0; i < clue.len; i++) {
            var cr = direction === 'across' ? clue.row : clue.row + i;
            var cc = direction === 'across' ? clue.col + i : clue.col;
            var key = cr + ',' + cc;
            if (cells[key]) cells[key].classList.add('active-word');
        }

        // highlight clue
        var listId = direction === 'across' ? 'across-clues' : 'down-clues';
        var lis = document.querySelectorAll('#' + listId + ' li');
        lis.forEach(function(li) {
            if (parseInt(li.dataset.num) === clue.num) li.classList.add('active-clue');
        });
    }

    function findClueForCell(clues, r, c) {
        for (var i = 0; i < clues.length; i++) {
            var cl = clues[i];
            if (!cl.clue) continue;
            for (var j = 0; j < cl.len; j++) {
                var cr = cl.row + (clues === PUZZLES[currentPuzzle].clues.down ? j : 0);
                var cc = cl.col + (clues === PUZZLES[currentPuzzle].clues.across ? j : 0);
                if (cr === r && cc === c) return cl;
            }
        }
        return null;
    }

    function onCellInput(r, c) {
        var inp = cells[r + ',' + c];
        inp.value = inp.value.toUpperCase().replace(/[^A-Z]/g, '');
        if (inp.value) moveNext(r, c);
    }

    function onCellKeydown(e, r, c) {
        if (e.key === 'Backspace' && !cells[r + ',' + c].value) {
            e.preventDefault();
            movePrev(r, c);
        } else if (e.key === 'ArrowRight') { e.preventDefault(); direction = 'across'; moveNext(r, c); }
        else if (e.key === 'ArrowLeft') { e.preventDefault(); direction = 'across'; movePrev(r, c); }
        else if (e.key === 'ArrowDown') { e.preventDefault(); direction = 'down'; moveNext(r, c); }
        else if (e.key === 'ArrowUp') { e.preventDefault(); direction = 'down'; movePrev(r, c); }
        else if (e.key === 'Tab') {
            e.preventDefault();
            direction = direction === 'across' ? 'down' : 'across';
            highlightWord(r, c);
        }
    }

    function moveNext(r, c) {
        var nr = direction === 'down' ? r + 1 : r;
        var nc = direction === 'across' ? c + 1 : c;
        focusCell(nr, nc);
    }

    function movePrev(r, c) {
        var nr = direction === 'down' ? r - 1 : r;
        var nc = direction === 'across' ? c - 1 : c;
        focusCell(nr, nc);
    }

    function focusCell(r, c) {
        var key = r + ',' + c;
        if (cells[key]) cells[key].focus();
    }

    function revealLetter() {
        if (!selectedCell) return;
        var key = selectedCell.r + ',' + selectedCell.c;
        var inp = cells[key];
        if (!inp) return;
        var answer = PUZZLES[currentPuzzle].grid[selectedCell.r][selectedCell.c];
        inp.value = answer;
        inp.classList.add('revealed');
        hintsUsed++;
    }

    function checkPuzzle() {
        var p = PUZZLES[currentPuzzle];
        var allCorrect = true;
        var allFilled = true;

        for (var key in cells) {
            var parts = key.split(',');
            var r = parseInt(parts[0]), c = parseInt(parts[1]);
            var inp = cells[key];
            var answer = p.grid[r][c];
            inp.classList.remove('correct', 'incorrect');

            if (!inp.value) {
                allFilled = false;
                allCorrect = false;
            } else if (inp.value.toUpperCase() === answer.toUpperCase()) {
                inp.classList.add('correct');
            } else {
                inp.classList.add('incorrect');
                allCorrect = false;
            }
        }

        if (allCorrect && allFilled) {
            clearInterval(timerInterval);
            document.getElementById('completion-msg').style.display = '';
            document.getElementById('completion-stats').textContent =
                'Completed in ' + formatTime(seconds) + ' with ' + hintsUsed + ' hint(s) used.';

            stats.solved++;
            stats.hints += hintsUsed;
            stats.streak++;
            if (!stats.bestTime || seconds < stats.bestTime) stats.bestTime = seconds;
            localStorage.setItem('vidly-crossword-stats', JSON.stringify(stats));
            updateStats();
        }
    }

    function resetPuzzle() {
        if (currentPuzzle !== null) loadPuzzle(currentPuzzle);
    }

    function updateStats() {
        document.getElementById('stat-solved').textContent = stats.solved;
        document.getElementById('stat-hints').textContent = stats.hints;
        document.getElementById('stat-best').textContent = stats.bestTime ? formatTime(stats.bestTime) : '--:--';
        document.getElementById('stat-streak').textContent = stats.streak;
    }

    function formatTime(s) {
        var m = Math.floor(s / 60);
        var sec = s % 60;
        return (m < 10 ? '0' : '') + m + ':' + (sec < 10 ? '0' : '') + sec;
    }

    init();
</script>
