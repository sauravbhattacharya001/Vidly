@{
    ViewBag.Title = "Movie Crossword";
}

<div class="container" style="margin-top: 20px;">
    <div class="page-header">
        <h1><span class="glyphicon glyphicon-th"></span> Movie Crossword</h1>
        <p class="lead text-muted">Solve crossword puzzles with clues about movies, actors, directors, and famous quotes</p>
    </div>

    <div class="row">
        <div class="col-md-4">
            <div class="panel panel-default">
                <div class="panel-heading">
                    <h3 class="panel-title"><span class="glyphicon glyphicon-list"></span> Choose a Puzzle</h3>
                </div>
                <div class="panel-body" id="puzzle-selector">
                    <div class="list-group" id="puzzle-list"></div>
                </div>
            </div>

            <div class="panel panel-info" id="clues-panel" style="display:none;">
                <div class="panel-heading">
                    <h3 class="panel-title"><span class="glyphicon glyphicon-question-sign"></span> Clues</h3>
                </div>
                <div class="panel-body" style="max-height: 500px; overflow-y: auto;">
                    <h4>Across</h4>
                    <ul class="list-unstyled" id="across-clues"></ul>
                    <hr />
                    <h4>Down</h4>
                    <ul class="list-unstyled" id="down-clues"></ul>
                </div>
            </div>
        </div>

        <div class="col-md-8">
            <div class="panel panel-default">
                <div class="panel-heading">
                    <div class="row">
                        <div class="col-xs-6">
                            <h3 class="panel-title" style="line-height:30px;" id="puzzle-title">Select a puzzle to begin</h3>
                        </div>
                        <div class="col-xs-6 text-right" id="controls" style="display:none;">
                            <span class="label label-info" id="timer">00:00</span>
                            <button class="btn btn-xs btn-warning" onclick="revealLetter()" title="Reveal current letter">
                                <span class="glyphicon glyphicon-eye-open"></span> Hint
                            </button>
                            <button class="btn btn-xs btn-success" onclick="checkPuzzle()" title="Check answers">
                                <span class="glyphicon glyphicon-ok"></span> Check
                            </button>
                            <button class="btn btn-xs btn-danger" onclick="resetPuzzle()" title="Clear all">
                                <span class="glyphicon glyphicon-refresh"></span> Reset
                            </button>
                        </div>
                    </div>
                </div>
                <div class="panel-body text-center">
                    <div id="crossword-container" style="display:inline-block; position:relative;"></div>
                    <div id="completion-msg" style="display:none; margin-top:15px;">
                        <div class="alert alert-success">
                            <h3><span class="glyphicon glyphicon-star"></span> Puzzle Complete!</h3>
                            <p id="completion-stats"></p>
                        </div>
                    </div>
                </div>
            </div>

            <div class="panel panel-default" id="stats-panel">
                <div class="panel-heading">
                    <h3 class="panel-title"><span class="glyphicon glyphicon-stats"></span> Your Stats</h3>
                </div>
                <div class="panel-body">
                    <div class="row text-center">
                        <div class="col-xs-3">
                            <h2 id="stat-solved">0</h2>
                            <p class="text-muted">Solved</p>
                        </div>
                        <div class="col-xs-3">
                            <h2 id="stat-hints">0</h2>
                            <p class="text-muted">Hints Used</p>
                        </div>
                        <div class="col-xs-3">
                            <h2 id="stat-best">--:--</h2>
                            <p class="text-muted">Best Time</p>
                        </div>
                        <div class="col-xs-3">
                            <h2 id="stat-streak">0</h2>
                            <p class="text-muted">Streak</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .cw-cell {
        width: 36px; height: 36px;
        border: 2px solid #333;
        text-align: center;
        font-size: 18px;
        font-weight: bold;
        text-transform: uppercase;
        padding: 0;
        background: #fff;
        position: relative;
        outline: none;
    }
    .cw-cell:focus { background: #ffffcc; border-color: #f0ad4e; }
    .cw-cell.active-word { background: #e8f4fd; }
    .cw-cell.correct { background: #dff0d8; }
    .cw-cell.incorrect { background: #f2dede; }
    .cw-cell.revealed { color: #337ab7; }
    .cw-black { width: 36px; height: 36px; background: #333; border: 2px solid #333; }
    .cw-number {
        position: absolute; top: 1px; left: 2px;
        font-size: 9px; font-weight: normal; color: #666;
        pointer-events: none;
    }
    .cw-cell-wrap { position: relative; display: inline-block; }
    #crossword-container table { border-collapse: collapse; margin: 0 auto; }
    #across-clues li, #down-clues li { padding: 3px 0; cursor: pointer; }
    #across-clues li:hover, #down-clues li:hover { color: #337ab7; }
    #across-clues li.active-clue, #down-clues li.active-clue { font-weight: bold; color: #337ab7; }
    .puzzle-btn { margin-bottom: 5px; }
    .puzzle-btn.active { background: #337ab7; color: #fff; }
</style>

