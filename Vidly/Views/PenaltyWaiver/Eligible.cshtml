@model System.Collections.Generic.List<Vidly.Models.Rental>
@{
    ViewBag.Title = "Eligible for Waiver";
}

<div class="container" style="margin-top: 20px;">
    <div class="page-header">
        <h1><span class="glyphicon glyphicon-search"></span> Rentals Eligible for Waiver</h1>
        <p class="lead text-muted">Overdue and returned rentals with outstanding late fees</p>
    </div>

    <a href="@Url.Action("Index")" class="btn btn-default" style="margin-bottom: 15px;">
        <span class="glyphicon glyphicon-arrow-left"></span> Back to Waivers
    </a>

    @if (Model.Any())
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead>
                    <tr>
                        <th>Customer</th>
                        <th>Movie</th>
                        <th>Due Date</th>
                        <th>Days Overdue</th>
                        <th>Late Fee</th>
                        <th>Status</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var rental in Model)
                    {
                        <tr class="@(rental.DaysOverdue > 14 ? "danger" : rental.DaysOverdue > 7 ? "warning" : "")">
                            <td>@rental.CustomerName</td>
                            <td>@rental.MovieName</td>
                            <td>@rental.DueDate.ToString("MMM d, yyyy")</td>
                            <td>
                                <span class="text-danger"><strong>@rental.DaysOverdue</strong> day(s)</span>
                            </td>
                            <td><strong>@rental.LateFee.ToString("C")</strong></td>
                            <td>
                                @if (rental.Status == Vidly.Models.RentalStatus.Overdue)
                                {
                                    <span class="label label-danger">Overdue</span>
                                }
                                else if (rental.Status == Vidly.Models.RentalStatus.Returned)
                                {
                                    <span class="label label-default">Returned</span>
                                }
                                else
                                {
                                    <span class="label label-info">@rental.Status</span>
                                }
                            </td>
                            <td>
                                <a href="@Url.Action("Create", new { rentalId = rental.Id })" class="btn btn-sm btn-success">
                                    <span class="glyphicon glyphicon-ok"></span> Grant Waiver
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="alert alert-success">
            <span class="glyphicon glyphicon-ok-sign"></span>
            No rentals currently eligible for waivers. All fees are paid or already waived!
        </div>
    }
</div>
