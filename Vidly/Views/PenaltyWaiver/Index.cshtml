@model Vidly.ViewModels.PenaltyWaiverIndexViewModel
@{
    ViewBag.Title = "Penalty Waivers";
}

<div class="container" style="margin-top: 20px;">
    <div class="page-header">
        <h1><span class="glyphicon glyphicon-ok-circle"></span> Penalty Waivers</h1>
        <p class="lead text-muted">Review and manage late-fee waivers for overdue rentals</p>
    </div>

    @if (!string.IsNullOrEmpty(Model.StatusMessage))
    {
        <div class="alert @(Model.IsError ? "alert-danger" : "alert-success") alert-dismissible">
            <button type="button" class="close" data-dismiss="alert">&times;</button>
            @Model.StatusMessage
        </div>
    }

    @* Stats Summary *@
    <div class="row" style="margin-bottom: 20px;">
        <div class="col-md-3">
            <div class="panel panel-default">
                <div class="panel-body text-center">
                    <h3 class="text-primary">@Model.Stats.TotalWaivers</h3>
                    <p class="text-muted">Total Waivers</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="panel panel-default">
                <div class="panel-body text-center">
                    <h3 class="text-success">@Model.Stats.TotalAmountWaived.ToString("C")</h3>
                    <p class="text-muted">Total Waived</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="panel panel-default">
                <div class="panel-body text-center">
                    <h3 class="text-info">@Model.Stats.FullWaivers</h3>
                    <p class="text-muted">Full Waivers</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="panel panel-default">
                <div class="panel-body text-center">
                    <h3 class="text-warning">@Model.Stats.PartialWaivers</h3>
                    <p class="text-muted">Partial Waivers</p>
                </div>
            </div>
        </div>
    </div>

    <div style="margin-bottom: 15px;">
        <a href="@Url.Action("Eligible")" class="btn btn-primary">
            <span class="glyphicon glyphicon-search"></span> View Eligible Rentals
        </a>
    </div>

    @if (Model.Waivers.Any())
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead>
                    <tr>
                        <th>Customer</th>
                        <th>Movie</th>
                        <th>Original Fee</th>
                        <th>Waived</th>
                        <th>Remaining</th>
                        <th>Type</th>
                        <th>Reason</th>
                        <th>Granted</th>
                        <th>Approved By</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var waiver in Model.Waivers)
                    {
                        <tr>
                            <td>@waiver.CustomerName</td>
                            <td>@waiver.MovieName</td>
                            <td>@waiver.OriginalLateFee.ToString("C")</td>
                            <td class="text-success"><strong>@waiver.AmountWaived.ToString("C")</strong></td>
                            <td>@waiver.RemainingFee.ToString("C")</td>
                            <td>
                                @switch (waiver.Type)
                                {
                                    case Vidly.Models.WaiverType.Full:
                                        <span class="label label-success">Full</span>
                                        break;
                                    case Vidly.Models.WaiverType.Partial:
                                        <span class="label label-warning">Partial</span>
                                        break;
                                    case Vidly.Models.WaiverType.Goodwill:
                                        <span class="label label-info">Goodwill</span>
                                        break;
                                    case Vidly.Models.WaiverType.SystemError:
                                        <span class="label label-danger">System Error</span>
                                        break;
                                    case Vidly.Models.WaiverType.FirstOffense:
                                        <span class="label label-primary">First Offense</span>
                                        break;
                                }
                            </td>
                            <td>@waiver.Reason</td>
                            <td>@waiver.GrantedDate.ToString("MMM d, yyyy")</td>
                            <td>@waiver.ApprovedBy</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="alert alert-info">
            <span class="glyphicon glyphicon-info-sign"></span>
            No waivers have been granted yet.
            <a href="@Url.Action("Eligible")">Check eligible rentals</a> to get started.
        </div>
    }
</div>
