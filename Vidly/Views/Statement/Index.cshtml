@model Vidly.ViewModels.StatementViewModel
@{
    ViewBag.Title = "Customer Statement";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h2><span class="glyphicon glyphicon-list-alt"></span> Customer Statement Generator</h2>
<p class="text-muted">Generate consolidated rental statements for any customer and date range.</p>
<hr />

<div class="well">
    @using (Html.BeginForm("Index", "Statement", FormMethod.Get, new { @class = "form-inline" }))
    {
        <div class="form-group" style="margin-right: 15px;">
            <label for="customerId">Customer:</label>
            <select name="customerId" id="customerId" class="form-control" style="margin-left: 5px;">
                <option value="">-- Select --</option>
                @if (Model.AllCustomers != null)
                {
                    foreach (var c in Model.AllCustomers)
                    {
                        var selected = Model.CustomerId.HasValue && Model.CustomerId.Value == c.Id ? "selected" : "";
                        <option value="@c.Id" @selected>@c.Name</option>
                    }
                }
            </select>
        </div>
        <div class="form-group" style="margin-right: 15px;">
            <label for="from">From:</label>
            <input type="date" name="from" id="from" class="form-control" style="margin-left: 5px;"
                   value="@(Model.PeriodStart?.ToString("yyyy-MM-dd") ?? DateTime.Today.AddMonths(-1).ToString("yyyy-MM-dd"))" />
        </div>
        <div class="form-group" style="margin-right: 15px;">
            <label for="to">To:</label>
            <input type="date" name="to" id="to" class="form-control" style="margin-left: 5px;"
                   value="@(Model.PeriodEnd?.ToString("yyyy-MM-dd") ?? DateTime.Today.ToString("yyyy-MM-dd"))" />
        </div>
        <button type="submit" class="btn btn-primary">
            <span class="glyphicon glyphicon-search"></span> Generate
        </button>
    }
</div>

@if (!string.IsNullOrEmpty(Model.StatusMessage) && Model.Statement == null)
{
    <div class="alert alert-info">@Model.StatusMessage</div>
}

@if (Model.Statement != null)
{
    var stmt = Model.Statement;
    <div class="panel panel-default">
        <div class="panel-heading">
            <div class="row">
                <div class="col-md-6">
                    <h3 class="panel-title" style="font-size: 18px;">
                        <span class="glyphicon glyphicon-file"></span>
                        Statement @stmt.StatementNumber
                    </h3>
                </div>
                <div class="col-md-6 text-right">
                    <a href="@Url.Action("Print", new { customerId = stmt.Customer.Id, from = stmt.PeriodStart.ToString("yyyy-MM-dd"), to = stmt.PeriodEnd.ToString("yyyy-MM-dd") })"
                       class="btn btn-sm btn-default" target="_blank">
                        <span class="glyphicon glyphicon-print"></span> Print Version
                    </a>
                </div>
            </div>
        </div>
        <div class="panel-body">
            <div class="row" style="margin-bottom: 20px;">
                <div class="col-md-6">
                    <strong>Customer:</strong> @stmt.Customer.Name<br />
                    <strong>Membership:</strong> @stmt.Customer.MembershipType<br />
                    @if (!string.IsNullOrEmpty(stmt.Customer.Email))
                    {
                        <strong>Email:</strong> @stmt.Customer.Email<br />
                    }
                </div>
                <div class="col-md-6 text-right">
                    <strong>Period:</strong> @stmt.PeriodStart.ToString("MMM dd, yyyy") — @stmt.PeriodEnd.ToString("MMM dd, yyyy")<br />
                    <strong>Generated:</strong> @stmt.GeneratedAt.ToString("MMM dd, yyyy hh:mm tt")<br />
                </div>
            </div>

            <!-- Summary Stats -->
            <div class="row" style="margin-bottom: 20px;">
                <div class="col-md-2 col-sm-4 text-center">
                    <div class="panel panel-info">
                        <div class="panel-body" style="padding: 10px;">
                            <h3 style="margin: 0;">@stmt.TotalRentals</h3>
                            <small>Total Rentals</small>
                        </div>
                    </div>
                </div>
                <div class="col-md-2 col-sm-4 text-center">
                    <div class="panel panel-success">
                        <div class="panel-body" style="padding: 10px;">
                            <h3 style="margin: 0;">@stmt.ReturnedRentals</h3>
                            <small>Returned</small>
                        </div>
                    </div>
                </div>
                <div class="col-md-2 col-sm-4 text-center">
                    <div class="panel panel-warning">
                        <div class="panel-body" style="padding: 10px;">
                            <h3 style="margin: 0;">@stmt.ActiveRentals</h3>
                            <small>Active</small>
                        </div>
                    </div>
                </div>
                <div class="col-md-2 col-sm-4 text-center">
                    <div class="panel panel-danger">
                        <div class="panel-body" style="padding: 10px;">
                            <h3 style="margin: 0;">@stmt.OverdueRentals</h3>
                            <small>Overdue</small>
                        </div>
                    </div>
                </div>
                <div class="col-md-2 col-sm-4 text-center">
                    <div class="panel panel-default">
                        <div class="panel-body" style="padding: 10px;">
                            <h3 style="margin: 0;">@stmt.AverageDurationDays</h3>
                            <small>Avg Days</small>
                        </div>
                    </div>
                </div>
                <div class="col-md-2 col-sm-4 text-center">
                    <div class="panel panel-primary">
                        <div class="panel-body" style="padding: 10px;">
                            <h3 style="margin: 0;">$@stmt.GrandTotal.ToString("F2")</h3>
                            <small>Grand Total</small>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Line Items Table -->
            @if (stmt.LineItems.Count == 0)
            {
                <div class="alert alert-warning">No rentals found in this period.</div>
            }
            else
            {
                <table class="table table-striped table-hover">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Movie</th>
                            <th>Rented</th>
                            <th>Due</th>
                            <th>Returned</th>
                            <th>Days</th>
                            <th>Rate</th>
                            <th>Rental Cost</th>
                            <th>Late Fee</th>
                            <th>Total</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in stmt.LineItems)
                        {
                            var rowClass = item.Status == Vidly.Models.RentalStatus.Overdue ? "danger" :
                                           item.WasLate ? "warning" : "";
                            <tr class="@rowClass">
                                <td>@item.RentalId</td>
                                <td>@item.MovieName</td>
                                <td>@item.RentalDate.ToString("MM/dd/yy")</td>
                                <td>@item.DueDate.ToString("MM/dd/yy")</td>
                                <td>@(item.ReturnDate?.ToString("MM/dd/yy") ?? "—")</td>
                                <td>@item.DaysRented</td>
                                <td>$@item.DailyRate.ToString("F2")</td>
                                <td>$@item.RentalCost.ToString("F2")</td>
                                <td class="@(item.LateFee > 0 ? "text-danger" : "")">
                                    @(item.LateFee > 0 ? "$" + item.LateFee.ToString("F2") : "—")
                                </td>
                                <td><strong>$@item.LineTotal.ToString("F2")</strong></td>
                                <td>
                                    @switch (item.Status)
                                    {
                                        case Vidly.Models.RentalStatus.Active:
                                            <span class="label label-info">Active</span>
                                            break;
                                        case Vidly.Models.RentalStatus.Overdue:
                                            <span class="label label-danger">Overdue</span>
                                            break;
                                        case Vidly.Models.RentalStatus.Returned:
                                            <span class="label label-success">Returned</span>
                                            break;
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                    <tfoot>
                        <tr class="active">
                            <td colspan="7" class="text-right"><strong>Subtotal:</strong></td>
                            <td><strong>$@stmt.Subtotal.ToString("F2")</strong></td>
                            <td class="text-danger"><strong>$@stmt.TotalLateFees.ToString("F2")</strong></td>
                            <td><strong>$@stmt.GrandTotal.ToString("F2")</strong></td>
                            <td></td>
                        </tr>
                    </tfoot>
                </table>
            }
        </div>
    </div>
}
