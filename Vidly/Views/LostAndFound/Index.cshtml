@model Vidly.ViewModels.LostAndFoundViewModel
@{
    ViewBag.Title = "Lost & Found";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h2>
    <span class="glyphicon glyphicon-search"></span> Lost &amp; Found
</h2>

@if (!string.IsNullOrEmpty(Model.StatusMessage))
{
    <div class="alert @(Model.IsError ? "alert-danger" : "alert-success") alert-dismissible" role="alert">
        <button type="button" class="close" data-dismiss="alert" aria-label="Close">
            <span aria-hidden="true">&times;</span>
        </button>
        @Model.StatusMessage
    </div>
}

@* Dashboard Stats *@
@if (Model.Report != null)
{
    <div class="row" style="margin-bottom: 20px;">
        <div class="col-md-2 col-sm-4 col-xs-6">
            <div class="panel panel-info">
                <div class="panel-heading"><strong>Total Items</strong></div>
                <div class="panel-body text-center"><h3>@Model.Report.TotalItems</h3></div>
            </div>
        </div>
        <div class="col-md-2 col-sm-4 col-xs-6">
            <div class="panel panel-warning">
                <div class="panel-heading"><strong>Unclaimed</strong></div>
                <div class="panel-body text-center"><h3>@Model.Report.Unclaimed</h3></div>
            </div>
        </div>
        <div class="col-md-2 col-sm-4 col-xs-6">
            <div class="panel panel-success">
                <div class="panel-heading"><strong>Claimed</strong></div>
                <div class="panel-body text-center"><h3>@Model.Report.Claimed</h3></div>
            </div>
        </div>
        <div class="col-md-2 col-sm-4 col-xs-6">
            <div class="panel panel-danger">
                <div class="panel-heading"><strong>Overdue</strong></div>
                <div class="panel-body text-center"><h3>@Model.Report.OverdueForDisposal</h3></div>
            </div>
        </div>
        <div class="col-md-2 col-sm-4 col-xs-6">
            <div class="panel panel-default">
                <div class="panel-heading"><strong>Claim Rate</strong></div>
                <div class="panel-body text-center"><h3>@((Model.Report.ClaimRate * 100).ToString("F0"))%</h3></div>
            </div>
        </div>
        <div class="col-md-2 col-sm-4 col-xs-6">
            <div class="panel panel-default">
                <div class="panel-heading"><strong>Avg Days</strong></div>
                <div class="panel-body text-center"><h3>@Model.Report.AverageDaysToClaimOrDefault.ToString("F1")</h3></div>
            </div>
        </div>
    </div>
}

@* Search & Filter Bar *@
<div class="well well-sm">
    <form class="form-inline" method="get" action="@Url.Action("Index")">
        <div class="form-group" style="margin-right: 10px;">
            <input type="text" name="q" class="form-control" placeholder="Search items..." value="@Model.SearchQuery" />
        </div>
        <div class="form-group" style="margin-right: 10px;">
            <select name="status" class="form-control">
                <option value="">All Statuses</option>
                @foreach (var s in Enum.GetValues(typeof(Vidly.Models.LostItemStatus)).Cast<Vidly.Models.LostItemStatus>())
                {
                    <option value="@s" @(Model.FilterStatus == s ? "selected" : "")>@s</option>
                }
            </select>
        </div>
        <div class="form-group" style="margin-right: 10px;">
            <select name="category" class="form-control">
                <option value="">All Categories</option>
                @foreach (var c in Enum.GetValues(typeof(Vidly.Models.LostItemCategory)).Cast<Vidly.Models.LostItemCategory>())
                {
                    <option value="@c" @(Model.FilterCategory == c ? "selected" : "")>@c</option>
                }
            </select>
        </div>
        <button type="submit" class="btn btn-primary"><span class="glyphicon glyphicon-filter"></span> Filter</button>
        <a href="@Url.Action("Index")" class="btn btn-default">Clear</a>
    </form>
</div>

@* Log New Item *@
<div class="panel panel-primary">
    <div class="panel-heading" role="button" data-toggle="collapse" data-target="#logItemPanel">
        <h4 class="panel-title">
            <span class="glyphicon glyphicon-plus"></span> Log Found Item
        </h4>
    </div>
    <div id="logItemPanel" class="panel-collapse collapse">
        <div class="panel-body">
            @using (Html.BeginForm("LogItem", "LostAndFound", FormMethod.Post))
            {
                @Html.AntiForgeryToken()
                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group">
                            <label>Description *</label>
                            <input type="text" name="description" class="form-control" placeholder="e.g. Red scarf, wool blend" required />
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="form-group">
                            <label>Category</label>
                            <select name="category" class="form-control">
                                @foreach (var c in Enum.GetValues(typeof(Vidly.Models.LostItemCategory)).Cast<Vidly.Models.LostItemCategory>())
                                {
                                    <option value="@c">@c</option>
                                }
                            </select>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="form-group">
                            <label>Location Found</label>
                            <input type="text" name="locationFound" class="form-control" placeholder="e.g. Aisle 3" />
                        </div>
                    </div>
                </div>
                <div class="row">
                    <div class="col-md-2">
                        <div class="form-group">
                            <label>Color</label>
                            <input type="text" name="color" class="form-control" placeholder="e.g. Black" />
                        </div>
                    </div>
                    <div class="col-md-2">
                        <div class="form-group">
                            <label>Brand</label>
                            <input type="text" name="brand" class="form-control" placeholder="e.g. Nike" />
                        </div>
                    </div>
                    <div class="col-md-2">
                        <div class="form-group">
                            <label>Storage Bin</label>
                            <input type="text" name="storageBin" class="form-control" placeholder="e.g. BIN-A1" />
                        </div>
                    </div>
                    <div class="col-md-2">
                        <div class="form-group">
                            <label>Staff ID</label>
                            <input type="text" name="staffId" class="form-control" placeholder="e.g. S001" />
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="form-group">
                            <label>Notes</label>
                            <input type="text" name="notes" class="form-control" placeholder="Any identifying marks..." />
                        </div>
                    </div>
                </div>
                <button type="submit" class="btn btn-primary"><span class="glyphicon glyphicon-ok"></span> Log Item</button>
            }
        </div>
    </div>
</div>

@* Items Table *@
<div class="table-responsive">
    <table class="table table-striped table-hover">
        <thead>
            <tr>
                <th>#</th>
                <th>Description</th>
                <th>Category</th>
                <th>Location</th>
                <th>Color</th>
                <th>Found</th>
                <th>Status</th>
                <th>Bin</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.Items)
            {
                var daysHeld = (DateTime.Now - item.FoundAt).TotalDays;
                var isOverdue = item.Status == Vidly.Models.LostItemStatus.Found && daysHeld > item.RetentionDays;
                <tr class="@(isOverdue ? "danger" : item.Status == Vidly.Models.LostItemStatus.Claimed ? "success" : "")">
                    <td>@item.Id</td>
                    <td>
                        <strong>@item.Description</strong>
                        @if (!string.IsNullOrEmpty(item.Brand))
                        {
                            <br /><small class="text-muted">@item.Brand</small>
                        }
                        @if (!string.IsNullOrEmpty(item.Notes))
                        {
                            <br /><small class="text-info">@item.Notes</small>
                        }
                    </td>
                    <td><span class="label label-default">@item.Category</span></td>
                    <td>@item.LocationFound</td>
                    <td>@item.Color</td>
                    <td>
                        @item.FoundAt.ToString("MMM dd")
                        <br /><small class="text-muted">@((int)daysHeld)d ago</small>
                    </td>
                    <td>
                        @switch (item.Status)
                        {
                            case Vidly.Models.LostItemStatus.Found:
                                <span class="label label-info">Found</span>
                                break;
                            case Vidly.Models.LostItemStatus.ClaimPending:
                                <span class="label label-warning">Claim Pending</span>
                                break;
                            case Vidly.Models.LostItemStatus.Claimed:
                                <span class="label label-success">Claimed</span>
                                break;
                            case Vidly.Models.LostItemStatus.Disposed:
                                <span class="label label-danger">Disposed</span>
                                break;
                            case Vidly.Models.LostItemStatus.Donated:
                                <span class="label label-primary">Donated</span>
                                break;
                        }
                        @if (isOverdue)
                        {
                            <br /><span class="label label-danger">OVERDUE</span>
                        }
                    </td>
                    <td>@item.StorageBin</td>
                    <td style="white-space: nowrap;">
                        @if (item.Status == Vidly.Models.LostItemStatus.Found || item.Status == Vidly.Models.LostItemStatus.ClaimPending)
                        {
                            <button type="button" class="btn btn-xs btn-success" data-toggle="modal" data-target="#claimModal-@item.Id">
                                <span class="glyphicon glyphicon-hand-up"></span> Claim
                            </button>
                        }
                        @if (item.Status == Vidly.Models.LostItemStatus.Found)
                        {
                            using (Html.BeginForm("Dispose", "LostAndFound", new { id = item.Id, donate = false }, FormMethod.Post, new { style = "display:inline" }))
                            {
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-xs btn-danger" onclick="return confirm('Dispose of this item?');">
                                    <span class="glyphicon glyphicon-trash"></span>
                                </button>
                            }
                            using (Html.BeginForm("Dispose", "LostAndFound", new { id = item.Id, donate = true }, FormMethod.Post, new { style = "display:inline" }))
                            {
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-xs btn-info" onclick="return confirm('Donate this item?');" title="Donate">
                                    <span class="glyphicon glyphicon-gift"></span>
                                </button>
                            }
                        }
                    </td>
                </tr>

                @* Claim Modal *@
                if (item.Status == Vidly.Models.LostItemStatus.Found || item.Status == Vidly.Models.LostItemStatus.ClaimPending)
                {
                    <div class="modal fade" id="claimModal-@item.Id" tabindex="-1" role="dialog">
                        <div class="modal-dialog" role="document">
                            <div class="modal-content">
                                @using (Html.BeginForm("SubmitClaim", "LostAndFound", FormMethod.Post))
                                {
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="itemId" value="@item.Id" />
                                    <div class="modal-header">
                                        <button type="button" class="close" data-dismiss="modal"><span>&times;</span></button>
                                        <h4 class="modal-title">Claim: @item.Description</h4>
                                    </div>
                                    <div class="modal-body">
                                        <div class="form-group">
                                            <label>Customer</label>
                                            <select name="customerId" class="form-control" required>
                                                <option value="">Select customer...</option>
                                                @foreach (var cust in Model.Customers)
                                                {
                                                    <option value="@cust.Id">@cust.Name</option>
                                                }
                                            </select>
                                        </div>
                                        <div class="form-group">
                                            <label>Describe the item (for verification)</label>
                                            <textarea name="customerDescription" class="form-control" rows="3"
                                                      placeholder="Please describe the item in detail to prove ownership..." required></textarea>
                                        </div>
                                    </div>
                                    <div class="modal-footer">
                                        <button type="button" class="btn btn-default" data-dismiss="modal">Cancel</button>
                                        <button type="submit" class="btn btn-success">Submit Claim</button>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                }
            }
        </tbody>
    </table>
</div>

@* Pending Claims Section *@
@if (Model.Report != null && Model.Report.PendingClaims > 0)
{
    <h3><span class="glyphicon glyphicon-exclamation-sign"></span> Pending Claims (@Model.Report.PendingClaims)</h3>
    <div class="table-responsive">
        <table class="table table-bordered">
            <thead>
                <tr>
                    <th>Claim #</th>
                    <th>Item</th>
                    <th>Customer</th>
                    <th>Their Description</th>
                    <th>Submitted</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.Items.Where(i => i.Status == Vidly.Models.LostItemStatus.ClaimPending))
                {
                    foreach (var claim in Model.Claims.Where(c => c.ItemId == item.Id && !c.Verified && !c.Rejected))
                    {
                        <tr>
                            <td>@claim.Id</td>
                            <td><strong>@item.Description</strong><br /><small>@item.Color @item.Brand — @item.LocationFound</small></td>
                            <td>Customer #@claim.CustomerId</td>
                            <td>@claim.CustomerDescription</td>
                            <td>@claim.ClaimDate.ToString("MMM dd, HH:mm")</td>
                            <td style="white-space: nowrap;">
                                @using (Html.BeginForm("VerifyClaim", "LostAndFound", new { claimId = claim.Id }, FormMethod.Post, new { style = "display:inline" }))
                                {
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="staffId" value="STAFF" />
                                    <button type="submit" class="btn btn-xs btn-success">
                                        <span class="glyphicon glyphicon-ok"></span> Approve
                                    </button>
                                }
                                @using (Html.BeginForm("RejectClaim", "LostAndFound", new { claimId = claim.Id }, FormMethod.Post, new { style = "display:inline" }))
                                {
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="reason" value="Description did not match." />
                                    <button type="submit" class="btn btn-xs btn-danger">
                                        <span class="glyphicon glyphicon-remove"></span> Reject
                                    </button>
                                }
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
}

@* Top Locations *@
@if (Model.Report != null && Model.Report.TopLocations.Any())
{
    <div class="panel panel-default">
        <div class="panel-heading"><strong><span class="glyphicon glyphicon-map-marker"></span> Top Locations</strong></div>
        <div class="panel-body">
            @foreach (var loc in Model.Report.TopLocations.OrderByDescending(l => l.Value))
            {
                var pct = Model.Report.TotalItems > 0 ? (int)((double)loc.Value / Model.Report.TotalItems * 100) : 0;
                <div style="margin-bottom: 8px;">
                    <strong>@loc.Key</strong> <small class="text-muted">(@loc.Value items)</small>
                    <div class="progress" style="margin-bottom: 0;">
                        <div class="progress-bar progress-bar-info" style="width: @(pct)%; min-width: 2em;">@(pct)%</div>
                    </div>
                </div>
            }
        </div>
    </div>
}
