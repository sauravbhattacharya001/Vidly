@model Vidly.ViewModels.TriviaBoardViewModel
@{
    ViewBag.Title = "Movie Trivia";
}

<div class="container" style="margin-top: 20px;">
    <div class="page-header">
        <h1><span class="glyphicon glyphicon-education"></span> Movie Trivia Board</h1>
        <p class="lead text-muted">Discover behind-the-scenes facts, easter eggs, and fun trivia about your favorite movies</p>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible">
            <button type="button" class="close" data-dismiss="alert">&times;</button>
            @TempData["Success"]
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible">
            <button type="button" class="close" data-dismiss="alert">&times;</button>
            @TempData["Error"]
        </div>
    }

    @* Random Trivia Spotlight *@
    @if (Model.RandomFact != null)
    {
        <div class="panel panel-warning">
            <div class="panel-heading">
                <h3 class="panel-title"><span class="glyphicon glyphicon-star"></span> Did You Know?</h3>
            </div>
            <div class="panel-body" style="text-align: center;">
                <p style="font-size: 1.2em; font-style: italic;">@Model.RandomFact.Fact</p>
                <p class="text-muted">
                    <strong>@Model.RandomFact.MovieName</strong>
                    &middot; <span class="label label-default">@Model.RandomFact.Category</span>
                    @if (Model.RandomFact.IsVerified)
                    {
                        <span class="label label-success" style="margin-left: 4px;">
                            <span class="glyphicon glyphicon-ok"></span> Verified
                        </span>
                    }
                </p>
            </div>
        </div>
    }

    <div class="row">
        @* Left: Submit Form + Filters *@
        <div class="col-md-4">
            <div class="panel panel-default">
                <div class="panel-heading">
                    <h3 class="panel-title"><span class="glyphicon glyphicon-plus"></span> Submit Trivia</h3>
                </div>
                <div class="panel-body">
                    @using (Html.BeginForm("Submit", "Trivia", FormMethod.Post))
                    {
                        @Html.AntiForgeryToken()
                        <div class="form-group">
                            <label for="movieId">Movie</label>
                            <select name="movieId" id="movieId" class="form-control" required>
                                <option value="">-- Select --</option>
                                @foreach (var movie in Model.Movies)
                                {
                                    <option value="@movie.Id">@movie.Name</option>
                                }
                            </select>
                        </div>
                        <div class="form-group">
                            <label for="category">Category</label>
                            <select name="category" id="category" class="form-control">
                                @foreach (var cat in Model.Categories)
                                {
                                    <option value="@cat">@cat</option>
                                }
                            </select>
                        </div>
                        <div class="form-group">
                            <label for="fact">Trivia Fact</label>
                            <textarea name="fact" id="fact" class="form-control" rows="4" maxlength="1000"
                                      placeholder="Did you know that..." required></textarea>
                            <p class="help-block">Max 1000 characters</p>
                        </div>
                        <div class="form-group">
                            <label for="source">Source (optional)</label>
                            <input type="text" name="source" id="source" class="form-control"
                                   placeholder="e.g. DVD Commentary, IMDb" />
                        </div>
                        <div class="form-group">
                            <label for="customerId">Your Customer ID</label>
                            <input type="number" name="customerId" id="customerId" class="form-control"
                                   min="1" required />
                        </div>
                        <button type="submit" class="btn btn-warning btn-block">
                            <span class="glyphicon glyphicon-send"></span> Submit Trivia
                        </button>
                    }
                </div>
            </div>

            @* Filter by Category *@
            <div class="panel panel-default">
                <div class="panel-heading">
                    <h3 class="panel-title"><span class="glyphicon glyphicon-tag"></span> Categories</h3>
                </div>
                <div class="list-group">
                    <a href="@Url.Action("Index")" class="list-group-item @(Model.FilterCategory == null && Model.FilterMovieId == null ? "active" : "")">
                        All Categories
                    </a>
                    @foreach (var cat in Model.Categories)
                    {
                        <a href="@Url.Action("Index", new { category = cat })"
                           class="list-group-item @(Model.FilterCategory == cat ? "active" : "")">
                            @cat
                        </a>
                    }
                </div>
            </div>

            @* Filter by Movie *@
            <div class="panel panel-default">
                <div class="panel-heading">
                    <h3 class="panel-title"><span class="glyphicon glyphicon-film"></span> By Movie</h3>
                </div>
                <div class="list-group">
                    @foreach (var movie in Model.Movies)
                    {
                        <a href="@Url.Action("Index", new { movieId = movie.Id })"
                           class="list-group-item @(Model.FilterMovieId == movie.Id ? "active" : "")">
                            @movie.Name
                        </a>
                    }
                </div>
            </div>
        </div>

        @* Right: Trivia List *@
        <div class="col-md-8">
            @if (!Model.Facts.Any())
            {
                <div class="alert alert-info">
                    <span class="glyphicon glyphicon-info-sign"></span>
                    No trivia yet. Be the first to share a fun fact!
                </div>
            }
            else
            {
                foreach (var fact in Model.Facts)
                {
                    <div class="panel panel-default">
                        <div class="panel-body">
                            <div class="row">
                                <div class="col-xs-2 col-sm-1 text-center">
                                    @using (Html.BeginForm("Like", "Trivia", new { id = fact.Id }, FormMethod.Post, new { style = "display:inline" }))
                                    {
                                        <button type="submit" class="btn btn-sm btn-default" title="Like">
                                            <span class="glyphicon glyphicon-heart"></span>
                                        </button>
                                    }
                                    <div style="font-size: 1.2em; font-weight: bold; margin-top: 4px;">@fact.Likes</div>
                                </div>
                                <div class="col-xs-10 col-sm-11">
                                    <p style="font-size: 1.1em;">@fact.Fact</p>
                                    <p class="text-muted" style="margin-top: 6px; font-size: 0.85em;">
                                        <span class="glyphicon glyphicon-film"></span> <strong>@fact.MovieName</strong>
                                        &middot; <span class="label label-default">@fact.Category</span>
                                        @if (fact.IsVerified)
                                        {
                                            <span class="label label-success" style="margin-left: 4px;">
                                                <span class="glyphicon glyphicon-ok"></span> Verified
                                            </span>
                                        }
                                        @if (!string.IsNullOrEmpty(fact.Source))
                                        {
                                            <text>&middot; <span class="glyphicon glyphicon-link"></span> @fact.Source</text>
                                        }
                                        &middot; <span class="glyphicon glyphicon-user"></span> @fact.SubmittedByName
                                        &middot; <span class="glyphicon glyphicon-time"></span> @fact.SubmittedAt.ToString("MMM dd, yyyy")
                                    </p>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            }
        </div>
    </div>
</div>
