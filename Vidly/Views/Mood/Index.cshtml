@model System.Collections.Generic.IReadOnlyList<Vidly.Models.MoodProfile>
@{
    ViewBag.Title = "Mood Matcher";
}

<h2><span class="glyphicon glyphicon-heart"></span> Movie Mood Matcher</h2>
<p class="lead">How are you feeling right now? Pick your mood and we'll find the perfect movie for you.</p>

<div class="row" style="margin-top: 25px;">
    @foreach (var mood in Model)
    {
        <div class="col-md-3 col-sm-4 col-xs-6" style="margin-bottom: 20px;">
            <a href="@Url.Action("Match", "Mood", new { id = (int)mood.Mood })"
               class="panel panel-default text-center mood-card"
               style="display: block; text-decoration: none; border-left: 4px solid @mood.ColorHex; transition: transform 0.2s, box-shadow 0.2s;">
                <div class="panel-body">
                    <div style="font-size: 48px; margin-bottom: 8px;">@mood.Emoji</div>
                    <h4 style="color: #333; margin-top: 0;">@mood.DisplayName</h4>
                    <p style="color: #777; font-size: 13px; margin: 0;">@mood.Description</p>
                </div>
            </a>
        </div>
    }
</div>

<style>
    .mood-card:hover {
        transform: translateY(-3px);
        box-shadow: 0 4px 15px rgba(0,0,0,0.15);
    }
</style>
