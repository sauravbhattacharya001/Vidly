@model List<Vidly.Models.ParentalControlLog>
@{
    var profile = ViewBag.Profile as Vidly.Models.FamilyProfile;
    ViewBag.Title = $"Activity Log — {profile?.Name}";
}

<div class="row" style="margin-top: 70px;">
    <div class="col-md-10 col-md-offset-1">
        <h2>
            <span class="glyphicon glyphicon-list-alt"></span>
            Activity Log: <strong>@profile?.Name</strong>
            <a href="@Url.Action("Index")" class="btn btn-default btn-sm pull-right">
                <span class="glyphicon glyphicon-arrow-left"></span> Back
            </a>
        </h2>

        @if (!Model.Any())
        {
            <div class="alert alert-info">No activity recorded for this profile yet.</div>
        }
        else
        {
            <table class="table table-striped table-hover">
                <thead>
                    <tr>
                        <th style="width:40px;"></th>
                        <th>Action</th>
                        <th>Details</th>
                        <th>Time</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var log in Model)
                    {
                        var icon = log.Action == "Blocked" ? "ban-circle" : log.Action == "Switch" ? "transfer" : log.Action == "Created" ? "plus" : log.Action == "Deleted" ? "trash" : "info-sign";
                        var rowClass = log.Action == "Blocked" ? "danger" : log.Action == "Created" ? "success" : "";
                        <tr class="@rowClass">
                            <td><span class="glyphicon glyphicon-@icon"></span></td>
                            <td><span class="label label-@(log.Action == "Blocked" ? "danger" : "default")">@log.Action</span></td>
                            <td>@log.Details</td>
                            <td class="text-muted">@log.Timestamp.ToString("MMM d, yyyy h:mm tt")</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>
