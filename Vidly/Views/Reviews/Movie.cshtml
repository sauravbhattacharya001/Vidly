@model Vidly.ViewModels.ReviewIndexViewModel
@{
    ViewBag.Title = Model.SelectedMovie != null ? Model.SelectedMovie.Name + " - Reviews" : "Movie Reviews";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<ol class="breadcrumb">
    <li><a href="@Url.Action("Index", "Reviews")">Reviews</a></li>
    <li class="active">@(Model.SelectedMovie?.Name ?? "Movie")</li>
</ol>

<h2>
    <span class="glyphicon glyphicon-film"></span>
    @(Model.SelectedMovie?.Name ?? "Movie")
    <small>Reviews</small>
</h2>

@if (!string.IsNullOrEmpty(Model.StatusMessage))
{
    <div class="alert @(Model.IsError ? "alert-danger" : "alert-success") alert-dismissible" role="alert">
        <button type="button" class="close" data-dismiss="alert" aria-label="Close">
            <span aria-hidden="true">&times;</span>
        </button>
        @Model.StatusMessage
    </div>
}

<div class="row">
    @* Movie stats sidebar *@
    <div class="col-md-4">
        @if (Model.MovieStats != null)
        {
            <div class="panel panel-info">
                <div class="panel-heading">
                    <h3 class="panel-title"><span class="glyphicon glyphicon-stats"></span> Rating Breakdown</h3>
                </div>
                <div class="panel-body">
                    <div style="text-align: center; margin-bottom: 12px;">
                        <div style="font-size: 36px; font-weight: bold; color: #f0ad4e;">
                            @Model.MovieStats.AverageStars.ToString("F1")
                        </div>
                        <div>
                            @for (int i = 1; i <= 5; i++)
                            {
                                <span class="glyphicon @(i <= Math.Round(Model.MovieStats.AverageStars) ? "glyphicon-star" : "glyphicon-star-empty")"
                                      style="color: #f0ad4e; font-size: 18px;"></span>
                            }
                        </div>
                        <small class="text-muted">@Model.MovieStats.TotalReviews review@(Model.MovieStats.TotalReviews != 1 ? "s" : "")</small>
                    </div>

                    @* Star distribution bars *@
                    @{
                        var starCounts = new[] {
                            Model.MovieStats.FiveStarCount,
                            Model.MovieStats.FourStarCount,
                            Model.MovieStats.ThreeStarCount,
                            Model.MovieStats.TwoStarCount,
                            Model.MovieStats.OneStarCount
                        };
                        var maxCount = starCounts.Max();
                    }
                    @for (int s = 5; s >= 1; s--)
                    {
                        var count = starCounts[5 - s];
                        var pct = maxCount > 0 ? (count * 100.0 / maxCount) : 0;
                        <div style="display: flex; align-items: center; margin-bottom: 4px;">
                            <span style="width: 40px; text-align: right; margin-right: 8px; font-size: 12px;">
                                @s <span class="glyphicon glyphicon-star" style="color: #f0ad4e; font-size: 10px;"></span>
                            </span>
                            <div style="flex: 1; background: #f5f5f5; border-radius: 3px; height: 16px; overflow: hidden;">
                                <div style="width: @pct%; background: #f0ad4e; height: 100%; border-radius: 3px; min-width: @(count > 0 ? "2px" : "0");"></div>
                            </div>
                            <span style="width: 30px; text-align: right; margin-left: 8px; font-size: 12px; color: #999;">@count</span>
                        </div>
                    }
                </div>
            </div>
        }

        @* Write a review for this movie *@
        <div class="panel panel-default">
            <div class="panel-heading">
                <h3 class="panel-title"><span class="glyphicon glyphicon-pencil"></span> Write a Review</h3>
            </div>
            <div class="panel-body">
                @using (Html.BeginForm("Create", "Reviews", FormMethod.Post))
                {
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="movieId" value="@Model.SelectedMovie?.Id" />

                    <div class="form-group">
                        <label for="customerId">Customer</label>
                        <select name="customerId" id="customerId" class="form-control" required>
                            <option value="">-- Select --</option>
                            @foreach (var c in Model.Customers)
                            {
                                <option value="@c.Id">@c.Name</option>
                            }
                        </select>
                    </div>

                    <div class="form-group">
                        <label>Rating</label>
                        <div id="star-rating" style="font-size: 24px; cursor: pointer; color: #ccc;">
                            @for (int i = 1; i <= 5; i++)
                            {
                                <span class="star-btn glyphicon glyphicon-star" data-value="@i"
                                      title="@i star@(i != 1 ? "s" : "")"></span>
                            }
                        </div>
                        <input type="hidden" name="stars" id="stars-input" value="" required />
                    </div>

                    <div class="form-group">
                        <label for="reviewText">Review <small class="text-muted">(optional)</small></label>
                        <textarea name="reviewText" id="reviewText" class="form-control" rows="3"
                                  maxlength="2000" placeholder="Share your thoughts..."></textarea>
                        <small class="text-muted"><span id="char-count">0</span>/2000</small>
                    </div>

                    <button type="submit" class="btn btn-primary btn-block">
                        <span class="glyphicon glyphicon-ok"></span> Submit Review
                    </button>
                }
            </div>
        </div>
    </div>

    @* Reviews list *@
    <div class="col-md-8">
        @if (Model.Reviews != null && Model.Reviews.Count > 0)
        {
            foreach (var review in Model.Reviews)
            {
                <div class="panel panel-default">
                    <div class="panel-body">
                        <div class="row">
                            <div class="col-sm-9">
                                <div style="margin-bottom: 4px;">
                                    @for (int i = 1; i <= 5; i++)
                                    {
                                        <span class="glyphicon @(i <= review.Stars ? "glyphicon-star" : "glyphicon-star-empty")"
                                              style="color: #f0ad4e; font-size: 16px;"></span>
                                    }
                                </div>
                                @if (!string.IsNullOrWhiteSpace(review.ReviewText))
                                {
                                    <p style="margin-bottom: 6px;">@review.ReviewText</p>
                                }
                                <small class="text-muted">
                                    By <strong>@review.CustomerName</strong>
                                    &middot; @review.CreatedDate.ToString("MMM d, yyyy")
                                </small>
                            </div>
                            <div class="col-sm-3 text-right">
                                @using (Html.BeginForm("Delete", "Reviews",
                                    new { id = review.Id, returnUrl = Url.Action("Movie", "Reviews", new { id = Model.SelectedMovie?.Id }) },
                                    FormMethod.Post, new { style = "display:inline" }))
                                {
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-xs btn-danger"
                                            onclick="return confirm('Delete this review?')">
                                        <span class="glyphicon glyphicon-trash"></span>
                                    </button>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="alert alert-info">
                <span class="glyphicon glyphicon-info-sign"></span>
                No reviews yet for this movie. Be the first!
            </div>
        }
    </div>
</div>

@section scripts {
    <script>
        (function () {
            var rating = 0;
            var stars = document.querySelectorAll('#star-rating .star-btn');
            var input = document.getElementById('stars-input');

            function updateStars(val) {
                rating = val;
                input.value = val;
                for (var i = 0; i < stars.length; i++) {
                    stars[i].style.color = (i < val) ? '#f0ad4e' : '#ccc';
                }
            }

            for (var i = 0; i < stars.length; i++) {
                (function (star) {
                    star.addEventListener('click', function () {
                        updateStars(parseInt(this.getAttribute('data-value')));
                    });
                    star.addEventListener('mouseenter', function () {
                        var val = parseInt(this.getAttribute('data-value'));
                        for (var j = 0; j < stars.length; j++) {
                            stars[j].style.color = (j < val) ? '#f0ad4e' : '#ccc';
                        }
                    });
                })(stars[i]);
            }

            document.getElementById('star-rating').addEventListener('mouseleave', function () {
                for (var j = 0; j < stars.length; j++) {
                    stars[j].style.color = (j < rating) ? '#f0ad4e' : '#ccc';
                }
            });

            var textarea = document.getElementById('reviewText');
            var counter = document.getElementById('char-count');
            textarea.addEventListener('input', function () {
                counter.textContent = this.value.length;
            });
        })();
    </script>
}
