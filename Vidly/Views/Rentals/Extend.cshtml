@model Vidly.ViewModels.RentalExtendViewModel
@{
    ViewBag.Title = "Extend Rental";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h2>Extend Rental</h2>

<div class="row">
    <div class="col-md-8">
        <div class="panel panel-default">
            <div class="panel-heading">
                <h3 class="panel-title">
                    Extend Rental #@Model.Rental.Id
                    @if (Model.Rental.Status == Vidly.Models.RentalStatus.Overdue)
                    {
                        <span class="label label-danger pull-right">Overdue</span>
                    }
                    else
                    {
                        <span class="label label-info pull-right">Active</span>
                    }
                </h3>
            </div>
            <div class="panel-body">
                <dl class="dl-horizontal">
                    <dt>Customer</dt>
                    <dd>@(Model.Rental.CustomerName ?? "—")</dd>

                    <dt>Movie</dt>
                    <dd>@(Model.Rental.MovieName ?? "—")</dd>

                    <dt>Rented On</dt>
                    <dd>@Model.Rental.RentalDate.ToString("MMMM dd, yyyy")</dd>

                    <dt>Current Due Date</dt>
                    <dd>
                        @Model.Rental.DueDate.ToString("MMMM dd, yyyy")
                        @if (Model.Rental.IsOverdue)
                        {
                            <span class="label label-danger">@Model.Rental.DaysOverdue day(s) overdue</span>
                        }
                    </dd>

                    <dt>Daily Rate</dt>
                    <dd>$@Model.Rental.DailyRate.ToString("F2")</dd>

                    <dt>Extension Fee/Day</dt>
                    <dd>$@Model.ExtensionFeePerDay.ToString("F2") <small class="text-muted">(50% of daily rate)</small></dd>
                </dl>

                <hr />

                @using (Html.BeginForm("Extend", "Rentals", new { id = Model.Rental.Id }, FormMethod.Post))
                {
                    @Html.AntiForgeryToken()
                    @Html.ValidationSummary(true, "", new { @class = "text-danger" })

                    <div class="form-group">
                        @Html.LabelFor(m => m.ExtensionDays, new { @class = "control-label" })
                        @Html.DropDownListFor(m => m.ExtensionDays,
                            Enumerable.Range(1, 7).Select(d => new SelectListItem
                            {
                                Value = d.ToString(),
                                Text = d + (d == 1 ? " day" : " days") + " — $" + (Model.ExtensionFeePerDay * d).ToString("F2") + " fee",
                                Selected = d == Model.ExtensionDays
                            }),
                            new { @class = "form-control" })
                        @Html.ValidationMessageFor(m => m.ExtensionDays, "", new { @class = "text-danger" })
                    </div>

                    <div class="alert alert-info">
                        <strong>New Due Date:</strong>
                        <span id="newDueDate">@Model.Rental.DueDate.AddDays(Model.ExtensionDays).ToString("MMMM dd, yyyy")</span>
                        <br />
                        <small>Each rental can only be extended once.</small>
                    </div>

                    <button type="submit" class="btn btn-primary"
                            onclick="return confirm('Extend this rental? An extension fee will be applied.');">
                        <span class="glyphicon glyphicon-calendar"></span> Extend Rental
                    </button>
                    @Html.ActionLink("Cancel", "Details", new { id = Model.Rental.Id }, new { @class = "btn btn-default" })
                }
            </div>
        </div>
    </div>
</div>
