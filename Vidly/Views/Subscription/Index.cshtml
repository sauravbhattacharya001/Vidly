@model Vidly.ViewModels.SubscriptionViewModel
@{
    ViewBag.Title = "Subscriptions";
}

<h2><span class="glyphicon glyphicon-credit-card"></span> Subscription Plans</h2>
<p class="lead">Choose a monthly plan for unlimited or discounted rentals, free reservations, and more.</p>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible">
        <button type="button" class="close" data-dismiss="alert">&times;</button>
        <span class="glyphicon glyphicon-ok"></span> @TempData["Success"]
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible">
        <button type="button" class="close" data-dismiss="alert">&times;</button>
        <span class="glyphicon glyphicon-exclamation-sign"></span> @TempData["Error"]
    </div>
}
@if (!string.IsNullOrEmpty(Model.StatusMessage))
{
    <div class="alert alert-info">@Model.StatusMessage</div>
}

<!-- Customer Selector -->
<div class="well">
    <form method="get" action="@Url.Action("Index")" class="form-inline">
        <div class="form-group" style="margin-right: 15px;">
            <label for="customerId">Customer: </label>
            <select name="customerId" id="customerId" class="form-control" style="margin-left: 8px;">
                <option value="">— Select Customer —</option>
                @foreach (var c in Model.Customers)
                {
                    <option value="@c.Id" @(Model.SelectedCustomerId == c.Id ? "selected" : "")>@c.Name</option>
                }
            </select>
        </div>
        <button type="submit" class="btn btn-primary">
            <span class="glyphicon glyphicon-user"></span> View Subscription
        </button>
    </form>
</div>

<!-- Plan Comparison Cards -->
<h3>Available Plans</h3>
<div class="row">
    @foreach (var plan in Model.AvailablePlans)
    {
        var isCurrentPlan = Model.Subscription != null && Model.Subscription.PlanType == plan.PlanType;
        var panelClass = isCurrentPlan ? "panel-success" : plan.PlanType.ToString() == "Premium" ? "panel-warning" : "panel-default";

        <div class="col-md-4">
            <div class="panel @panelClass">
                <div class="panel-heading text-center">
                    <h3 class="panel-title">
                        @plan.Name
                        @if (isCurrentPlan)
                        {
                            <span class="label label-success">Current</span>
                        }
                    </h3>
                </div>
                <div class="panel-body text-center">
                    <h2 style="margin-top: 0;">
                        <sup style="font-size: 18px;">$</sup>@plan.MonthlyPrice.ToString("F2")
                        <small>/month</small>
                    </h2>
                    <ul class="list-unstyled" style="margin: 15px 0;">
                        <li>
                            <span class="glyphicon glyphicon-film"></span>
                            @(plan.RentalsPerMonth == 0 ? "Unlimited" : plan.RentalsPerMonth.ToString()) rentals/month
                        </li>
                        <li>
                            <span class="glyphicon glyphicon-tag"></span>
                            @(plan.OverageDiscountPercent > 0 ? plan.OverageDiscountPercent + "% overage discount" : "No overage discount")
                        </li>
                        <li>
                            <span class="glyphicon glyphicon-bookmark"></span>
                            @(plan.FreeReservations ? "Free reservations" : "Standard reservations")
                        </li>
                        <li>
                            <span class="glyphicon glyphicon-time"></span>
                            @(plan.ExtraGraceDays > 0 ? "+" + plan.ExtraGraceDays + " grace days" : "Standard due dates")
                        </li>
                        <li>
                            <span class="glyphicon glyphicon-pause"></span>
                            @plan.MaxPausesPerYear pause(s)/year
                        </li>
                    </ul>

                    @if (Model.SelectedCustomer != null && Model.Subscription == null)
                    {
                        using (Html.BeginForm("Subscribe", "Subscription"))
                        {
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="customerId" value="@Model.SelectedCustomerId" />
                            <input type="hidden" name="planType" value="@((int)plan.PlanType)" />
                            <button type="submit" class="btn btn-primary btn-block">
                                <span class="glyphicon glyphicon-plus"></span> Subscribe
                            </button>
                        }
                    }
                    else if (Model.Subscription != null && !isCurrentPlan && Model.Subscription.Status == Vidly.Models.SubscriptionStatus.Active)
                    {
                        using (Html.BeginForm("ChangePlan", "Subscription"))
                        {
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="customerId" value="@Model.SelectedCustomerId" />
                            <input type="hidden" name="subscriptionId" value="@Model.Subscription.Id" />
                            <input type="hidden" name="newPlanType" value="@((int)plan.PlanType)" />
                            var label = plan.MonthlyPrice > Vidly.Services.SubscriptionService.GetPlan(Model.Subscription.PlanType).MonthlyPrice ? "Upgrade" : "Downgrade";
                            <button type="submit" class="btn btn-default btn-block">
                                <span class="glyphicon glyphicon-transfer"></span> @label
                            </button>
                        }
                    }
                </div>
            </div>
        </div>
    }
</div>

<!-- Current Subscription Details -->
@if (Model.Subscription != null && Model.Usage != null)
{
    var sub = Model.Subscription;
    var usage = Model.Usage;
    var statusLabel = sub.Status == Vidly.Models.SubscriptionStatus.Active ? "label-success"
                    : sub.Status == Vidly.Models.SubscriptionStatus.Paused ? "label-warning"
                    : sub.Status == Vidly.Models.SubscriptionStatus.PastDue ? "label-danger"
                    : "label-default";

    <hr />
    <h3>
        <span class="glyphicon glyphicon-stats"></span>
        @Model.SelectedCustomer.Name's Subscription
        <span class="label @statusLabel">@sub.Status</span>
    </h3>

    <div class="row">
        <!-- Usage Panel -->
        <div class="col-md-6">
            <div class="panel panel-info">
                <div class="panel-heading"><strong>Usage This Period</strong></div>
                <div class="panel-body">
                    @if (usage.IsUnlimited)
                    {
                        <p><strong>@usage.RentalsUsed</strong> rentals used (unlimited plan)</p>
                    }
                    else
                    {
                        var usagePercent = usage.RentalsAllowed > 0 ? (int)((double)usage.RentalsUsed / usage.RentalsAllowed * 100) : 0;
                        var barClass = usagePercent >= 100 ? "progress-bar-danger" : usagePercent >= 80 ? "progress-bar-warning" : "progress-bar-success";
                        <p><strong>@usage.RentalsUsed</strong> / @usage.RentalsAllowed rentals used</p>
                        <div class="progress">
                            <div class="progress-bar @barClass" role="progressbar"
                                 style="width: @(Math.Min(usagePercent, 100))%; min-width: 2em;">
                                @usagePercent%
                            </div>
                        </div>
                    }

                    <p>
                        <span class="glyphicon glyphicon-calendar"></span>
                        <strong>@usage.DaysRemainingInPeriod</strong> days left in period
                    </p>
                    <div class="progress">
                        <div class="progress-bar progress-bar-info" role="progressbar"
                             style="width: @usage.PeriodProgressPercent%; min-width: 2em;">
                            @usage.PeriodProgressPercent%
                        </div>
                    </div>

                    <p>
                        <span class="glyphicon glyphicon-pause"></span>
                        <strong>@usage.PausesRemaining</strong> pauses remaining this year
                    </p>
                    <p>
                        <span class="glyphicon glyphicon-usd"></span>
                        Total billed: <strong>$@usage.TotalBilled.ToString("F2")</strong>
                    </p>
                </div>
            </div>
        </div>

        <!-- Actions Panel -->
        <div class="col-md-6">
            <div class="panel panel-default">
                <div class="panel-heading"><strong>Manage Subscription</strong></div>
                <div class="panel-body">
                    @if (sub.Status == Vidly.Models.SubscriptionStatus.Active)
                    {
                        using (Html.BeginForm("Pause", "Subscription", FormMethod.Post, new { style = "display:inline; margin-right: 8px;" }))
                        {
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="customerId" value="@Model.SelectedCustomerId" />
                            <input type="hidden" name="subscriptionId" value="@sub.Id" />
                            <button type="submit" class="btn btn-warning">
                                <span class="glyphicon glyphicon-pause"></span> Pause
                            </button>
                        }
                    }
                    @if (sub.Status == Vidly.Models.SubscriptionStatus.Paused)
                    {
                        using (Html.BeginForm("Resume", "Subscription", FormMethod.Post, new { style = "display:inline; margin-right: 8px;" }))
                        {
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="customerId" value="@Model.SelectedCustomerId" />
                            <input type="hidden" name="subscriptionId" value="@sub.Id" />
                            <button type="submit" class="btn btn-success">
                                <span class="glyphicon glyphicon-play"></span> Resume
                            </button>
                        }
                    }
                    @if (sub.Status == Vidly.Models.SubscriptionStatus.Active || sub.Status == Vidly.Models.SubscriptionStatus.Paused)
                    {
                        <hr />
                        <p><strong>Cancel Subscription</strong></p>
                        using (Html.BeginForm("Cancel", "Subscription"))
                        {
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="customerId" value="@Model.SelectedCustomerId" />
                            <input type="hidden" name="subscriptionId" value="@sub.Id" />
                            <div class="form-group">
                                <input type="text" name="reason" class="form-control" placeholder="Reason (optional)" />
                            </div>
                            <button type="submit" class="btn btn-danger"
                                    onclick="return confirm('Are you sure you want to cancel?');">
                                <span class="glyphicon glyphicon-remove"></span> Cancel Subscription
                            </button>
                        }
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- Billing History -->
    @if (sub.BillingHistory != null && sub.BillingHistory.Count > 0)
    {
        <h4><span class="glyphicon glyphicon-list"></span> Billing History</h4>
        <table class="table table-striped table-condensed">
            <thead>
                <tr>
                    <th>Date</th>
                    <th>Event</th>
                    <th>Amount</th>
                    <th>Description</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var evt in sub.BillingHistory.OrderByDescending(e => e.Timestamp))
                {
                    var rowClass = evt.EventType == "charge" ? "" : evt.EventType == "refund" ? "success" : evt.EventType == "cancellation" ? "danger" : "info";
                    <tr class="@rowClass">
                        <td>@evt.Timestamp.ToString("MMM dd, yyyy h:mm tt")</td>
                        <td><span class="label label-default">@evt.EventType</span></td>
                        <td>@(evt.Amount != 0 ? "$" + evt.Amount.ToString("F2") : "—")</td>
                        <td>@evt.Description</td>
                    </tr>
                }
            </tbody>
        </table>
    }
}
else if (Model.SelectedCustomer != null && Model.Subscription == null)
{
    <div class="alert alert-info">
        <span class="glyphicon glyphicon-info-sign"></span>
        <strong>@Model.SelectedCustomer.Name</strong> doesn't have an active subscription. Choose a plan above to get started!
    </div>
}

<!-- Revenue Overview -->
@if (Model.Revenue != null)
{
    <hr />
    <h3><span class="glyphicon glyphicon-usd"></span> Revenue Overview</h3>
    <div class="row">
        <div class="col-md-3">
            <div class="panel panel-success">
                <div class="panel-body text-center">
                    <h4>$@Model.Revenue.MonthlyRecurringRevenue.ToString("F2")</h4>
                    <small class="text-muted">Monthly Recurring Revenue</small>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="panel panel-info">
                <div class="panel-body text-center">
                    <h4>$@Model.Revenue.TotalLifetimeRevenue.ToString("F2")</h4>
                    <small class="text-muted">Lifetime Revenue</small>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="panel panel-primary">
                <div class="panel-body text-center">
                    <h4>@Model.Revenue.TotalSubscribers</h4>
                    <small class="text-muted">Active Subscribers</small>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="panel panel-default">
                <div class="panel-body text-center">
                    <h4>@Model.Revenue.ChurnedSubscribers</h4>
                    <small class="text-muted">Churned</small>
                </div>
            </div>
        </div>
    </div>

    @if (Model.Revenue.ActiveSubscribersByPlan != null && Model.Revenue.ActiveSubscribersByPlan.Count > 0)
    {
        <div class="row">
            @foreach (var kv in Model.Revenue.ActiveSubscribersByPlan)
            {
                <div class="col-md-4">
                    <div class="well text-center">
                        <h4>@kv.Value</h4>
                        <small>@kv.Key subscribers</small>
                    </div>
                </div>
            }
        </div>
    }
}
