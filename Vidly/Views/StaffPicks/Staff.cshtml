@model System.Collections.Generic.List<Vidly.Models.StaffPickViewModel>
@{
    ViewBag.Title = "Staff Picks by " + ViewBag.StaffName;
}

<div class="container" style="margin-top: 20px;">
    <div class="page-header">
        <h1>
            <span class="glyphicon glyphicon-user"></span> @ViewBag.StaffName's Picks
            <small>@Model.Count recommendations</small>
        </h1>
        <a href="@Url.Action("Index")" class="btn btn-default">
            <span class="glyphicon glyphicon-arrow-left"></span> All Staff Picks
        </a>
    </div>

    @foreach (var pick in Model)
    {
        <div class="panel panel-default">
            <div class="panel-body">
                <div class="row">
                    <div class="col-md-4">
                        <h4>@pick.Movie.Name</h4>
                        @if (pick.Movie.Genre.HasValue) { <span class="label label-info">@pick.Movie.Genre</span> }
                        @if (pick.Movie.Rating.HasValue)
                        {
                            for (int i = 0; i < pick.Movie.Rating.Value; i++)
                            {
                                <span class="glyphicon glyphicon-star" style="color: #f0ad4e;"></span>
                            }
                        }
                    </div>
                    <div class="col-md-6">
                        <blockquote>
                            <p>@pick.Pick.Note</p>
                            <footer>in <em>@pick.Pick.Theme</em></footer>
                        </blockquote>
                    </div>
                    <div class="col-md-2 text-right">
                        <small class="text-muted">@pick.Pick.PickedDate.ToString("MMM d, yyyy")</small>
                    </div>
                </div>
            </div>
        </div>
    }

    @if (Model.Count == 0)
    {
        <div class="alert alert-info">No picks from this staff member yet.</div>
    }
</div>
