@model Vidly.Services.CustomerHealthResult
@{ Layout = null; }
<!DOCTYPE html>
<html>
<head>
<title>@Model.CustomerName Health - Vidly</title>
<style>
*{box-sizing:border-box;margin:0;padding:0}
body{font-family:'Segoe UI',system-ui,sans-serif;background:#0f1117;color:#e0e0e0;padding:20px;max-width:1000px;margin:0 auto}
a{color:#60a5fa;text-decoration:none}a:hover{text-decoration:underline}
h1{font-size:1.6em;margin-bottom:4px;color:#fff}
.back{margin-bottom:16px;display:inline-block}
.header{display:flex;align-items:center;gap:16px;margin-bottom:24px;flex-wrap:wrap}
.score-big{font-size:3em;font-weight:700}
.tier{padding:4px 14px;border-radius:16px;font-size:.85em;font-weight:600}
.tier-Thriving{background:#0d4d2a;color:#4ade80}
.tier-Healthy{background:#1e3a5f;color:#60a5fa}
.tier-AtRisk{background:#4a3620;color:#fbbf24}
.tier-Critical{background:#4a2020;color:#f87171}
.tier-Churned{background:#3a1a1a;color:#888}
.trend-Improving{color:#4ade80}.trend-Stable{color:#888}.trend-Declining{color:#f87171}
.grid{display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-bottom:24px}
@media(max-width:700px){.grid{grid-template-columns:1fr}}
.panel{background:#1a1d27;border-radius:12px;padding:20px}
.panel h2{font-size:1em;color:#aaa;margin-bottom:12px}
.dim{margin-bottom:12px}
.dim-label{display:flex;justify-content:space-between;font-size:.85em;margin-bottom:4px}
.dim-bar{height:8px;background:#2a2d37;border-radius:4px;overflow:hidden}
.dim-fill{height:100%;border-radius:4px;transition:width .6s}
.rec{padding:10px 14px;background:#1f2233;border-radius:8px;margin-bottom:8px;font-size:.9em}
.rental{display:flex;justify-content:space-between;padding:8px 0;border-bottom:1px solid #2a2d37;font-size:.85em}
.rental:last-child{border:none}
.late{color:#f87171}
</style>
</head>
<body>
<a href="@Url.Action("Index","CustomerHealth")" class="back">← Back to Dashboard</a>
<div class="header">
    <div>
        <h1>@Model.CustomerName</h1>
        <span class="tier tier-@Model.Tier">@Model.Tier</span>
        <span class="trend-@Model.Trend" style="margin-left:8px;font-size:.9em">
            @(Model.Trend==Vidly.Services.TrendDirection.Improving?"↗ Improving":Model.Trend==Vidly.Services.TrendDirection.Declining?"↘ Declining":"→ Stable")
        </span>
    </div>
    <div class="score-big" style="color:@ScoreColor(Model.HealthScore)">@Model.HealthScore</div>
</div>

<div class="grid">
    <div class="panel">
        <h2>Health Dimensions</h2>
        @foreach(var d in Model.Dimensions){
            var pct = d.Max>0 ? (d.Score/d.Max*100) : 0;
            var color = pct>=75?"#4ade80":pct>=50?"#60a5fa":pct>=30?"#fbbf24":"#f87171";
            <div class="dim">
                <div class="dim-label"><span>@d.Name</span><span>@d.Score / @d.Max</span></div>
                <div class="dim-bar"><div class="dim-fill" style="width:@(pct)%;background:@color"></div></div>
                <div style="font-size:.75em;color:#666;margin-top:2px">@d.Detail</div>
            </div>
        }
    </div>
    <div class="panel">
        <h2>Genre Diversity</h2>
        <canvas id="genreChart" width="280" height="280"></canvas>
    </div>
</div>

<div class="grid">
    <div class="panel">
        <h2>💡 Recommendations</h2>
        @foreach(var r in Model.Recommendations){
            <div class="rec">@r</div>
        }
    </div>
    <div class="panel">
        <h2>Recent Rentals</h2>
        @foreach(var r in Model.RecentRentals){
            <div class="rental">
                <span>@r.MovieName <span style="color:#666">(@r.Genre)</span></span>
                <span>
                    @r.DateRented.ToString("MMM d")
                    @if(r.WasLate){<span class="late"> — Late</span>}
                    <span style="color:#888"> $@r.AmountPaid</span>
                </span>
            </div>
        }
    </div>
</div>

<script>
(function(){
    var c=document.getElementById('genreChart'),ctx=c.getContext('2d');
    var genres=@Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(Model.GenreDistribution));
    var keys=Object.keys(genres),vals=keys.map(function(k){return genres[k]});
    var total=vals.reduce(function(a,b){return a+b},0);
    if(!total)return;
    var colors=['#4ade80','#60a5fa','#fbbf24','#f87171','#a78bfa','#f472b6','#fb923c','#34d399','#e879f9','#94a3b8'];
    var cx=140,cy=140,r=110,ir=55,a=-Math.PI/2;
    for(var i=0;i<keys.length;i++){
        var slice=vals[i]/total*2*Math.PI;
        ctx.beginPath();ctx.moveTo(cx+Math.cos(a)*ir,cy+Math.sin(a)*ir);
        ctx.arc(cx,cy,r,a,a+slice);var ea=a+slice;
        ctx.lineTo(cx+Math.cos(ea)*ir,cy+Math.sin(ea)*ir);
        ctx.arc(cx,cy,ir,ea,a,true);ctx.closePath();
        ctx.fillStyle=colors[i%colors.length];ctx.fill();
        var mid=a+slice/2;
        if(slice>0.3){ctx.fillStyle='#fff';ctx.font='11px sans-serif';ctx.textAlign='center';
        ctx.fillText(keys[i],cx+Math.cos(mid)*(r-30),cy+Math.sin(mid)*(r-30));}
        a+=slice;
    }
})();
</script>
</body>
</html>

@functions{
    string ScoreColor(double s){
        if(s>=80)return"#4ade80";if(s>=60)return"#60a5fa";if(s>=40)return"#fbbf24";if(s>=20)return"#f87171";return"#888";
    }
}
