@model Vidly.ViewModels.DamageViewModel

@{
    ViewBag.Title = "Damage Assessment";
}

<h2><span class="glyphicon glyphicon-alert"></span> Damage Assessment</h2>
<p class="text-muted">Log and track damage to returned rentals. Assess fees, resolve reports, and monitor trends.</p>

@if (!string.IsNullOrEmpty(Model.StatusMessage))
{
    <div class="alert @(Model.IsError ? "alert-danger" : "alert-success") alert-dismissible" role="alert">
        <button type="button" class="close" data-dismiss="alert">&times;</button>
        @Model.StatusMessage
    </div>
}

<!-- Summary Cards -->
<div class="row" style="margin-bottom: 20px;">
    <div class="col-md-2">
        <div class="panel panel-default text-center">
            <div class="panel-body">
                <h3>@Model.Summary.TotalReports</h3>
                <small class="text-muted">Total Reports</small>
            </div>
        </div>
    </div>
    <div class="col-md-2">
        <div class="panel panel-warning text-center">
            <div class="panel-body">
                <h3>@Model.Summary.OpenReports</h3>
                <small class="text-muted">Open / Pending</small>
            </div>
        </div>
    </div>
    <div class="col-md-2">
        <div class="panel panel-success text-center">
            <div class="panel-body">
                <h3>@Model.Summary.ResolvedReports</h3>
                <small class="text-muted">Resolved</small>
            </div>
        </div>
    </div>
    <div class="col-md-2">
        <div class="panel panel-info text-center">
            <div class="panel-body">
                <h3>@Model.Summary.TotalFeesAssessed.ToString("C")</h3>
                <small class="text-muted">Total Assessed</small>
            </div>
        </div>
    </div>
    <div class="col-md-2">
        <div class="panel panel-success text-center">
            <div class="panel-body">
                <h3>@Model.Summary.TotalFeesCollected.ToString("C")</h3>
                <small class="text-muted">Collected</small>
            </div>
        </div>
    </div>
    <div class="col-md-2">
        <div class="panel panel-default text-center">
            <div class="panel-body">
                <h3>@Model.Summary.TotalFeesWaived.ToString("C")</h3>
                <small class="text-muted">Waived</small>
            </div>
        </div>
    </div>
</div>

<!-- Filters -->
<div class="row" style="margin-bottom: 15px;">
    <div class="col-md-12">
        <div class="btn-group">
            <a href="@Url.Action("Index")" class="btn btn-default @(Model.FilterStatus == null && Model.FilterSeverity == null ? "active" : "")">All</a>
            <a href="@Url.Action("Index", new { status = "Open" })" class="btn btn-default @(Model.FilterStatus == Vidly.Models.DamageStatus.Open ? "active" : "")">Open</a>
            <a href="@Url.Action("Index", new { status = "Assessed" })" class="btn btn-default @(Model.FilterStatus == Vidly.Models.DamageStatus.Assessed ? "active" : "")">Assessed</a>
            <a href="@Url.Action("Index", new { status = "Disputed" })" class="btn btn-default @(Model.FilterStatus == Vidly.Models.DamageStatus.Disputed ? "active" : "")">Disputed</a>
            <a href="@Url.Action("Index", new { status = "Paid" })" class="btn btn-default @(Model.FilterStatus == Vidly.Models.DamageStatus.Paid ? "active" : "")">Paid</a>
            <a href="@Url.Action("Index", new { status = "Waived" })" class="btn btn-default @(Model.FilterStatus == Vidly.Models.DamageStatus.Waived ? "active" : "")">Waived</a>
        </div>
        &nbsp;
        <div class="btn-group">
            <a href="@Url.Action("Index", new { severity = "Minor" })" class="btn btn-sm btn-info @(Model.FilterSeverity == Vidly.Models.DamageSeverity.Minor ? "active" : "")">Minor</a>
            <a href="@Url.Action("Index", new { severity = "Moderate" })" class="btn btn-sm btn-warning @(Model.FilterSeverity == Vidly.Models.DamageSeverity.Moderate ? "active" : "")">Moderate</a>
            <a href="@Url.Action("Index", new { severity = "Severe" })" class="btn btn-sm btn-danger @(Model.FilterSeverity == Vidly.Models.DamageSeverity.Severe ? "active" : "")">Severe</a>
            <a href="@Url.Action("Index", new { severity = "Destroyed" })" class="btn btn-sm btn-default @(Model.FilterSeverity == Vidly.Models.DamageSeverity.Destroyed ? "active" : "")">Destroyed</a>
        </div>
    </div>
</div>

<!-- New Report Form -->
<div class="panel panel-primary">
    <div class="panel-heading">
        <h3 class="panel-title"><span class="glyphicon glyphicon-plus"></span> File Damage Report</h3>
    </div>
    <div class="panel-body">
        @using (Html.BeginForm("Report", "Damage", FormMethod.Post))
        {
            @Html.AntiForgeryToken()
            <div class="row">
                <div class="col-md-3">
                    <div class="form-group">
                        <label>Customer</label>
                        <select name="customerId" class="form-control" required>
                            <option value="">-- Select --</option>
                            @foreach (var c in Model.Customers)
                            {
                                <option value="@c.Id">@c.Name</option>
                            }
                        </select>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="form-group">
                        <label>Movie</label>
                        <select name="movieId" class="form-control" required>
                            <option value="">-- Select --</option>
                            @foreach (var m in Model.Movies)
                            {
                                <option value="@m.Id">@m.Name</option>
                            }
                        </select>
                    </div>
                </div>
                <div class="col-md-2">
                    <div class="form-group">
                        <label>Damage Type</label>
                        <select name="damageType" class="form-control">
                            @foreach (var dt in Enum.GetValues(typeof(Vidly.Models.DamageType)))
                            {
                                <option value="@dt">@dt</option>
                            }
                        </select>
                    </div>
                </div>
                <div class="col-md-2">
                    <div class="form-group">
                        <label>Severity</label>
                        <select name="severity" class="form-control">
                            @foreach (var s in Enum.GetValues(typeof(Vidly.Models.DamageSeverity)))
                            {
                                <option value="@s">@s</option>
                            }
                        </select>
                    </div>
                </div>
                <div class="col-md-2">
                    <div class="form-group">
                        <label>Fee ($)</label>
                        <input type="number" name="assessedFee" class="form-control" step="0.50" min="0" value="0.00" />
                    </div>
                </div>
            </div>
            <div class="row">
                <div class="col-md-10">
                    <div class="form-group">
                        <label>Description</label>
                        <input type="text" name="description" class="form-control" placeholder="Describe the damage observed..." required />
                    </div>
                </div>
                <div class="col-md-2">
                    <div class="form-group">
                        <label>&nbsp;</label>
                        <button type="submit" class="btn btn-primary btn-block">File Report</button>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<!-- Reports Table -->
<div class="panel panel-default">
    <div class="panel-heading"><h3 class="panel-title">Damage Reports</h3></div>
    <table class="table table-striped table-hover">
        <thead>
            <tr>
                <th>#</th>
                <th>Customer</th>
                <th>Movie</th>
                <th>Type</th>
                <th>Severity</th>
                <th>Fee</th>
                <th>Status</th>
                <th>Reported</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var r in Model.Reports)
            {
                var severityClass = r.Severity == Vidly.Models.DamageSeverity.Minor ? "info"
                    : r.Severity == Vidly.Models.DamageSeverity.Moderate ? "warning"
                    : r.Severity == Vidly.Models.DamageSeverity.Severe ? "danger"
                    : "default";
                var statusClass = r.Status == Vidly.Models.DamageStatus.Paid ? "success"
                    : r.Status == Vidly.Models.DamageStatus.Waived ? "default"
                    : r.Status == Vidly.Models.DamageStatus.Disputed ? "danger"
                    : "warning";
                <tr>
                    <td>@r.Id</td>
                    <td>@r.CustomerName</td>
                    <td>@r.MovieTitle</td>
                    <td>@r.DamageType</td>
                    <td><span class="label label-@severityClass">@r.Severity</span></td>
                    <td>@r.AssessedFee.ToString("C")</td>
                    <td><span class="label label-@statusClass">@r.Status</span></td>
                    <td>@r.ReportedAt.ToString("MMM d, yyyy")</td>
                    <td>
                        @if (r.Status != Vidly.Models.DamageStatus.Paid && r.Status != Vidly.Models.DamageStatus.Waived)
                        {
                            using (Html.BeginForm("Resolve", "Damage", FormMethod.Post, new { style = "display:inline" }))
                            {
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@r.Id" />
                                <input type="hidden" name="staffNotes" value="" />
                                <button type="submit" name="resolution" value="Paid" class="btn btn-xs btn-success" title="Mark as paid">
                                    <span class="glyphicon glyphicon-ok"></span> Paid
                                </button>
                                <button type="submit" name="resolution" value="Waived" class="btn btn-xs btn-default" title="Waive fee">
                                    <span class="glyphicon glyphicon-remove"></span> Waive
                                </button>
                            }
                        }
                        else
                        {
                            <span class="text-muted">@(r.ResolvedAt?.ToString("MMM d") ?? "—")</span>
                        }
                    </td>
                </tr>
                @if (!string.IsNullOrEmpty(r.Description) || !string.IsNullOrEmpty(r.StaffNotes))
                {
                    <tr class="active">
                        <td></td>
                        <td colspan="8">
                            <small>
                                @if (!string.IsNullOrEmpty(r.Description))
                                {
                                    <strong>Description:</strong> @r.Description
                                }
                                @if (!string.IsNullOrEmpty(r.StaffNotes))
                                {
                                    <text> &mdash; </text><strong>Staff:</strong> @r.StaffNotes
                                }
                            </small>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>
