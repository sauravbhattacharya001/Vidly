@model Vidly.Services.HabitCoachViewModel
@{
    ViewBag.Title = "Rental Habit Coach";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>🏋️ Rental Habit Coach</title>
    <style>
        :root {
            --bg: #0f1117;
            --surface: #1a1d27;
            --surface2: #232736;
            --accent: #6c5ce7;
            --accent2: #a29bfe;
            --green: #00b894;
            --yellow: #fdcb6e;
            --red: #d63031;
            --orange: #e17055;
            --text: #dfe6e9;
            --text-dim: #8395a7;
            --border: #2d3142;
            --radius: 12px;
        }
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: 'Segoe UI', system-ui, -apple-system, sans-serif; background: var(--bg); color: var(--text); min-height: 100vh; }

        .header { background: linear-gradient(135deg, #6c5ce7 0%, #a29bfe 100%); padding: 2rem; text-align: center; }
        .header h1 { font-size: 2rem; margin-bottom: 0.5rem; }
        .header p { opacity: 0.9; font-size: 1rem; }

        .container { max-width: 1200px; margin: 0 auto; padding: 1.5rem; }

        .selector { background: var(--surface); padding: 1.5rem; border-radius: var(--radius); margin-bottom: 1.5rem; display: flex; align-items: center; gap: 1rem; flex-wrap: wrap; }
        .selector label { font-weight: 600; font-size: 1rem; }
        .selector select { padding: 0.6rem 1rem; border-radius: 8px; border: 1px solid var(--border); background: var(--surface2); color: var(--text); font-size: 1rem; min-width: 250px; }
        .selector button { padding: 0.6rem 1.5rem; border-radius: 8px; border: none; background: var(--accent); color: white; font-size: 1rem; cursor: pointer; font-weight: 600; }
        .selector button:hover { background: var(--accent2); }

        .error { background: rgba(214,48,49,0.15); border: 1px solid var(--red); padding: 1rem; border-radius: var(--radius); color: var(--red); margin-bottom: 1rem; }

        .grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(340px, 1fr)); gap: 1.5rem; margin-bottom: 1.5rem; }
        .card { background: var(--surface); border-radius: var(--radius); padding: 1.5rem; border: 1px solid var(--border); }
        .card h3 { margin-bottom: 1rem; font-size: 1.1rem; color: var(--accent2); }
        .card-wide { grid-column: 1 / -1; }

        /* Wellness Gauge */
        .gauge-container { text-align: center; padding: 1rem 0; }
        .gauge-svg { width: 180px; height: 110px; }
        .gauge-label { font-size: 2.5rem; font-weight: 700; margin-top: 0.5rem; }
        .gauge-grade { font-size: 1.5rem; font-weight: 600; margin-top: 0.25rem; }
        .gauge-subtitle { color: var(--text-dim); font-size: 0.9rem; margin-top: 0.25rem; }

        /* Stats */
        .stat-row { display: flex; justify-content: space-between; align-items: center; padding: 0.6rem 0; border-bottom: 1px solid var(--border); }
        .stat-row:last-child { border-bottom: none; }
        .stat-label { color: var(--text-dim); font-size: 0.9rem; }
        .stat-value { font-weight: 600; font-size: 1rem; }

        /* Bar chart */
        .bar-chart { display: flex; align-items: flex-end; gap: 6px; height: 120px; padding-top: 0.5rem; }
        .bar-col { flex: 1; display: flex; flex-direction: column; align-items: center; gap: 4px; height: 100%; justify-content: flex-end; }
        .bar { width: 100%; border-radius: 4px 4px 0 0; transition: height 0.3s; min-height: 2px; }
        .bar-label { font-size: 0.7rem; color: var(--text-dim); white-space: nowrap; }
        .bar-value { font-size: 0.75rem; font-weight: 600; }

        /* Day heatmap */
        .day-grid { display: grid; grid-template-columns: repeat(7, 1fr); gap: 6px; }
        .day-cell { text-align: center; padding: 0.8rem 0.4rem; border-radius: 8px; }
        .day-name { font-size: 0.7rem; color: var(--text-dim); margin-bottom: 4px; }
        .day-count { font-size: 1.2rem; font-weight: 700; }

        /* Goals */
        .goal-card { background: var(--surface2); border-radius: 10px; padding: 1.2rem; margin-bottom: 0.8rem; }
        .goal-header { display: flex; align-items: center; gap: 0.5rem; margin-bottom: 0.5rem; }
        .goal-emoji { font-size: 1.5rem; }
        .goal-title { font-weight: 700; font-size: 1rem; }
        .goal-difficulty { font-size: 0.75rem; padding: 2px 8px; border-radius: 12px; font-weight: 600; }
        .goal-desc { color: var(--text-dim); font-size: 0.9rem; margin-bottom: 0.5rem; }
        .goal-rationale { font-size: 0.8rem; color: var(--text-dim); font-style: italic; margin-bottom: 0.7rem; }
        .progress-bar { height: 8px; background: var(--surface); border-radius: 4px; overflow: hidden; }
        .progress-fill { height: 100%; border-radius: 4px; transition: width 0.5s; }
        .progress-text { font-size: 0.75rem; color: var(--text-dim); margin-top: 4px; }

        /* Nudges */
        .nudge { display: flex; align-items: flex-start; gap: 0.8rem; padding: 1rem; background: var(--surface2); border-radius: 10px; margin-bottom: 0.6rem; }
        .nudge-emoji { font-size: 1.3rem; flex-shrink: 0; }
        .nudge-body { flex: 1; }
        .nudge-msg { font-size: 0.95rem; line-height: 1.4; }
        .nudge-meta { display: flex; gap: 0.5rem; margin-top: 0.3rem; }
        .nudge-tag { font-size: 0.7rem; padding: 2px 8px; border-radius: 10px; font-weight: 600; }

        /* Engagement sparkline */
        .sparkline-container { padding: 0.5rem 0; }
        .sparkline-svg { width: 100%; height: 60px; }

        .empty-state { text-align: center; padding: 4rem 2rem; }
        .empty-state .emoji { font-size: 4rem; margin-bottom: 1rem; }
        .empty-state p { color: var(--text-dim); font-size: 1.1rem; }

        /* Badge/pill */
        .pill { display: inline-block; padding: 3px 10px; border-radius: 12px; font-size: 0.8rem; font-weight: 600; }

        @@media (max-width: 600px) {
            .grid { grid-template-columns: 1fr; }
            .header h1 { font-size: 1.5rem; }
            .day-grid { grid-template-columns: repeat(7, 1fr); gap: 3px; }
            .day-cell { padding: 0.4rem 0.2rem; }
        }
    </style>
</head>
<body>
    <div class="header">
        <h1>🏋️ Rental Habit Coach</h1>
        <p>Autonomous analysis of your rental patterns with personalized coaching</p>
    </div>

    <div class="container">
        <form class="selector" method="get">
            <label for="customerId">👤 Customer:</label>
            <select name="customerId" id="customerId">
                <option value="">— Select a customer —</option>
                @if (Model.Customers != null)
                {
                    foreach (var c in Model.Customers)
                    {
                        <option value="@c.Id" @(Model.SelectedCustomerId == c.Id ? "selected" : "")>@c.Name</option>
                    }
                }
            </select>
            <button type="submit">Analyze</button>
        </form>

        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="error">⚠️ @Model.ErrorMessage</div>
        }

        @if (Model.Report != null)
        {
            var r = Model.Report;
            var gaugeColor = r.OverallWellnessScore >= 75 ? "#00b894" : r.OverallWellnessScore >= 50 ? "#fdcb6e" : r.OverallWellnessScore >= 25 ? "#e17055" : "#d63031";
            var gaugeAngle = 180.0 * r.OverallWellnessScore / 100.0;
            var gaugeRad = gaugeAngle * Math.PI / 180.0;
            var gx = 90 + 70 * Math.Cos(Math.PI - gaugeRad);
            var gy = 95 - 70 * Math.Sin(Math.PI - gaugeRad);

            <!-- Wellness Score -->
            <div class="grid">
                <div class="card" style="text-align:center;">
                    <h3>🎯 Wellness Score</h3>
                    <div class="gauge-container">
                        <svg class="gauge-svg" viewBox="0 0 180 110">
                            <path d="M 20 95 A 70 70 0 0 1 160 95" fill="none" stroke="#2d3142" stroke-width="12" stroke-linecap="round"/>
                            @if (r.OverallWellnessScore > 0)
                            {
                                var largeArc = gaugeAngle > 180 ? 1 : 0;
                                <path d="M 20 95 A 70 70 0 @largeArc 1 @gx.ToString("F1") @gy.ToString("F1")" fill="none" stroke="@gaugeColor" stroke-width="12" stroke-linecap="round"/>
                            }
                        </svg>
                        <div class="gauge-label" style="color: @gaugeColor;">@r.OverallWellnessScore</div>
                        <div class="gauge-grade" style="color: @gaugeColor;">@r.WellnessGrade</div>
                        <div class="gauge-subtitle">Overall Rental Wellness</div>
                    </div>
                </div>

                <div class="card">
                    <h3>🥁 Rhythm</h3>
                    <div class="stat-row">
                        <span class="stat-label">Current State</span>
                        <span class="stat-value">
                            @switch (r.RhythmState)
                            {
                                case "Binge": <text>🔥 Binge</text> break;
                                case "Active": <text>✅ Active</text> break;
                                case "Casual": <text>😌 Casual</text> break;
                                default: <text>💤 Dormant</text> break;
                            }
                        </span>
                    </div>
                    <div class="stat-row">
                        <span class="stat-label">Trend</span>
                        <span class="stat-value">
                            @switch (r.RhythmTrend)
                            {
                                case "Accelerating": <text>🚀 Accelerating</text> break;
                                case "Decelerating": <text>📉 Decelerating</text> break;
                                default: <text>➡️ Stable</text> break;
                            }
                        </span>
                    </div>
                    <div class="stat-row">
                        <span class="stat-label">Engagement</span>
                        <span class="stat-value">@r.EngagementScore/100 (@r.EngagementTrend)</span>
                    </div>
                    <div class="stat-row">
                        <span class="stat-label">Avg Monthly Spend</span>
                        <span class="stat-value">$@r.AvgMonthlySpend.ToString("F2")</span>
                    </div>
                </div>

                <div class="card">
                    <h3>🌈 Genre Diversity</h3>
                    <div class="stat-row">
                        <span class="stat-label">Diversity Score</span>
                        <span class="stat-value" style="color: @(r.DiversityScore >= 60 ? "#00b894" : r.DiversityScore >= 30 ? "#fdcb6e" : "#d63031")">@r.DiversityScore%</span>
                    </div>
                    <div class="stat-row">
                        <span class="stat-label">Genre Rut?</span>
                        <span class="stat-value">@(r.InGenreRut ? "⚠️ Yes — too much " + r.DominantGenre : "✅ No")</span>
                    </div>
                    <div class="stat-row">
                        <span class="stat-label">Entropy</span>
                        <span class="stat-value">@r.GenreEntropy / @r.MaxPossibleEntropy</span>
                    </div>
                    @if (r.GenreDistribution.Any())
                    {
                        var maxPct = r.GenreDistribution.Values.Max();
                        <div class="bar-chart" style="margin-top: 0.8rem;">
                            @foreach (var kv in r.GenreDistribution.OrderByDescending(x => x.Value))
                            {
                                var h = maxPct > 0 ? (kv.Value / maxPct * 100) : 0;
                                <div class="bar-col">
                                    <span class="bar-value">@kv.Value%</span>
                                    <div class="bar" style="height: @h%; background: var(--accent);"></div>
                                    <span class="bar-label">@kv.Key</span>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>

            <div class="grid">
                <!-- Timing Heatmap -->
                <div class="card">
                    <h3>📅 Timing — @r.TimingPersona</h3>
                    @if (r.DayOfWeekDistribution.Any())
                    {
                        var maxDay = r.DayOfWeekDistribution.Values.Max();
                        var days = new[] { "Sunday", "Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday" };
                        var dayAbbr = new[] { "Sun", "Mon", "Tue", "Wed", "Thu", "Fri", "Sat" };
                        <div class="day-grid">
                            @for (int i = 0; i < 7; i++)
                            {
                                var count = r.DayOfWeekDistribution.ContainsKey(days[i]) ? r.DayOfWeekDistribution[days[i]] : 0;
                                var intensity = maxDay > 0 ? (double)count / maxDay : 0;
                                var bgColor = intensity > 0.75 ? "rgba(108,92,231,0.6)" : intensity > 0.5 ? "rgba(108,92,231,0.4)" : intensity > 0.25 ? "rgba(108,92,231,0.2)" : "rgba(108,92,231,0.05)";
                                <div class="day-cell" style="background: @bgColor;">
                                    <div class="day-name">@dayAbbr[i]</div>
                                    <div class="day-count">@count</div>
                                </div>
                            }
                        </div>
                    }
                </div>

                <!-- Punctuality -->
                <div class="card">
                    <h3>⏱️ Punctuality — @r.ReturnBehavior</h3>
                    <div class="stat-row">
                        <span class="stat-label">Score</span>
                        <span class="stat-value" style="color: @(r.PunctualityScore >= 80 ? "#00b894" : r.PunctualityScore >= 50 ? "#fdcb6e" : "#d63031")">@r.PunctualityScore%</span>
                    </div>
                    <div class="stat-row">
                        <span class="stat-label">🌅 Early</span>
                        <span class="stat-value">@r.EarlyCount</span>
                    </div>
                    <div class="stat-row">
                        <span class="stat-label">✅ On Time</span>
                        <span class="stat-value">@r.OnTimeCount</span>
                    </div>
                    <div class="stat-row">
                        <span class="stat-label">⏰ Late</span>
                        <span class="stat-value" style="color: @(r.LateCount > 0 ? "#e17055" : "inherit")">@r.LateCount</span>
                    </div>
                    <div class="stat-row">
                        <span class="stat-label">Total Returned</span>
                        <span class="stat-value">@r.TotalReturned</span>
                    </div>
                    @if (r.TotalReturned > 0)
                    {
                        var earlyPct = r.TotalReturned > 0 ? (double)r.EarlyCount / r.TotalReturned * 100 : 0;
                        var onTimePct = r.TotalReturned > 0 ? (double)r.OnTimeCount / r.TotalReturned * 100 : 0;
                        var latePct = r.TotalReturned > 0 ? (double)r.LateCount / r.TotalReturned * 100 : 0;
                        <div style="display:flex; height:12px; border-radius:6px; overflow:hidden; margin-top:0.8rem;">
                            <div style="width:@earlyPct%; background:#00b894;" title="Early: @r.EarlyCount"></div>
                            <div style="width:@onTimePct%; background:#6c5ce7;" title="On Time: @r.OnTimeCount"></div>
                            <div style="width:@latePct%; background:#d63031;" title="Late: @r.LateCount"></div>
                        </div>
                    }
                </div>

                <!-- Spending -->
                <div class="card">
                    <h3>💰 Spending</h3>
                    <div class="stat-row">
                        <span class="stat-label">Avg Monthly</span>
                        <span class="stat-value">$@r.AvgMonthlySpend.ToString("F2")</span>
                    </div>
                    <div class="stat-row">
                        <span class="stat-label">Trend</span>
                        <span class="stat-value">
                            @switch (r.SpendingTrend)
                            {
                                case "Increasing": <text>📈 Increasing</text> break;
                                case "Decreasing": <text>📉 Decreasing</text> break;
                                default: <text>➡️ Stable</text> break;
                            }
                        </span>
                    </div>
                    @if (r.MonthlyHistory.Any())
                    {
                        var maxSpend = r.MonthlyHistory.Max(m => m.Spend);
                        <div class="bar-chart" style="margin-top: 0.8rem; height: 80px;">
                            @foreach (var m in r.MonthlyHistory.TakeLast(6))
                            {
                                var h = maxSpend > 0 ? ((double)m.Spend / (double)maxSpend * 100) : 0;
                                <div class="bar-col">
                                    <span class="bar-value">$@m.Spend.ToString("F0")</span>
                                    <div class="bar" style="height: @h%; background: var(--green);"></div>
                                    <span class="bar-label">@m.Month/@(m.Year % 100)</span>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>

            <!-- Coaching Goals -->
            @if (r.Goals.Any())
            {
                <div class="card card-wide" style="margin-bottom: 1.5rem;">
                    <h3>🎯 Coaching Goals</h3>
                    @foreach (var goal in r.Goals)
                    {
                        var diffColor = goal.Difficulty == "Easy" ? "#00b894" : goal.Difficulty == "Medium" ? "#fdcb6e" : "#e17055";
                        var progress = goal.TargetValue > 0 ? Math.Min(100, goal.CurrentValue / goal.TargetValue * 100) : 0;
                        var progressColor = progress >= 75 ? "#00b894" : progress >= 40 ? "#fdcb6e" : "#6c5ce7";
                        <div class="goal-card">
                            <div class="goal-header">
                                <span class="goal-emoji">@goal.Emoji</span>
                                <span class="goal-title">@goal.Title</span>
                                <span class="goal-difficulty" style="background: @diffColor; color: #1a1d27;">@goal.Difficulty</span>
                            </div>
                            <div class="goal-desc">@goal.Description</div>
                            <div class="goal-rationale">@goal.Rationale</div>
                            <div class="progress-bar">
                                <div class="progress-fill" style="width: @progress%; background: @progressColor;"></div>
                            </div>
                            <div class="progress-text">@goal.TargetMetric: @goal.CurrentValue.ToString("F0") → @goal.TargetValue.ToString("F0")</div>
                        </div>
                    }
                </div>
            }

            <!-- Nudges -->
            @if (r.Nudges.Any())
            {
                <div class="card card-wide">
                    <h3>💡 Coaching Nudges</h3>
                    @foreach (var nudge in r.Nudges)
                    {
                        var prioColor = nudge.Priority == "High" ? "#d63031" : nudge.Priority == "Medium" ? "#fdcb6e" : "#00b894";
                        var catColor = "var(--accent)";
                        <div class="nudge">
                            <span class="nudge-emoji">@nudge.Emoji</span>
                            <div class="nudge-body">
                                <div class="nudge-msg">@nudge.Message</div>
                                <div class="nudge-meta">
                                    <span class="nudge-tag" style="background: @prioColor; color: #1a1d27;">@nudge.Priority</span>
                                    <span class="nudge-tag" style="background: var(--surface); color: var(--text-dim); border: 1px solid var(--border);">@nudge.Category</span>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }

            <!-- Engagement Trend -->
            @if (r.MonthlyHistory.Count > 1)
            {
                <div class="card card-wide" style="margin-top: 1.5rem;">
                    <h3>📊 Engagement History</h3>
                    <div class="sparkline-container">
                        @{
                            var maxCount = r.MonthlyHistory.Max(m => m.RentalCount);
                            var width = 800.0;
                            var height = 60.0;
                            var stepX = r.MonthlyHistory.Count > 1 ? width / (r.MonthlyHistory.Count - 1) : 0;
                            var points = string.Join(" ", r.MonthlyHistory.Select((m, i) =>
                            {
                                var x = i * stepX;
                                var y = maxCount > 0 ? height - (m.RentalCount / (double)maxCount * (height - 10)) - 5 : height - 5;
                                return $"{x:F1},{y:F1}";
                            }));
                        }
                        <svg class="sparkline-svg" viewBox="0 0 @width @height" preserveAspectRatio="none">
                            <polyline points="@points" fill="none" stroke="#6c5ce7" stroke-width="2" stroke-linejoin="round" stroke-linecap="round"/>
                            @for (int i = 0; i < r.MonthlyHistory.Count; i++)
                            {
                                var m = r.MonthlyHistory[i];
                                var x = i * stepX;
                                var y = maxCount > 0 ? height - (m.RentalCount / (double)maxCount * (height - 10)) - 5 : height - 5;
                                <circle cx="@x.ToString("F1")" cy="@y.ToString("F1")" r="3" fill="#a29bfe"/>
                            }
                        </svg>
                    </div>
                </div>
            }
        }
        else if (!Model.SelectedCustomerId.HasValue)
        {
            <div class="empty-state">
                <div class="emoji">🏋️</div>
                <p>Select a customer to analyze their rental habits and get personalized coaching.</p>
            </div>
        }
    </div>
</body>
</html>
