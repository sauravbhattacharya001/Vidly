@model Vidly.Models.AwardsCeremony

@{
    ViewBag.Title = "Vidly Awards " + Model.Year;
}

<style>
    .awards-header {
        text-align: center;
        padding: 40px 0 30px;
        background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
        color: #fff;
        margin: -20px -15px 30px;
        border-radius: 0 0 20px 20px;
    }
    .awards-header h1 {
        font-size: 42px;
        font-weight: 700;
        margin-bottom: 5px;
    }
    .awards-header .trophy-icon {
        font-size: 64px;
        display: block;
        margin-bottom: 10px;
    }
    .awards-header .tagline {
        font-size: 16px;
        opacity: 0.8;
        margin-top: 5px;
    }
    .year-selector {
        text-align: center;
        margin: -10px 0 30px;
    }
    .year-selector .btn {
        margin: 0 3px;
    }
    .year-selector .btn.active {
        background-color: #0f3460;
        color: #fff;
        border-color: #0f3460;
    }
    .summary-cards {
        display: flex;
        justify-content: center;
        gap: 15px;
        flex-wrap: wrap;
        margin-bottom: 35px;
    }
    .summary-card {
        background: #fff;
        border: 1px solid #e0e0e0;
        border-radius: 12px;
        padding: 15px 25px;
        text-align: center;
        min-width: 130px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.06);
    }
    .summary-card .value {
        font-size: 28px;
        font-weight: 700;
        color: #0f3460;
    }
    .summary-card .label {
        font-size: 13px;
        color: #777;
        margin-top: 2px;
    }
    .award-card {
        background: #fff;
        border: 1px solid #e0e0e0;
        border-radius: 16px;
        padding: 25px;
        margin-bottom: 25px;
        box-shadow: 0 3px 12px rgba(0,0,0,0.07);
        transition: transform 0.2s;
    }
    .award-card:hover {
        transform: translateY(-3px);
        box-shadow: 0 6px 20px rgba(0,0,0,0.1);
    }
    .award-card .category-header {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 15px;
    }
    .award-card .category-icon {
        font-size: 36px;
    }
    .award-card .category-name {
        font-size: 20px;
        font-weight: 700;
        color: #1a1a2e;
        margin: 0;
    }
    .award-card .category-desc {
        font-size: 13px;
        color: #888;
        margin: 0;
    }
    .winner-block {
        background: linear-gradient(135deg, #fef9e7 0%, #fdebd0 100%);
        border: 2px solid #f0c040;
        border-radius: 12px;
        padding: 20px;
        display: flex;
        align-items: center;
        gap: 20px;
        margin-bottom: 15px;
    }
    .winner-trophy {
        font-size: 48px;
    }
    .winner-info h3 {
        margin: 0 0 4px;
        font-size: 22px;
        color: #1a1a2e;
    }
    .winner-info .subtitle {
        color: #777;
        font-size: 14px;
        margin: 0;
    }
    .winner-stat {
        margin-left: auto;
        text-align: center;
        min-width: 100px;
    }
    .winner-stat .stat-value {
        font-size: 28px;
        font-weight: 700;
        color: #c0850a;
    }
    .winner-stat .stat-label {
        font-size: 12px;
        color: #999;
    }
    .nominees-list {
        padding: 0;
        list-style: none;
        margin: 0;
    }
    .nominees-list li {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 8px 12px;
        border-bottom: 1px solid #f0f0f0;
    }
    .nominees-list li:last-child {
        border-bottom: none;
    }
    .nominee-rank {
        background: #e8e8e8;
        color: #555;
        border-radius: 50%;
        width: 28px;
        height: 28px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 13px;
        font-weight: 600;
        flex-shrink: 0;
    }
    .nominee-rank.silver { background: #c0c0c0; color: #fff; }
    .nominee-rank.bronze { background: #cd7f32; color: #fff; }
    .nominee-name {
        font-weight: 500;
    }
    .nominee-stat {
        margin-left: auto;
        color: #888;
        font-size: 13px;
    }
    .no-awards {
        text-align: center;
        padding: 60px 20px;
        color: #999;
    }
    .no-awards .emoji { font-size: 48px; }
</style>

<div class="awards-header">
    <span class="trophy-icon">🏆</span>
    <h1>Vidly Awards @Model.Year</h1>
    <p class="tagline">Celebrating the best movies, customers, and moments of the year</p>
</div>

@if (Model.AvailableYears.Count > 1)
{
    <div class="year-selector">
        @foreach (var y in Model.AvailableYears)
        {
            <a href="@Url.Action("Index", "Awards", new { year = y })"
               class="btn btn-default @(y == Model.Year ? "active" : "")">@y</a>
        }
    </div>
}

<div class="summary-cards">
    <div class="summary-card">
        <div class="value">@Model.Summary.TotalRentals</div>
        <div class="label">Rentals</div>
    </div>
    <div class="summary-card">
        <div class="value">@Model.Summary.TotalMovies</div>
        <div class="label">Movies Rented</div>
    </div>
    <div class="summary-card">
        <div class="value">@Model.Summary.TotalCustomers</div>
        <div class="label">Active Customers</div>
    </div>
    <div class="summary-card">
        <div class="value">@Model.Summary.TotalReviews</div>
        <div class="label">Reviews</div>
    </div>
    <div class="summary-card">
        <div class="value">$@Model.Summary.TotalRevenue.ToString("N2")</div>
        <div class="label">Revenue</div>
    </div>
</div>

@if (Model.Categories.Count == 0)
{
    <div class="no-awards">
        <div class="emoji">🎬</div>
        <h2>No awards data for @Model.Year</h2>
        <p>Rent some movies and write reviews to see awards!</p>
    </div>
}
else
{
    <div class="row">
        @foreach (var cat in Model.Categories)
        {
            <div class="col-md-6">
                <div class="award-card">
                    <div class="category-header">
                        <span class="category-icon">@cat.Icon</span>
                        <div>
                            <h2 class="category-name">@cat.Name</h2>
                            <p class="category-desc">@cat.Description</p>
                        </div>
                    </div>

                    @if (cat.Winner != null)
                    {
                        <div class="winner-block">
                            <span class="winner-trophy">🏆</span>
                            <div class="winner-info">
                                <h3>@cat.Winner.Name</h3>
                                <p class="subtitle">@cat.Winner.Subtitle</p>
                            </div>
                            <div class="winner-stat">
                                <div class="stat-value">@cat.Winner.StatValue</div>
                                <div class="stat-label">@cat.Winner.StatLabel</div>
                            </div>
                        </div>

                        if (cat.Nominees.Count > 0)
                        {
                            <ul class="nominees-list">
                                @foreach (var nom in cat.Nominees)
                                {
                                    <li>
                                        <span class="nominee-rank @(nom.Rank == 2 ? "silver" : nom.Rank == 3 ? "bronze" : "")">@nom.Rank</span>
                                        <span class="nominee-name">@nom.Name</span>
                                        <span class="nominee-stat">@nom.StatValue</span>
                                    </li>
                                }
                            </ul>
                        }
                    }
                </div>
            </div>
        }
    </div>
}
