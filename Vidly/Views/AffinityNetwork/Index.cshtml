@model Vidly.Models.AffinityNetworkSummary
@{
    ViewBag.Title = "Movie Affinity Network";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width,initial-scale=1"/>
    <title>Movie Affinity Network — Vidly</title>
    <style>
        :root{--bg:#0f1117;--card:#1a1d27;--border:#2a2d3a;--text:#e4e6eb;--muted:#8b8fa3;
              --accent:#818cf8;--strong:#22c55e;--mod:#eab308;--weak:#6b7280}
        *{margin:0;padding:0;box-sizing:border-box}
        body{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif;
             background:var(--bg);color:var(--text);min-height:100vh;padding:24px}
        .header{display:flex;justify-content:space-between;align-items:center;margin-bottom:24px}
        .header h1{font-size:24px;font-weight:700}
        .header h1 span{color:var(--accent)}
        .badge{font-size:12px;padding:3px 10px;border-radius:12px;background:var(--accent);color:#fff;margin-left:8px}
        .cards{display:grid;grid-template-columns:repeat(auto-fit,minmax(150px,1fr));gap:14px;margin-bottom:24px}
        .card{background:var(--card);border:1px solid var(--border);border-radius:12px;padding:18px;text-align:center}
        .card .val{font-size:28px;font-weight:700;color:var(--accent)}
        .card .lbl{font-size:12px;color:var(--muted);margin-top:4px}
        .row{display:flex;gap:20px;margin-bottom:24px;flex-wrap:wrap}
        .box{background:var(--card);border:1px solid var(--border);border-radius:12px;padding:20px;flex:1;min-width:300px}
        .box h3{font-size:14px;color:var(--muted);margin-bottom:14px}
        canvas#graph{border-radius:8px;cursor:grab;display:block;width:100%;background:#12141c}
        .insight{display:flex;gap:10px;padding:10px 0;border-bottom:1px solid var(--border);font-size:14px}
        .insight .icon{font-size:20px;flex-shrink:0}
        .insight .title{font-weight:600}
        .insight .desc{color:var(--muted);font-size:13px;margin-top:2px}
        table{width:100%;border-collapse:collapse;background:var(--card);border-radius:12px;overflow:hidden;border:1px solid var(--border)}
        th{background:#14161e;font-size:12px;color:var(--muted);text-transform:uppercase;letter-spacing:.5px;padding:12px 14px;text-align:left;cursor:pointer}
        td{padding:10px 14px;border-top:1px solid var(--border);font-size:14px}
        tr:hover{background:#1f2231}
        .strength{display:inline-block;padding:2px 10px;border-radius:6px;font-size:12px;font-weight:600}
        .strength-Strong{background:rgba(34,197,94,.15);color:var(--strong)}
        .strength-Moderate{background:rgba(234,179,8,.15);color:var(--mod)}
        .strength-Weak{background:rgba(107,114,128,.15);color:var(--weak)}
        .cluster-card{background:var(--bg);border:1px solid var(--border);border-radius:10px;padding:14px;margin-bottom:12px}
        .cluster-card h4{font-size:14px;margin-bottom:8px;display:flex;justify-content:space-between}
        .cluster-card .members{display:flex;flex-wrap:wrap;gap:6px}
        .cluster-card .member{background:var(--card);border:1px solid var(--border);border-radius:6px;padding:4px 10px;font-size:12px}
        .tabs{display:flex;gap:8px;margin-bottom:16px}
        .tab{padding:7px 16px;border-radius:8px;border:1px solid var(--border);background:var(--card);color:var(--text);cursor:pointer;font-size:13px}
        .tab.active{background:var(--accent);color:#fff;border-color:var(--accent)}
        .panel{display:none} .panel.active{display:block}
    </style>
</head>
<body>
<div class="header">
    <h1>🧬 <span>Movie Affinity Network</span> <span class="badge">Autonomous</span></h1>
</div>

<div class="cards">
    <div class="card"><div class="val">@Model.TotalMovies</div><div class="lbl">Movies Analyzed</div></div>
    <div class="card"><div class="val">@Model.TotalLinks</div><div class="lbl">Co-Rental Links</div></div>
    <div class="card"><div class="val">@Model.TotalClusters</div><div class="lbl">Clusters Found</div></div>
    <div class="card"><div class="val">@Model.AverageAffinity</div><div class="lbl">Avg Affinity</div></div>
</div>

<!-- Insights -->
<div class="box" style="margin-bottom:24px">
    <h3>🤖 Autonomous Insights</h3>
    @foreach (var ins in Model.Insights)
    {
        <div class="insight">
            <div class="icon">@ins.Icon</div>
            <div><div class="title">@ins.Title</div><div class="desc">@ins.Description</div></div>
        </div>
    }
    @if (!Model.Insights.Any())
    {
        <p style="color:var(--muted);font-size:14px">Not enough rental data to generate insights yet.</p>
    }
</div>

<div class="row">
    <!-- Force-directed graph -->
    <div class="box" style="min-width:400px">
        <h3>Affinity Graph</h3>
        <canvas id="graph" width="600" height="500"></canvas>
    </div>

    <!-- Clusters -->
    <div class="box" style="max-width:400px">
        <h3>Clusters</h3>
        @foreach (var cl in Model.Clusters)
        {
            <div class="cluster-card">
                <h4><span>@cl.Label</span><span style="color:var(--muted);font-size:12px">Cohesion: @cl.Cohesion</span></h4>
                <div class="members">
                    @foreach (var m in cl.Members)
                    {
                        <span class="member" title="@m.Genre — @m.TotalRentals rentals, @m.Connections links">@m.MovieName</span>
                    }
                </div>
            </div>
        }
        @if (!Model.Clusters.Any())
        {
            <p style="color:var(--muted);font-size:14px">No clusters detected at current threshold.</p>
        }
    </div>
</div>

<!-- Affinities table -->
<h3 style="font-size:14px;color:var(--muted);margin-bottom:12px">Top Co-Rental Affinities</h3>
<table>
    <thead>
        <tr>
            <th>Movie A</th><th>Movie B</th><th>Shared Customers</th><th>Jaccard Score</th><th>Strength</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var a in Model.TopAffinities)
        {
            <tr>
                <td>@a.MovieNameA</td>
                <td>@a.MovieNameB</td>
                <td>@a.SharedCustomers</td>
                <td><strong>@a.AffinityScore</strong></td>
                <td><span class="strength strength-@a.Strength">@a.Strength</span></td>
            </tr>
        }
    </tbody>
</table>

<script>
// ── Force-directed graph visualization ──────────────────────
(function(){
    var canvas=document.getElementById('graph');
    var ctx=canvas.getContext('2d');
    var W=canvas.width,H=canvas.height;

    // Build nodes & edges from model data
    var nodeMap={};
    var nodes=[];
    var edges=[];

    @foreach (var a in Model.TopAffinities.Take(40))
    {
        <text>
        if(!nodeMap[@a.MovieIdA]){nodeMap[@a.MovieIdA]={id:@a.MovieIdA,label:"@Html.Raw(a.MovieNameA.Replace("\"","\\\""))",x:Math.random()*W,y:Math.random()*H,vx:0,vy:0};nodes.push(nodeMap[@a.MovieIdA]);}
        if(!nodeMap[@a.MovieIdB]){nodeMap[@a.MovieIdB]={id:@a.MovieIdB,label:"@Html.Raw(a.MovieNameB.Replace("\"","\\\""))",x:Math.random()*W,y:Math.random()*H,vx:0,vy:0};nodes.push(nodeMap[@a.MovieIdB]);}
        edges.push({a:nodeMap[@a.MovieIdA],b:nodeMap[@a.MovieIdB],w:@a.AffinityScore,str:"@a.Strength"});
        </text>
    }

    var colors={Strong:'#22c55e',Moderate:'#eab308',Weak:'#4b5563'};
    var clusterColors=['#818cf8','#f472b6','#34d399','#fbbf24','#f87171','#a78bfa','#22d3ee','#fb923c'];

    // Assign cluster colors
    @for (int ci = 0; ci < Model.Clusters.Count && ci < 8; ci++)
    {
        var cl = Model.Clusters[ci];
        foreach (var m in cl.Members)
        {
            <text>if(nodeMap[@m.MovieId])nodeMap[@m.MovieId].color=clusterColors[@ci];</text>
        }
    }

    function simulate(){
        // Repulsion
        for(var i=0;i<nodes.length;i++){
            for(var j=i+1;j<nodes.length;j++){
                var dx=nodes[j].x-nodes[i].x,dy=nodes[j].y-nodes[i].y;
                var dist=Math.sqrt(dx*dx+dy*dy)||1;
                var force=800/(dist*dist);
                nodes[i].vx-=dx/dist*force;nodes[i].vy-=dy/dist*force;
                nodes[j].vx+=dx/dist*force;nodes[j].vy+=dy/dist*force;
            }
        }
        // Attraction
        edges.forEach(function(e){
            var dx=e.b.x-e.a.x,dy=e.b.y-e.a.y;
            var dist=Math.sqrt(dx*dx+dy*dy)||1;
            var force=(dist-120)*0.005*e.w;
            e.a.vx+=dx/dist*force;e.a.vy+=dy/dist*force;
            e.b.vx-=dx/dist*force;e.b.vy-=dy/dist*force;
        });
        // Center gravity
        nodes.forEach(function(n){
            n.vx+=(W/2-n.x)*0.001;n.vy+=(H/2-n.y)*0.001;
            n.vx*=0.9;n.vy*=0.9;
            n.x+=n.vx;n.y+=n.vy;
            n.x=Math.max(30,Math.min(W-30,n.x));
            n.y=Math.max(30,Math.min(H-30,n.y));
        });
    }

    function draw(){
        ctx.clearRect(0,0,W,H);
        // Edges
        edges.forEach(function(e){
            ctx.beginPath();ctx.moveTo(e.a.x,e.a.y);ctx.lineTo(e.b.x,e.b.y);
            ctx.strokeStyle=colors[e.str]||'#333';ctx.lineWidth=Math.max(1,e.w*4);
            ctx.globalAlpha=0.4+e.w*0.6;ctx.stroke();ctx.globalAlpha=1;
        });
        // Nodes
        nodes.forEach(function(n){
            ctx.beginPath();ctx.arc(n.x,n.y,8,0,Math.PI*2);
            ctx.fillStyle=n.color||'#818cf8';ctx.fill();
            ctx.strokeStyle='#0f1117';ctx.lineWidth=2;ctx.stroke();
            ctx.fillStyle='#e4e6eb';ctx.font='11px sans-serif';ctx.textAlign='center';
            ctx.fillText(n.label,n.x,n.y-14);
        });
    }

    var frame=0;
    function tick(){
        simulate();draw();frame++;
        if(frame<200)requestAnimationFrame(tick);
    }
    if(nodes.length>0)tick();
    else{ctx.fillStyle='#8b8fa3';ctx.font='14px sans-serif';ctx.textAlign='center';
         ctx.fillText('Not enough data to visualize',W/2,H/2);}
})();
</script>
</body>
</html>
