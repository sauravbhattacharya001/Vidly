@model Vidly.Models.ShowdownViewModel
@{
    ViewBag.Title = "Showdown Leaderboard";
}

<div class="container">
    <div class="page-header">
        <h1><span class="glyphicon glyphicon-trophy"></span> Showdown Leaderboard</h1>
        <p class="lead">@Model.TotalRounds total rounds played</p>
    </div>

    <p><a href="@Url.Action("Index")" class="btn btn-primary"><span class="glyphicon glyphicon-fire"></span> Back to Showdown</a></p>

    @if (Model.Leaderboard.Count == 0)
    {
        <div class="alert alert-info">No votes yet! Start a showdown to build the leaderboard.</div>
    }
    else
    {
        <table class="table table-striped table-hover">
            <thead>
                <tr>
                    <th>Rank</th>
                    <th>Movie</th>
                    <th>Wins</th>
                    <th>Losses</th>
                    <th>Win Rate</th>
                </tr>
            </thead>
            <tbody>
                @{ int rank = 1; }
                @foreach (var score in Model.Leaderboard)
                {
                    <tr class="@(rank == 1 ? "success" : rank == 2 ? "info" : rank == 3 ? "warning" : "")">
                        <td>
                            @if (rank == 1) { <span class="glyphicon glyphicon-king text-warning"></span> }
                            @rank
                        </td>
                        <td><strong>@score.MovieName</strong></td>
                        <td><span class="text-success">@score.Wins</span></td>
                        <td><span class="text-danger">@score.Losses</span></td>
                        <td>@score.WinRate.ToString("F1")%</td>
                    </tr>
                    rank++;
                }
            </tbody>
        </table>
    }
</div>
