@model Vidly.ViewModels.AnnouncementBoardViewModel
@{
    ViewBag.Title = "Announcements";
}

<div class="container" style="margin-top: 20px;">
    <div class="page-header">
        <h1><span class="glyphicon glyphicon-bullhorn"></span> Announcements</h1>
        <p class="lead text-muted">Stay up to date with the latest news from Vidly</p>
    </div>

    @if (TempData["Message"] != null)
    {
        <div class="alert alert-success alert-dismissible">
            <button type="button" class="close" data-dismiss="alert">&times;</button>
            @TempData["Message"]
        </div>
    }

    <div class="row" style="margin-bottom: 20px;">
        <div class="col-md-8">
            <form method="get" class="form-inline">
                <div class="form-group" style="margin-right: 10px;">
                    <input type="text" name="q" class="form-control" placeholder="Search announcements..."
                           value="@Model.SearchQuery" />
                </div>
                <div class="form-group" style="margin-right: 10px;">
                    <select name="category" class="form-control" onchange="this.form.submit()">
                        <option value="">All Categories</option>
                        <option value="General" @(Model.CategoryFilter == AnnouncementCategory.General ? "selected" : "")>General</option>
                        <option value="NewArrival" @(Model.CategoryFilter == AnnouncementCategory.NewArrival ? "selected" : "")>New Arrivals</option>
                        <option value="Promotion" @(Model.CategoryFilter == AnnouncementCategory.Promotion ? "selected" : "")>Promotions</option>
                        <option value="PolicyChange" @(Model.CategoryFilter == AnnouncementCategory.PolicyChange ? "selected" : "")>Policy Changes</option>
                        <option value="Event" @(Model.CategoryFilter == AnnouncementCategory.Event ? "selected" : "")>Events</option>
                        <option value="StoreClosure" @(Model.CategoryFilter == AnnouncementCategory.StoreClosure ? "selected" : "")>Store Closures</option>
                    </select>
                </div>
                <button type="submit" class="btn btn-default">
                    <span class="glyphicon glyphicon-search"></span> Search
                </button>
            </form>
        </div>
        <div class="col-md-4 text-right">
            <a href="@Url.Action("Manage")" class="btn btn-info">
                <span class="glyphicon glyphicon-cog"></span> Staff Management
            </a>
        </div>
    </div>

    @* Pinned Announcements *@
    @if (Model.PinnedAnnouncements != null && Model.PinnedAnnouncements.Any())
    {
        foreach (var pinned in Model.PinnedAnnouncements)
        {
            <div class="panel panel-danger">
                <div class="panel-heading">
                    <span class="glyphicon glyphicon-pushpin"></span>
                    <strong>PINNED</strong> &mdash; @pinned.Title
                    <span class="badge pull-right">@pinned.Priority Priority</span>
                </div>
                <div class="panel-body">
                    <p>@pinned.Body</p>
                    <small class="text-muted">
                        Posted @(pinned.PublishedAt.HasValue ? pinned.PublishedAt.Value.ToString("MMM dd, yyyy") : "N/A")
                        &middot; @pinned.ViewCount views
                        @if (pinned.RequiresAcknowledgment)
                        {
                            <span class="label label-warning" style="margin-left: 5px;">Requires Acknowledgment</span>
                        }
                    </small>
                    <a href="@Url.Action("Details", new { id = pinned.Id })" class="btn btn-xs btn-default pull-right">
                        View Details
                    </a>
                </div>
            </div>
        }
    }

    @* Quick Stats *@
    @if (Model.Analytics != null)
    {
        <div class="row" style="margin-bottom: 20px;">
            <div class="col-md-3">
                <div class="panel panel-success">
                    <div class="panel-body text-center">
                        <h3 style="margin: 0;">@Model.Analytics.ActiveCount</h3>
                        <small class="text-muted">Active</small>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="panel panel-warning">
                    <div class="panel-body text-center">
                        <h3 style="margin: 0;">@Model.Analytics.DraftCount</h3>
                        <small class="text-muted">Drafts</small>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="panel panel-default">
                    <div class="panel-body text-center">
                        <h3 style="margin: 0;">@Model.Analytics.PinnedCount</h3>
                        <small class="text-muted">Pinned</small>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="panel panel-info">
                    <div class="panel-body text-center">
                        <h3 style="margin: 0;">@Model.Analytics.TotalAnnouncements</h3>
                        <small class="text-muted">Total</small>
                    </div>
                </div>
            </div>
        </div>
    }

    @* Announcements List *@
    @if (!Model.Announcements.Any())
    {
        <div class="alert alert-info">
            <span class="glyphicon glyphicon-info-sign"></span>
            No announcements found. Check back later!
        </div>
    }
    else
    {
        foreach (var announcement in Model.Announcements)
        {
            var panelClass = "panel-default";
            if (announcement.Priority == AnnouncementPriority.Urgent) panelClass = "panel-danger";
            else if (announcement.Priority == AnnouncementPriority.High) panelClass = "panel-warning";
            else if (announcement.Category == AnnouncementCategory.Promotion) panelClass = "panel-success";
            else if (announcement.Category == AnnouncementCategory.NewArrival) panelClass = "panel-info";

            <div class="panel @panelClass">
                <div class="panel-heading">
                    @{
                        var icon = "glyphicon-info-sign";
                        switch (announcement.Category)
                        {
                            case AnnouncementCategory.NewArrival: icon = "glyphicon-film"; break;
                            case AnnouncementCategory.Promotion: icon = "glyphicon-gift"; break;
                            case AnnouncementCategory.PolicyChange: icon = "glyphicon-list-alt"; break;
                            case AnnouncementCategory.StoreClosure: icon = "glyphicon-lock"; break;
                            case AnnouncementCategory.Event: icon = "glyphicon-calendar"; break;
                            case AnnouncementCategory.Maintenance: icon = "glyphicon-wrench"; break;
                            case AnnouncementCategory.MemberExclusive: icon = "glyphicon-star"; break;
                        }
                    }
                    <span class="glyphicon @icon"></span>
                    <strong>@announcement.Title</strong>
                    <span class="label label-default" style="margin-left: 8px;">@announcement.Category</span>
                    @if (announcement.Priority >= AnnouncementPriority.High)
                    {
                        <span class="label label-danger" style="margin-left: 4px;">@announcement.Priority</span>
                    }
                </div>
                <div class="panel-body">
                    <p>@announcement.Body</p>
                    @if (announcement.Tags.Any())
                    {
                        <p>
                            @foreach (var tag in announcement.Tags)
                            {
                                <span class="label label-info" style="margin-right: 4px;">@tag</span>
                            }
                        </p>
                    }
                    <div class="row">
                        <div class="col-md-8">
                            <small class="text-muted">
                                Posted @(announcement.PublishedAt.HasValue ? announcement.PublishedAt.Value.ToString("MMM dd, yyyy h:mm tt") : "Not published")
                                &middot; @announcement.ViewCount views
                                @if (announcement.ExpiresAt.HasValue)
                                {
                                    <text>&middot; Expires @announcement.ExpiresAt.Value.ToString("MMM dd, yyyy")</text>
                                }
                            </small>
                        </div>
                        <div class="col-md-4 text-right">
                            @if (announcement.RequiresAcknowledgment)
                            {
                                <span class="label label-warning">
                                    <span class="glyphicon glyphicon-exclamation-sign"></span> Action Required
                                </span>
                            }
                            <a href="@Url.Action("Details", new { id = announcement.Id })" class="btn btn-xs btn-default">
                                Read More
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        }
    }
</div>
