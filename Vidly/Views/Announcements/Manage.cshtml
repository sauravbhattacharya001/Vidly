@model Vidly.ViewModels.AnnouncementBoardViewModel
@{
    ViewBag.Title = "Manage Announcements";
}

<div class="container" style="margin-top: 20px;">
    <div class="page-header">
        <h1><span class="glyphicon glyphicon-cog"></span> Manage Announcements</h1>
        <p class="lead text-muted">Create, publish, pin, and archive store announcements</p>
    </div>

    @if (TempData["Message"] != null)
    {
        <div class="alert alert-success alert-dismissible">
            <button type="button" class="close" data-dismiss="alert">&times;</button>
            @TempData["Message"]
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible">
            <button type="button" class="close" data-dismiss="alert">&times;</button>
            @TempData["Error"]
        </div>
    }

    <div class="row" style="margin-bottom: 20px;">
        <div class="col-md-6">
            <div class="btn-group">
                <a href="@Url.Action("Manage")" class="btn btn-default @(Model.StatusFilter == null ? "active" : "")">All</a>
                <a href="@Url.Action("Manage", new { status = "Draft" })" class="btn btn-default @(Model.StatusFilter == AnnouncementStatus.Draft ? "active" : "")">
                    Drafts <span class="badge">@Model.Analytics.DraftCount</span>
                </a>
                <a href="@Url.Action("Manage", new { status = "Active" })" class="btn btn-default @(Model.StatusFilter == AnnouncementStatus.Active ? "active" : "")">
                    Active <span class="badge">@Model.Analytics.ActiveCount</span>
                </a>
                <a href="@Url.Action("Manage", new { status = "Expired" })" class="btn btn-default @(Model.StatusFilter == AnnouncementStatus.Expired ? "active" : "")">
                    Expired <span class="badge">@Model.Analytics.ExpiredCount</span>
                </a>
                <a href="@Url.Action("Manage", new { status = "Archived" })" class="btn btn-default @(Model.StatusFilter == AnnouncementStatus.Archived ? "active" : "")">
                    Archived <span class="badge">@Model.Analytics.ArchivedCount</span>
                </a>
            </div>
        </div>
        <div class="col-md-6 text-right">
            <a href="@Url.Action("Create")" class="btn btn-primary">
                <span class="glyphicon glyphicon-plus"></span> New Announcement
            </a>
            <a href="@Url.Action("Index")" class="btn btn-default">
                <span class="glyphicon glyphicon-eye-open"></span> Public Board
            </a>
            <a href="@Url.Action("Analytics")" class="btn btn-info">
                <span class="glyphicon glyphicon-stats"></span> Analytics
            </a>
        </div>
    </div>

    @if (!Model.Announcements.Any())
    {
        <div class="alert alert-info">No announcements match this filter.</div>
    }
    else
    {
        <table class="table table-striped table-hover">
            <thead>
                <tr>
                    <th>Title</th>
                    <th>Category</th>
                    <th>Priority</th>
                    <th>Status</th>
                    <th>Views</th>
                    <th>Created</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var a in Model.Announcements)
                {
                    var statusLabel = "label-default";
                    switch (a.Status)
                    {
                        case AnnouncementStatus.Active: statusLabel = "label-success"; break;
                        case AnnouncementStatus.Draft: statusLabel = "label-warning"; break;
                        case AnnouncementStatus.Expired: statusLabel = "label-danger"; break;
                        case AnnouncementStatus.Archived: statusLabel = "label-default"; break;
                        case AnnouncementStatus.Scheduled: statusLabel = "label-info"; break;
                    }
                    <tr>
                        <td>
                            <a href="@Url.Action("Details", new { id = a.Id })">@a.Title</a>
                            @if (a.RequiresAcknowledgment)
                            {
                                <span class="glyphicon glyphicon-exclamation-sign text-warning" title="Requires acknowledgment"></span>
                            }
                        </td>
                        <td><span class="label label-info">@a.Category</span></td>
                        <td>
                            @{
                                var priLabel = "label-default";
                                if (a.Priority == AnnouncementPriority.High) priLabel = "label-warning";
                                else if (a.Priority == AnnouncementPriority.Urgent) priLabel = "label-danger";
                            }
                            <span class="label @priLabel">@a.Priority</span>
                        </td>
                        <td><span class="label @statusLabel">@a.Status</span></td>
                        <td>@a.ViewCount</td>
                        <td>@a.CreatedAt.ToString("MMM dd, yyyy")</td>
                        <td>
                            @if (a.Status == AnnouncementStatus.Draft)
                            {
                                using (Html.BeginForm("Publish", "Announcements", new { id = a.Id }, FormMethod.Post, new { style = "display:inline" }))
                                {
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-xs btn-success" title="Publish">
                                        <span class="glyphicon glyphicon-ok"></span>
                                    </button>
                                }
                            }
                            @if (a.Status == AnnouncementStatus.Active)
                            {
                                using (Html.BeginForm("TogglePin", "Announcements", new { id = a.Id }, FormMethod.Post, new { style = "display:inline" }))
                                {
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-xs btn-warning" title="Toggle Pin">
                                        <span class="glyphicon glyphicon-pushpin"></span>
                                    </button>
                                }
                                using (Html.BeginForm("Archive", "Announcements", new { id = a.Id }, FormMethod.Post, new { style = "display:inline" }))
                                {
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-xs btn-default" title="Archive">
                                        <span class="glyphicon glyphicon-folder-close"></span>
                                    </button>
                                }
                            }
                            using (Html.BeginForm("Delete", "Announcements", new { id = a.Id }, FormMethod.Post, new { style = "display:inline" }))
                            {
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-xs btn-danger" title="Delete"
                                        onclick="return confirm('Delete this announcement?');">
                                    <span class="glyphicon glyphicon-trash"></span>
                                </button>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>
