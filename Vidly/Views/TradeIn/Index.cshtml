@model System.Collections.Generic.List<Vidly.Models.TradeIn>
@{
    ViewBag.Title = "Movie Trade-Ins";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var stats = ViewBag.Stats as Vidly.Repositories.TradeInStats;
}

<h2>
    <span class="glyphicon glyphicon-transfer"></span> Movie Trade-Ins
</h2>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible" role="alert">
        <button type="button" class="close" data-dismiss="alert" aria-label="Close">
            <span aria-hidden="true">&times;</span>
        </button>
        @TempData["Success"]
    </div>
}

@if (stats != null)
{
    <div class="row" style="margin-bottom: 20px;">
        <div class="col-md-2 col-sm-4 col-xs-6">
            <div class="panel panel-info">
                <div class="panel-heading"><strong>Total</strong></div>
                <div class="panel-body text-center"><h3>@stats.TotalTradeIns</h3></div>
            </div>
        </div>
        <div class="col-md-2 col-sm-4 col-xs-6">
            <div class="panel panel-warning">
                <div class="panel-heading"><strong>Pending</strong></div>
                <div class="panel-body text-center"><h3>@stats.PendingCount</h3></div>
            </div>
        </div>
        <div class="col-md-2 col-sm-4 col-xs-6">
            <div class="panel panel-success">
                <div class="panel-heading"><strong>Accepted</strong></div>
                <div class="panel-body text-center"><h3>@stats.AcceptedCount</h3></div>
            </div>
        </div>
        <div class="col-md-2 col-sm-4 col-xs-6">
            <div class="panel panel-danger">
                <div class="panel-heading"><strong>Rejected</strong></div>
                <div class="panel-body text-center"><h3>@stats.RejectedCount</h3></div>
            </div>
        </div>
        <div class="col-md-2 col-sm-4 col-xs-6">
            <div class="panel panel-default">
                <div class="panel-heading"><strong>Credits Paid</strong></div>
                <div class="panel-body text-center"><h3>@stats.TotalCreditsAwarded.ToString("C")</h3></div>
            </div>
        </div>
    </div>
}

<div style="margin-bottom: 15px;">
    <a href="@Url.Action("Submit")" class="btn btn-primary">
        <span class="glyphicon glyphicon-plus"></span> Submit Trade-In
    </a>
    <a href="@Url.Action("Pending")" class="btn btn-warning">
        <span class="glyphicon glyphicon-eye-open"></span> Review Pending (@(stats?.PendingCount ?? 0))
    </a>
</div>

@if (Model.Any())
{
    <table class="table table-striped table-hover">
        <thead>
            <tr>
                <th>#</th>
                <th>Movie</th>
                <th>Format</th>
                <th>Condition</th>
                <th>Credits</th>
                <th>Date</th>
                <th>Status</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                var statusClass = item.Status == Vidly.Models.TradeInStatus.Accepted ? "success"
                    : item.Status == Vidly.Models.TradeInStatus.Rejected ? "danger" : "warning";
                <tr class="@statusClass">
                    <td>@item.Id</td>
                    <td>@item.MovieTitle</td>
                    <td>@item.Format</td>
                    <td>@item.Condition</td>
                    <td>@item.CreditsAwarded.ToString("C")</td>
                    <td>@item.TradeInDate.ToString("MMM dd, yyyy")</td>
                    <td><span class="label label-@statusClass">@item.Status</span></td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <div class="alert alert-info">No trade-ins yet. Be the first to trade in a movie!</div>
}
