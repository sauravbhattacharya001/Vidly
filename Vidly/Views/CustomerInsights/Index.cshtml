@model Vidly.ViewModels.CustomerInsightsViewModel
@{ ViewBag.Title = Model.Customer != null ? Model.Customer.Name + " - Insights" : "Customer Insights"; Layout = "~/Views/Shared/_Layout.cshtml"; }
<h2><span class="glyphicon glyphicon-stats"></span> Customer Insights</h2>
<div class="row" style="margin-bottom:20px"><div class="col-md-6">
@using (Html.BeginForm("Index", "CustomerInsights", FormMethod.Get, new { @class = "form-inline" })) {
<div class="form-group"><label for="customerId">Select Customer:</label>
<select name="customerId" id="customerId" class="form-control" style="margin-left:10px;width:250px">
<option value="">-- Choose --</option>
@if (Model.AllCustomers != null) { foreach (var c in Model.AllCustomers) {
<option value="@c.Id" @(Model.Customer != null && Model.Customer.Id == c.Id ? "selected" : "")>@c.Name</option> } }
</select></div>
<button type="submit" class="btn btn-primary" style="margin-left:10px"><span class="glyphicon glyphicon-search"></span> View Insights</button>
}</div></div>
@if (!string.IsNullOrEmpty(Model.StatusMessage) && Model.Customer == null) { <div class="alert alert-info">@Model.StatusMessage</div> }
@if (Model.Customer != null) {
<div class="row">
<div class="col-md-3"><div class="panel panel-primary"><div class="panel-heading"><h3 class="panel-title"><span class="glyphicon glyphicon-star"></span> Loyalty</h3></div>
<div class="panel-body text-center">@if (Model.Loyalty != null) { <h1 style="font-size:48px;margin:10px 0">@Model.Loyalty.Score</h1>
<span class="label label-primary" style="font-size:14px">@Model.Loyalty.Tier</span>
@if (Model.Loyalty.Breakdown != null) { <hr/><div style="text-align:left;font-size:12px">
<div>Frequency: <strong>@Model.Loyalty.Breakdown.FrequencyPoints</strong></div>
<div>Recency: <strong>@Model.Loyalty.Breakdown.RecencyPoints</strong></div>
<div>On-Time: <strong>@Model.Loyalty.Breakdown.OnTimePoints</strong></div>
<div>Spending: <strong>@Model.Loyalty.Breakdown.SpendPoints</strong></div></div> }
} else { <p class="text-muted">No data</p> }</div></div></div>
<div class="col-md-3"><div class="panel panel-success"><div class="panel-heading"><h3 class="panel-title"><span class="glyphicon glyphicon-usd"></span> Spending</h3></div>
<div class="panel-body">@if (Model.Spending != null) { <dl><dt>Total</dt><dd><strong style="font-size:24px">$@Model.Spending.TotalSpent.ToString("F2")</strong></dd>
<dt>Avg/Rental</dt><dd>$@Model.Spending.AveragePerRental.ToString("F2")</dd>
<dt>Late Fees</dt><dd>$@Model.Spending.TotalLateFees.ToString("F2") (@Model.Spending.LateFeePct%)</dd>
<dt>Rentals</dt><dd>@Model.Spending.TotalRentals</dd></dl> }</div></div></div>
<div class="col-md-3"><div class="panel panel-info"><div class="panel-heading"><h3 class="panel-title"><span class="glyphicon glyphicon-time"></span> Patterns</h3></div>
<div class="panel-body">@if (Model.Patterns != null) { <dl><dt>Avg Duration</dt><dd>@Model.Patterns.AverageDurationDays days</dd>
<dt>Longest</dt><dd>@Model.Patterns.LongestRentalDays days</dd>
<dt>On-Time</dt><dd><span class="@(Model.Patterns.OnTimeReturnRate >= 80 ? "text-success" : "text-danger")">@Model.Patterns.OnTimeReturnRate%</span></dd>
<dt>Active Day</dt><dd>@Model.Patterns.MostActiveDay</dd>
<dt>Streak</dt><dd>@Model.Patterns.CurrentStreak <span class="glyphicon glyphicon-fire" style="color:@(Model.Patterns.CurrentStreak >= 3 ? "#e67e22" : "#ccc")"></span></dd></dl> }</div></div></div>
<div class="col-md-3"><div class="panel panel-warning"><div class="panel-heading"><h3 class="panel-title"><span class="glyphicon glyphicon-film"></span> Genres</h3></div>
<div class="panel-body">@if (Model.GenreStats != null && Model.GenreStats.GenreCounts.Count > 0) {
<p>Fav: <strong>@Model.GenreStats.FavoriteGenre</strong> (@Model.GenreStats.UniqueGenres genres)</p>
@foreach (var g in Model.GenreStats.GenreCounts.OrderByDescending(x => x.Value)) {
var pct = Model.GenreStats.TotalRentals > 0 ? (int)Math.Round((double)g.Value/Model.GenreStats.TotalRentals*100) : 0;
<div style="margin-bottom:4px"><span style="display:inline-block;width:80px;font-size:12px">@g.Key</span>
<div class="progress" style="display:inline-block;width:55%;margin-bottom:0;vertical-align:middle">
<div class="progress-bar progress-bar-info" style="width:@(pct)%" title="@g.Value">@g.Value</div></div></div> }
} else { <p class="text-muted">No rentals</p> }</div></div></div>
</div>
@if (Model.Timeline != null && Model.Timeline.Count > 0) {
<div class="panel panel-default"><div class="panel-heading"><h3 class="panel-title"><span class="glyphicon glyphicon-list"></span> Timeline <span class="badge">@Model.Timeline.Count</span></h3></div>
<div class="panel-body" style="max-height:400px;overflow-y:auto"><table class="table table-condensed table-hover">
<thead><tr><th>Date</th><th>Event</th><th>Description</th><th>Movie</th><th>Amount</th></tr></thead>
<tbody>@foreach (var e in Model.Timeline.OrderByDescending(x => x.Date)) {
<tr><td>@e.Date.ToString("MMM dd, yyyy")</td><td><span class="label label-info">@e.EventType</span></td><td>@e.Description</td><td>@(e.MovieName ?? "-")</td><td>@(e.Amount.HasValue ? "$"+e.Amount.Value.ToString("F2") : "-")</td></tr>}</tbody></table></div></div> }
@if (Model.RentalHistory != null && Model.RentalHistory.Count > 0) {
<div class="panel panel-default"><div class="panel-heading"><h3 class="panel-title"><span class="glyphicon glyphicon-list-alt"></span> History <span class="badge">@Model.RentalHistory.Count</span></h3></div>
<table class="table table-striped table-hover"><thead><tr><th>Movie</th><th>Genre</th><th>Rented</th><th>Returned</th><th>Days</th><th>Cost</th><th>Status</th></tr></thead>
<tbody>@foreach (var r in Model.RentalHistory.OrderByDescending(x => x.RentalDate)) {
<tr class="@(r.WasLate?"danger":"")"><td>@r.MovieName</td><td>@(r.MovieGenre?.ToString() ?? "-")</td>
<td>@r.RentalDate.ToString("MMM dd")</td><td>@(r.ReturnDate.HasValue ? r.ReturnDate.Value.ToString("MMM dd") : "-")</td>
<td>@r.RentalDurationDays</td><td>$@r.TotalCost.ToString("F2")</td>
<td><span class="label @(r.Status==Vidly.Models.RentalStatus.Overdue?"label-danger":r.Status==Vidly.Models.RentalStatus.Active?"label-primary":"label-success")">@r.Status</span></td></tr>}</tbody></table></div> }
}
