@model Vidly.ViewModels.EmojiStoryViewModel
@{
    ViewBag.Title = "Movie Emoji Story - Round " + Model.Session.Round;
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container" style="max-width: 700px; margin: 2rem auto; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;">

    <!-- Round feedback from previous answer -->
    @if (Model.LastResult != null)
    {
        var feedbackBg = Model.LastResult.Correct ? "#f0fdf4" : "#fef2f2";
        var feedbackBorder = Model.LastResult.Correct ? "#86efac" : "#fca5a5";
        var feedbackColor = Model.LastResult.Correct ? "#166534" : "#991b1b";
        <div style="background: @feedbackBg; border: 1px solid @feedbackBorder; color: @feedbackColor; padding: 1rem; border-radius: 12px; margin-bottom: 1.5rem; text-align: center;">
            @if (Model.LastResult.Correct)
            {
                <strong>✅ Correct! +@Model.LastResult.PointsEarned pts</strong>
                <span style="margin-left: 0.5rem;">@Model.LastResult.Emojis = @Model.LastResult.MovieName</span>
            }
            else
            {
                <strong>❌ Not quite!</strong>
                <span style="margin-left: 0.5rem;">@Model.LastResult.Emojis = <strong>@Model.LastResult.MovieName</strong></span>
            }
        </div>
    }

    <!-- Progress bar -->
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem;">
        <span style="font-weight: 600;">Round @Model.Session.Round / @Model.Session.TotalRounds</span>
        <span style="font-weight: 600;">⭐ @Model.Session.Score pts</span>
        @if (Model.Session.Streak > 1)
        {
            <span style="color: #f59e0b; font-weight: 600;">🔥 @Model.Session.Streak streak!</span>
        }
    </div>
    <div style="background: #e2e8f0; border-radius: 10px; height: 8px; margin-bottom: 2rem;">
        <div style="background: linear-gradient(90deg, #6366f1, #8b5cf6); height: 100%; border-radius: 10px; width: @(Math.Round((double)(Model.Session.Round - 1) / Model.Session.TotalRounds * 100))%; transition: width 0.5s;"></div>
    </div>

    <!-- Puzzle card -->
    <div style="background: linear-gradient(135deg, #1e293b, #334155); border-radius: 20px; padding: 2.5rem; text-align: center; margin-bottom: 2rem; color: white;">
        <div style="font-size: 0.85rem; text-transform: uppercase; letter-spacing: 2px; opacity: 0.6; margin-bottom: 1rem;">Which movie is this?</div>
        <div style="font-size: 4rem; letter-spacing: 8px; margin-bottom: 1.5rem; line-height: 1.3;" id="emoji-display">
            @Model.CurrentPuzzle.Emojis
        </div>
        <span style="background: @(Model.CurrentPuzzle.Difficulty == "Easy" ? "#10b981" : Model.CurrentPuzzle.Difficulty == "Medium" ? "#f59e0b" : "#ef4444"); padding: 4px 12px; border-radius: 10px; font-size: 0.8rem;">
            @Model.CurrentPuzzle.Difficulty
        </span>
    </div>

    <!-- Hint toggle -->
    <div style="text-align: center; margin-bottom: 1.5rem;">
        <button type="button" onclick="document.getElementById('hint').style.display='block'; document.getElementById('hintUsed').value='true'; this.style.display='none';"
                style="background: none; border: 1px dashed #94a3b8; color: #64748b; padding: 0.5rem 1rem; border-radius: 8px; cursor: pointer; font-size: 0.9rem;">
            💡 Show Hint (−50% points)
        </button>
        <div id="hint" style="display: none; color: #64748b; font-style: italic; margin-top: 0.5rem;">
            💡 @Model.CurrentPuzzle.Hint
        </div>
    </div>

    <!-- Answer choices -->
    @using (Html.BeginForm("Answer", "EmojiStory", FormMethod.Post))
    {
        @Html.AntiForgeryToken()
        <input type="hidden" name="puzzleId" value="@Model.CurrentPuzzle.Id" />
        <input type="hidden" name="gameQueue" value="@Model.GameQueue" />
        <input type="hidden" name="sessionJson" value="@Html.Raw(Html.Encode(Model.SessionJson))" />
        <input type="hidden" name="hintUsed" id="hintUsed" value="false" />

        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 0.8rem;">
            @foreach (var choice in Model.Choices)
            {
                <button type="submit" name="guess" value="@choice"
                        style="background: #f8fafc; border: 2px solid #e2e8f0; padding: 1rem; border-radius: 12px; font-size: 1.05rem; cursor: pointer; transition: all 0.2s; font-weight: 500;"
                        onmouseover="this.style.borderColor='#6366f1'; this.style.background='#eef2ff';"
                        onmouseout="this.style.borderColor='#e2e8f0'; this.style.background='#f8fafc';">
                    🎬 @choice
                </button>
            }
        </div>
    }
</div>
