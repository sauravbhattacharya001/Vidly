@model Vidly.Models.MovieChallenge

@{
    ViewBag.Title = Model.Title + " - Challenge Details";
}

<style>
    .detail-header {
        text-align: center; padding: 40px 20px;
        background: linear-gradient(135deg, #e65100, #ff6d00);
        color: #fff; margin: -20px -15px 30px; border-radius: 0 0 20px 20px;
    }
    .detail-header .icon { font-size: 72px; display: block; margin-bottom: 10px; }
    .detail-header h1 { font-size: 36px; margin: 0; }
    .detail-header .desc { font-size: 16px; opacity: .85; margin-top: 8px; }

    .stat-row { display: flex; gap: 20px; margin-bottom: 30px; flex-wrap: wrap; }
    .stat-box {
        flex: 1; min-width: 140px; background: #fff; border-radius: 12px;
        padding: 20px; text-align: center; box-shadow: 0 2px 10px rgba(0,0,0,.06);
    }
    .stat-box .val { font-size: 28px; font-weight: 700; color: #e65100; }
    .stat-box .lbl { font-size: 13px; color: #888; margin-top: 4px; }

    .participants-table { width: 100%; border-collapse: collapse; }
    .participants-table th { text-align: left; padding: 10px; border-bottom: 2px solid #eee; color: #666; font-size: 13px; }
    .participants-table td { padding: 10px; border-bottom: 1px solid #f5f5f5; }
    .prog-bar { background: #eee; border-radius: 8px; height: 8px; overflow: hidden; width: 120px; display: inline-block; vertical-align: middle; }
    .prog-fill { height: 100%; border-radius: 8px; background: linear-gradient(90deg, #e65100, #ff6d00); }
    .completed-badge { background: #e8f5e9; color: #2e7d32; padding: 2px 10px; border-radius: 10px; font-size: 12px; font-weight: 600; }
    .in-progress-badge { background: #fff3e0; color: #e65100; padding: 2px 10px; border-radius: 10px; font-size: 12px; font-weight: 600; }
</style>

<div class="detail-header">
    <span class="icon">@Model.Icon</span>
    <h1>@Model.Title</h1>
    <p class="desc">@Model.Description</p>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<div class="stat-row">
    <div class="stat-box">
        <div class="val">@Model.Target</div>
        <div class="lbl">Target</div>
    </div>
    <div class="stat-box">
        <div class="val">@Model.RewardPoints</div>
        <div class="lbl">Reward Points</div>
    </div>
    <div class="stat-box">
        <div class="val">@Model.Participants.Count</div>
        <div class="lbl">Participants</div>
    </div>
    <div class="stat-box">
        <div class="val">@Model.Participants.Count(p => p.IsCompleted)</div>
        <div class="lbl">Completed</div>
    </div>
    <div class="stat-box">
        <div class="val">@Model.Difficulty</div>
        <div class="lbl">Difficulty</div>
    </div>
    <div class="stat-box">
        <div class="val">@(Model.IsActive ? "Active" : "Expired")</div>
        <div class="lbl">@Model.StartDate.ToString("MMM d") – @Model.EndDate.ToString("MMM d")</div>
    </div>
</div>

<h3>Participants</h3>
@if (Model.Participants.Any())
{
    <table class="participants-table">
        <thead>
            <tr>
                <th>#</th>
                <th>Name</th>
                <th>Progress</th>
                <th>Status</th>
                <th>Joined</th>
            </tr>
        </thead>
        <tbody>
            @{ int i = 0; }
            @foreach (var p in Model.Participants.OrderByDescending(x => x.Progress))
            {
                i++;
                var pct = p.PercentComplete(Model.Target);
                <tr>
                    <td>@i</td>
                    <td><strong>@p.CustomerName</strong></td>
                    <td>
                        @p.Progress / @Model.Target
                        <div class="prog-bar"><div class="prog-fill" style="width:@((int)pct)%"></div></div>
                    </td>
                    <td>
                        @if (p.IsCompleted)
                        {
                            <span class="completed-badge">✅ Completed</span>
                        }
                        else
                        {
                            <span class="in-progress-badge">🔄 In Progress</span>
                        }
                    </td>
                    <td>@p.JoinedDate.ToString("MMM d")</td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <p style="color:#999;text-align:center;padding:30px">No participants yet. Be the first to join!</p>
}

<div style="margin-top:30px">
    @if (Model.IsActive)
    {
        using (Html.BeginForm("Join", "Challenges", new { id = Model.Id }, FormMethod.Post, new { style = "display:inline" }))
        {
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-warning btn-lg">Join This Challenge</button>
        }
    }
    <a href="@Url.Action("Index")" class="btn btn-default btn-lg" style="margin-left:8px">← Back to Challenges</a>
</div>
