@{ ViewBag.Title = "Demand Forecast"; }

<div class="container-fluid" id="forecast-app" style="padding-top:20px">
    <!-- Summary Cards -->
    <div class="row" id="summary-row">
        <div class="col-md-2 col-sm-4">
            <div class="panel panel-primary text-center">
                <div class="panel-heading"><strong>Predicted Rentals</strong></div>
                <div class="panel-body"><h2 id="total-predicted">—</h2><small>next 7 days</small></div>
            </div>
        </div>
        <div class="col-md-2 col-sm-4">
            <div class="panel panel-success text-center">
                <div class="panel-heading"><strong>Top Genre</strong></div>
                <div class="panel-body"><h3 id="top-genre">—</h3></div>
            </div>
        </div>
        <div class="col-md-2 col-sm-4">
            <div class="panel panel-info text-center">
                <div class="panel-heading"><strong>Top Movie</strong></div>
                <div class="panel-body"><h4 id="top-movie" style="font-size:14px">—</h4></div>
            </div>
        </div>
        <div class="col-md-2 col-sm-4">
            <div class="panel panel-warning text-center">
                <div class="panel-heading"><strong>Stock Alerts</strong></div>
                <div class="panel-body"><h2 id="alert-count">—</h2></div>
            </div>
        </div>
        <div class="col-md-2 col-sm-4">
            <div class="panel panel-default text-center">
                <div class="panel-heading"><strong>Health Score</strong></div>
                <div class="panel-body"><canvas id="health-gauge" width="100" height="70"></canvas><div id="health-label"></div></div>
            </div>
        </div>
        <div class="col-md-2 col-sm-4">
            <div class="panel panel-default text-center">
                <div class="panel-heading"><strong>Auto-Refresh</strong></div>
                <div class="panel-body">
                    <label class="switch-label"><input type="checkbox" id="auto-refresh"> <span id="refresh-status">Off</span></label>
                    <br><small id="last-updated"></small>
                </div>
            </div>
        </div>
    </div>

    <!-- Charts Row -->
    <div class="row">
        <div class="col-md-7">
            <div class="panel panel-default">
                <div class="panel-heading"><strong>📈 7-Day Rental Forecast</strong></div>
                <div class="panel-body"><canvas id="forecast-chart" height="250"></canvas></div>
            </div>
        </div>
        <div class="col-md-5">
            <div class="panel panel-default">
                <div class="panel-heading"><strong>🔥 Genre Demand Heatmap</strong></div>
                <div class="panel-body" id="heatmap-container" style="overflow-x:auto"></div>
            </div>
        </div>
    </div>

    <!-- Alerts & Recommendations -->
    <div class="row">
        <div class="col-md-7">
            <div class="panel panel-danger">
                <div class="panel-heading"><strong>⚠️ Stock Alerts</strong>
                    <select id="risk-filter" class="pull-right" style="color:#333">
                        <option value="">All Levels</option>
                        <option value="Critical">Critical</option>
                        <option value="High">High</option>
                        <option value="Medium">Medium</option>
                        <option value="Low">Low</option>
                    </select>
                </div>
                <table class="table table-striped table-hover" id="alerts-table">
                    <thead><tr><th>Movie</th><th>Stock</th><th>Predicted</th><th>Risk</th><th>Days Left</th></tr></thead>
                    <tbody></tbody>
                </table>
                <div class="panel-footer text-muted" id="no-alerts" style="display:none">✅ No stock alerts — inventory looks healthy!</div>
            </div>
        </div>
        <div class="col-md-5">
            <div class="panel panel-warning">
                <div class="panel-heading"><strong>📦 Restock Recommendations</strong></div>
                <div class="panel-body" id="restock-list"></div>
                <div class="panel-footer text-muted" id="no-restock" style="display:none">No restocking needed right now.</div>
            </div>
        </div>
    </div>

    <!-- Proactive Insights -->
    <div class="row">
        <div class="col-md-12">
            <div class="panel panel-default">
                <div class="panel-heading"><strong>🤖 Proactive Insights</strong></div>
                <div class="panel-body" id="insights-container"></div>
            </div>
        </div>
    </div>

    <!-- Movie Forecasts Table -->
    <div class="row">
        <div class="col-md-12">
            <div class="panel panel-default">
                <div class="panel-heading"><strong>📊 Per-Movie Forecasts</strong>
                    <select id="genre-filter" class="pull-right" style="color:#333">
                        <option value="">All Genres</option>
                    </select>
                </div>
                <table class="table table-striped table-condensed" id="movie-table">
                    <thead><tr><th>Movie</th><th>Genre</th><th>Day 1</th><th>Day 2</th><th>Day 3</th><th>Day 4</th><th>Day 5</th><th>Day 6</th><th>Day 7</th><th>Trend</th><th>Surge</th></tr></thead>
                    <tbody></tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<style>
    .risk-Critical { background:#d9534f; color:#fff; padding:2px 8px; border-radius:3px; font-weight:bold }
    .risk-High { background:#f0ad4e; color:#fff; padding:2px 8px; border-radius:3px; font-weight:bold }
    .risk-Medium { background:#f7dc6f; color:#333; padding:2px 8px; border-radius:3px }
    .risk-Low { background:#5cb85c; color:#fff; padding:2px 8px; border-radius:3px }
    .urgency-Critical { border-left:4px solid #d9534f; padding:8px 12px; margin-bottom:8px; background:#fdf2f2 }
    .urgency-High { border-left:4px solid #f0ad4e; padding:8px 12px; margin-bottom:8px; background:#fef9e7 }
    .trend-Rising { color:#27ae60 }
    .trend-Falling { color:#e74c3c }
    .trend-Stable { color:#7f8c8d }
    .surge-badge { background:#e74c3c; color:#fff; padding:2px 6px; border-radius:10px; font-size:11px }
    .insight-card { padding:10px 15px; margin-bottom:8px; border-radius:4px; border-left:4px solid #3498db; background:#eaf2f8 }
    .heatmap-cell { display:inline-block; width:50px; height:30px; text-align:center; line-height:30px; font-size:11px; color:#fff; margin:1px; border-radius:2px }
    #heatmap-container table { width:100% }
    #heatmap-container td, #heatmap-container th { text-align:center; padding:4px; font-size:12px }
    .fade-in { animation: fadeIn 0.5s ease-in }
    @@keyframes fadeIn { from { opacity:0 } to { opacity:1 } }
</style>

<script>
(function() {
    var refreshTimer = null;
    var data = null;

    function load() {
        var xhr = new XMLHttpRequest();
        xhr.open('GET', '@Url.Action("Api")');
        xhr.onload = function() {
            if (xhr.status === 200) {
                data = JSON.parse(xhr.responseText);
                render(data);
                document.getElementById('last-updated').textContent = 'Updated: ' + new Date().toLocaleTimeString();
            }
        };
        xhr.send();
    }

    function render(d) {
        // Summary
        document.getElementById('total-predicted').textContent = d.Summary.TotalPredictedRentals.toFixed(0);
        document.getElementById('top-genre').textContent = d.Summary.TopGenre;
        document.getElementById('top-movie').textContent = d.Summary.TopMovie;
        document.getElementById('alert-count').textContent = d.Summary.AlertCount;
        drawGauge(d.Summary.HealthScore);
        document.getElementById('health-label').textContent = d.Summary.HealthScore + '/100';

        drawForecastChart(d);
        drawHeatmap(d.GenreHeatmap);
        drawAlerts(d.StockAlerts);
        drawRestock(d.Recommendations);
        drawInsights(d);
        drawMovieTable(d.MovieForecasts);
        populateGenreFilter(d.MovieForecasts);
    }

    function drawGauge(score) {
        var c = document.getElementById('health-gauge');
        var ctx = c.getContext('2d');
        ctx.clearRect(0, 0, c.width, c.height);
        var cx = c.width / 2, cy = 55, r = 40;
        // Background arc
        ctx.beginPath(); ctx.arc(cx, cy, r, Math.PI, 0); ctx.lineWidth = 10;
        ctx.strokeStyle = '#eee'; ctx.stroke();
        // Score arc
        var angle = Math.PI + (score / 100) * Math.PI;
        ctx.beginPath(); ctx.arc(cx, cy, r, Math.PI, angle); ctx.lineWidth = 10;
        ctx.strokeStyle = score >= 70 ? '#27ae60' : score >= 40 ? '#f39c12' : '#e74c3c';
        ctx.stroke();
    }

    function drawForecastChart(d) {
        var c = document.getElementById('forecast-chart');
        var ctx = c.getContext('2d');
        var W = c.width = c.parentElement.offsetWidth - 30;
        var H = c.height = 250;
        ctx.clearRect(0, 0, W, H);

        // Aggregate daily totals
        var days = ['Day 1','Day 2','Day 3','Day 4','Day 5','Day 6','Day 7'];
        var totals = [0,0,0,0,0,0,0];
        d.MovieForecasts.forEach(function(m) {
            for (var i = 0; i < 7; i++) totals[i] += m.DailyPredictions[i];
        });
        var max = Math.max.apply(null, totals) * 1.2 || 1;

        var pad = 50, barW = (W - pad * 2) / 7 * 0.6, gap = (W - pad * 2) / 7;

        // Bars
        totals.forEach(function(v, i) {
            var x = pad + i * gap + gap * 0.2;
            var h = (v / max) * (H - 80);
            var y = H - 40 - h;
            ctx.fillStyle = '#3498db';
            ctx.fillRect(x, y, barW, h);
            // Label
            ctx.fillStyle = '#333'; ctx.font = '11px sans-serif'; ctx.textAlign = 'center';
            ctx.fillText(v.toFixed(1), x + barW/2, y - 5);
            ctx.fillText(days[i], x + barW/2, H - 25);
        });

        // Trend line
        ctx.beginPath(); ctx.strokeStyle = '#e74c3c'; ctx.lineWidth = 2;
        totals.forEach(function(v, i) {
            var x = pad + i * gap + gap * 0.2 + barW/2;
            var y = H - 40 - (v / max) * (H - 80);
            if (i === 0) ctx.moveTo(x, y); else ctx.lineTo(x, y);
        });
        ctx.stroke();
    }

    function drawHeatmap(heatmap) {
        if (!heatmap.length) { document.getElementById('heatmap-container').innerHTML = '<p class="text-muted">No data</p>'; return; }
        var genres = [], dayOrder = ['Sun','Mon','Tue','Wed','Thu','Fri','Sat'];
        var map = {};
        heatmap.forEach(function(e) {
            if (genres.indexOf(e.Genre) < 0) genres.push(e.Genre);
            map[e.Genre + '_' + e.DayOfWeek] = e.PredictedDemand;
        });
        var maxVal = Math.max.apply(null, heatmap.map(function(e){ return e.PredictedDemand; })) || 1;

        var html = '<table class="table table-condensed"><thead><tr><th></th>';
        dayOrder.forEach(function(d){ html += '<th>' + d + '</th>'; });
        html += '</tr></thead><tbody>';
        genres.forEach(function(g) {
            html += '<tr><td><strong>' + g + '</strong></td>';
            dayOrder.forEach(function(d) {
                var v = map[g + '_' + d] || 0;
                var intensity = Math.round((v / maxVal) * 255);
                var bg = 'rgb(' + (255 - intensity) + ',' + (100 + Math.round(intensity * 0.6)) + ',' + (100) + ')';
                html += '<td style="background:' + bg + ';color:#fff;font-weight:bold">' + v.toFixed(1) + '</td>';
            });
            html += '</tr>';
        });
        html += '</tbody></table>';
        document.getElementById('heatmap-container').innerHTML = html;
    }

    function drawAlerts(alerts) {
        var filter = document.getElementById('risk-filter').value;
        var filtered = filter ? alerts.filter(function(a){ return a.RiskLevel === filter; }) : alerts;
        var tbody = document.querySelector('#alerts-table tbody');
        if (!filtered.length) {
            tbody.innerHTML = '';
            document.getElementById('no-alerts').style.display = 'block';
            return;
        }
        document.getElementById('no-alerts').style.display = 'none';
        tbody.innerHTML = filtered.map(function(a) {
            return '<tr class="fade-in"><td>' + a.MovieName + '</td><td>' + a.CurrentStock + '</td><td>' +
                a.PredictedDemand.toFixed(1) + '</td><td><span class="risk-' + a.RiskLevel + '">' +
                a.RiskLevel + '</span></td><td>' + a.DaysUntilStockout + '</td></tr>';
        }).join('');
    }

    function drawRestock(recs) {
        var el = document.getElementById('restock-list');
        if (!recs.length) { el.innerHTML = ''; document.getElementById('no-restock').style.display = 'block'; return; }
        document.getElementById('no-restock').style.display = 'none';
        el.innerHTML = recs.map(function(r) {
            return '<div class="urgency-' + r.Urgency + ' fade-in"><strong>' + r.MovieName + '</strong> (' + r.Genre + ')' +
                '<br>➕ Add <strong>' + r.RecommendedQuantity + '</strong> copies — ' + r.Reason +
                '<br><button class="btn btn-xs btn-default" onclick="this.textContent=\'✓ Acknowledged\';this.disabled=true">Acknowledge</button></div>';
        }).join('');
    }

    function drawInsights(d) {
        var insights = [];
        // Surge detection
        d.MovieForecasts.filter(function(m){ return m.SurgeDetected; }).forEach(function(m) {
            insights.push('🚀 <strong>' + m.Genre + '</strong> surge detected for "' + m.Name + '" — demand is ' +
                (m.DailyPredictions.reduce(function(a,b){return a+b},0) / 7 / (m.HistoricalAverage || 1)).toFixed(1) + 'x historical average');
        });
        // Genre trends
        var genreGroups = {};
        d.MovieForecasts.forEach(function(m) {
            if (!genreGroups[m.Genre]) genreGroups[m.Genre] = { rising: 0, falling: 0, total: 0 };
            genreGroups[m.Genre].total++;
            if (m.TrendDirection === 'Rising') genreGroups[m.Genre].rising++;
            if (m.TrendDirection === 'Falling') genreGroups[m.Genre].falling++;
        });
        Object.keys(genreGroups).forEach(function(g) {
            var info = genreGroups[g];
            if (info.rising > info.total * 0.6) insights.push('📈 <strong>' + g + '</strong> genre is trending up — ' + info.rising + '/' + info.total + ' movies rising');
            if (info.falling > info.total * 0.6) insights.push('📉 <strong>' + g + '</strong> genre is cooling down — consider promotional push');
        });
        // Health
        if (d.Summary.HealthScore < 50) insights.push('🏥 Inventory health is <strong>critical</strong> (' + d.Summary.HealthScore + '/100) — immediate restocking recommended');
        else if (d.Summary.HealthScore >= 90) insights.push('💚 Inventory health is <strong>excellent</strong> (' + d.Summary.HealthScore + '/100) — well stocked for projected demand');
        // Stock alerts summary
        if (d.StockAlerts.length > 3) insights.push('⚠️ <strong>' + d.StockAlerts.length + ' movies</strong> have stock concerns — review alerts table for details');

        if (!insights.length) insights.push('✅ Everything looks good — no proactive actions needed right now');
        document.getElementById('insights-container').innerHTML = insights.map(function(i) {
            return '<div class="insight-card fade-in">' + i + '</div>';
        }).join('');
    }

    function drawMovieTable(forecasts) {
        var filter = document.getElementById('genre-filter').value;
        var filtered = filter ? forecasts.filter(function(m){ return m.Genre === filter; }) : forecasts;
        filtered.sort(function(a,b) {
            var sa = a.DailyPredictions.reduce(function(x,y){return x+y},0);
            var sb = b.DailyPredictions.reduce(function(x,y){return x+y},0);
            return sb - sa;
        });
        var tbody = document.querySelector('#movie-table tbody');
        tbody.innerHTML = filtered.slice(0, 50).map(function(m) {
            var trendCls = 'trend-' + m.TrendDirection;
            var trendIcon = m.TrendDirection === 'Rising' ? '▲' : m.TrendDirection === 'Falling' ? '▼' : '—';
            var surge = m.SurgeDetected ? '<span class="surge-badge">SURGE</span>' : '';
            return '<tr><td>' + m.Name + '</td><td>' + m.Genre + '</td>' +
                m.DailyPredictions.map(function(p){ return '<td>' + p.toFixed(2) + '</td>'; }).join('') +
                '<td class="' + trendCls + '">' + trendIcon + ' ' + m.TrendDirection + '</td><td>' + surge + '</td></tr>';
        }).join('');
    }

    function populateGenreFilter(forecasts) {
        var sel = document.getElementById('genre-filter');
        if (sel.options.length > 1) return;
        var genres = [];
        forecasts.forEach(function(m) { if (genres.indexOf(m.Genre) < 0) genres.push(m.Genre); });
        genres.sort().forEach(function(g) {
            var opt = document.createElement('option');
            opt.value = g; opt.textContent = g;
            sel.appendChild(opt);
        });
    }

    // Filter handlers
    document.getElementById('risk-filter').addEventListener('change', function() { if (data) drawAlerts(data.StockAlerts); });
    document.getElementById('genre-filter').addEventListener('change', function() { if (data) drawMovieTable(data.MovieForecasts); });

    // Auto-refresh
    document.getElementById('auto-refresh').addEventListener('change', function() {
        if (this.checked) {
            refreshTimer = setInterval(load, 30000);
            document.getElementById('refresh-status').textContent = 'On (30s)';
        } else {
            clearInterval(refreshTimer);
            document.getElementById('refresh-status').textContent = 'Off';
        }
    });

    load();
})();
</script>
