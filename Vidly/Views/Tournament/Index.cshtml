@model Vidly.ViewModels.TournamentViewModel
@{
    ViewBag.Title = "Movie Tournament";
}

<h2><span class="glyphicon glyphicon-tower"></span> Movie Tournament</h2>
<p class="lead">Create a bracket, vote head-to-head, crown a champion!</p>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<div class="row">
    <!-- Create Tournament -->
    <div class="col-md-5">
        <div class="panel panel-primary">
            <div class="panel-heading"><strong>New Tournament</strong></div>
            <div class="panel-body">
                @using (Html.BeginForm("Create", "Tournament", FormMethod.Post))
                {
                    @Html.AntiForgeryToken()
                    <div class="form-group">
                        <label for="name">Tournament Name</label>
                        <input type="text" class="form-control" id="name" name="name"
                               placeholder="e.g. March Madness Movies" required />
                    </div>
                    <div class="form-group">
                        <label for="customerId">Created By</label>
                        <select class="form-control" id="customerId" name="customerId" required>
                            <option value="">-- Select Customer --</option>
                            @foreach (var c in Model.Customers)
                            {
                                <option value="@c.Id">@c.Name</option>
                            }
                        </select>
                    </div>
                    <div class="form-group">
                        <label for="size">Bracket Size</label>
                        <select class="form-control" id="size" name="size">
                            <option value="4">4 Movies</option>
                            <option value="8" selected>8 Movies</option>
                            <option value="16">16 Movies</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label for="genreFilter">Genre Filter (optional)</label>
                        <select class="form-control" id="genreFilter" name="genreFilter">
                            <option value="Any">Any Genre</option>
                            @foreach (var g in Enum.GetValues(typeof(Vidly.Models.Genre)).Cast<Vidly.Models.Genre>())
                            {
                                <option value="@g">@g</option>
                            }
                        </select>
                    </div>
                    <button type="submit" class="btn btn-primary btn-block">
                        <span class="glyphicon glyphicon-play"></span> Start Tournament
                    </button>
                }
            </div>
        </div>
    </div>

    <!-- Active Tournaments -->
    <div class="col-md-7">
        <div class="panel panel-info">
            <div class="panel-heading"><strong>Active Tournaments</strong></div>
            @if (Model.ActiveTournaments.Count == 0)
            {
                <div class="panel-body text-muted">No active tournaments. Create one!</div>
            }
            else
            {
                <table class="table table-hover">
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>Size</th>
                            <th>Round</th>
                            <th>Created By</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var t in Model.ActiveTournaments)
                        {
                            <tr>
                                <td><strong>@t.Name</strong></td>
                                <td>@t.Size movies</td>
                                <td>Round @t.CurrentRound / @t.TotalRounds</td>
                                <td>@t.CreatedByCustomerName</td>
                                <td>
                                    <a href="@Url.Action("Bracket", new { id = t.Id })" class="btn btn-sm btn-success">
                                        <span class="glyphicon glyphicon-play"></span> Continue
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </div>
</div>

<!-- Hall of Fame -->
@if (Model.HallOfFame.Count > 0)
{
    <div class="panel panel-warning">
        <div class="panel-heading"><strong><span class="glyphicon glyphicon-star"></span> Hall of Fame</strong></div>
        <table class="table">
            <thead>
                <tr>
                    <th>Tournament</th>
                    <th>Champion</th>
                    <th>Bracket Size</th>
                    <th>Created By</th>
                    <th>Completed</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var r in Model.HallOfFame)
                {
                    <tr>
                        <td>@r.TournamentName</td>
                        <td><strong class="text-warning">🏆 @r.ChampionName</strong></td>
                        <td>@r.Size movies</td>
                        <td>@r.CreatedBy</td>
                        <td>@r.CompletedAt.ToString("MMM d, yyyy")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

<!-- Movie Records -->
@if (Model.MovieRecords.Count > 0)
{
    <div class="panel panel-default">
        <div class="panel-heading"><strong>Movie Win/Loss Records</strong></div>
        <table class="table table-striped">
            <thead>
                <tr>
                    <th>Movie</th>
                    <th>Tournaments Won</th>
                    <th>Matches W/L</th>
                    <th>Win Rate</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var r in Model.MovieRecords.Take(10))
                {
                    <tr>
                        <td>@r.MovieName</td>
                        <td>
                            @for (int i = 0; i < r.TournamentsWon; i++)
                            {
                                <span>🏆</span>
                            }
                            @if (r.TournamentsWon == 0)
                            {
                                <span class="text-muted">—</span>
                            }
                        </td>
                        <td>@r.MatchesWon W / @r.MatchesLost L</td>
                        <td>
                            <div class="progress" style="margin-bottom: 0; min-width: 80px;">
                                <div class="progress-bar progress-bar-success" style="width: @r.WinRate%;">
                                    @r.WinRate%
                                </div>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
