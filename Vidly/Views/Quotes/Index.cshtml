@model Vidly.ViewModels.QuoteBoardViewModel
@{
    ViewBag.Title = "Movie Quotes";
}

<div class="container" style="margin-top: 20px;">
    <div class="page-header">
        <h1><span class="glyphicon glyphicon-comment"></span> Movie Quotes Board</h1>
        <p class="lead text-muted">Browse, submit, and vote on memorable movie lines</p>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible">
            <button type="button" class="close" data-dismiss="alert">&times;</button>
            @TempData["Success"]
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible">
            <button type="button" class="close" data-dismiss="alert">&times;</button>
            @TempData["Error"]
        </div>
    }

    @* Random Quote of the Day *@
    @if (Model.RandomQuote != null)
    {
        <div class="panel panel-info">
            <div class="panel-heading">
                <h3 class="panel-title"><span class="glyphicon glyphicon-random"></span> Quote of the Moment</h3>
            </div>
            <div class="panel-body" style="text-align: center;">
                <blockquote style="border-left: 4px solid #5bc0de; font-size: 1.3em;">
                    <p>"@Model.RandomQuote.Text"</p>
                    <footer>
                        @Model.RandomQuote.Character in <cite>@Model.RandomQuote.MovieName</cite>
                        <span class="badge" style="margin-left: 8px;">@Model.RandomQuote.Votes votes</span>
                    </footer>
                </blockquote>
            </div>
        </div>
    }

    <div class="row">
        @* Left: Submit Form + Filter *@
        <div class="col-md-4">
            <div class="panel panel-default">
                <div class="panel-heading">
                    <h3 class="panel-title"><span class="glyphicon glyphicon-plus"></span> Submit a Quote</h3>
                </div>
                <div class="panel-body">
                    @using (Html.BeginForm("Submit", "Quotes", FormMethod.Post))
                    {
                        @Html.AntiForgeryToken()
                        <div class="form-group">
                            <label for="movieId">Movie</label>
                            <select name="movieId" id="movieId" class="form-control" required>
                                <option value="">-- Select --</option>
                                @foreach (var movie in Model.Movies)
                                {
                                    <option value="@movie.Id">@movie.Name</option>
                                }
                            </select>
                        </div>
                        <div class="form-group">
                            <label for="text">Quote</label>
                            <textarea name="text" id="text" class="form-control" rows="3" maxlength="500"
                                      placeholder="I'm gonna make him an offer he can't refuse..." required></textarea>
                            <p class="help-block">Max 500 characters</p>
                        </div>
                        <div class="form-group">
                            <label for="character">Character</label>
                            <input type="text" name="character" id="character" class="form-control"
                                   placeholder="e.g. Don Corleone" />
                        </div>
                        <div class="form-group">
                            <label for="customerId">Your Customer ID</label>
                            <input type="number" name="customerId" id="customerId" class="form-control"
                                   min="1" required />
                        </div>
                        <button type="submit" class="btn btn-primary btn-block">
                            <span class="glyphicon glyphicon-send"></span> Submit Quote
                        </button>
                    }
                </div>
            </div>

            @* Filter by Movie *@
            <div class="panel panel-default">
                <div class="panel-heading">
                    <h3 class="panel-title"><span class="glyphicon glyphicon-filter"></span> Filter by Movie</h3>
                </div>
                <div class="list-group">
                    <a href="@Url.Action("Index")" class="list-group-item @(Model.FilterMovieId == null ? "active" : "")">
                        All Movies
                    </a>
                    @foreach (var movie in Model.Movies)
                    {
                        <a href="@Url.Action("Index", new { movieId = movie.Id })"
                           class="list-group-item @(Model.FilterMovieId == movie.Id ? "active" : "")">
                            @movie.Name
                        </a>
                    }
                </div>
            </div>
        </div>

        @* Right: Quotes List *@
        <div class="col-md-8">
            @if (!Model.Quotes.Any())
            {
                <div class="alert alert-info">
                    <span class="glyphicon glyphicon-info-sign"></span>
                    No quotes yet. Be the first to submit one!
                </div>
            }
            else
            {
                var rank = 1;
                foreach (var quote in Model.Quotes)
                {
                    <div class="panel panel-default">
                        <div class="panel-body">
                            <div class="row">
                                <div class="col-xs-2 col-sm-1 text-center">
                                    @using (Html.BeginForm("Upvote", "Quotes", new { id = quote.Id }, FormMethod.Post, new { style = "display:inline" }))
                                    {
                                        <button type="submit" class="btn btn-sm btn-default" title="Upvote">
                                            <span class="glyphicon glyphicon-thumbs-up"></span>
                                        </button>
                                    }
                                    <div style="font-size: 1.2em; font-weight: bold; margin-top: 4px;">@quote.Votes</div>
                                </div>
                                <div class="col-xs-10 col-sm-11">
                                    <blockquote style="margin-bottom: 0; border-left-color: #337ab7;">
                                        <p style="font-size: 1.1em;">"@quote.Text"</p>
                                        <footer>
                                            <strong>@quote.Character</strong> in <cite>@quote.MovieName</cite>
                                        </footer>
                                    </blockquote>
                                    <p class="text-muted" style="margin-top: 6px; font-size: 0.85em;">
                                        <span class="glyphicon glyphicon-user"></span> Submitted by @quote.SubmittedByName
                                        &middot;
                                        <span class="glyphicon glyphicon-time"></span> @quote.SubmittedAt.ToString("MMM dd, yyyy")
                                        @if (rank <= 3)
                                        {
                                            <span class="label label-warning" style="margin-left: 6px;">
                                                <span class="glyphicon glyphicon-star"></span>
                                                Top @rank
                                            </span>
                                        }
                                    </p>
                                </div>
                            </div>
                        </div>
                    </div>
                    rank++;
                }
            }
        </div>
    </div>
</div>
