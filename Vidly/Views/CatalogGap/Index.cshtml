@model Vidly.Models.CatalogGapDashboard
@{
    ViewBag.Title = "Catalog Gap Analyzer";
}

<style>
    .gap-header { background: #1a1a2e; color: #fff; padding: 30px; border-radius: 8px; margin-bottom: 25px; }
    .gap-header h1 { margin: 0 0 5px; font-size: 28px; }
    .gap-header p { margin: 0; opacity: 0.8; }
    .score-circle { width: 120px; height: 120px; border-radius: 50%; border: 8px solid; display: flex; align-items: center; justify-content: center; flex-direction: column; margin: 0 auto; }
    .score-circle.grade-a { border-color: #27ae60; }
    .score-circle.grade-b { border-color: #2ecc71; }
    .score-circle.grade-c { border-color: #f39c12; }
    .score-circle.grade-d { border-color: #e67e22; }
    .score-circle.grade-f { border-color: #e74c3c; }
    .score-value { font-size: 28px; font-weight: bold; }
    .score-grade { font-size: 14px; opacity: 0.7; }
    .metric-card { background: #f8f9fa; border-radius: 8px; padding: 20px; text-align: center; margin-bottom: 15px; border-left: 4px solid #3498db; }
    .metric-card .value { font-size: 24px; font-weight: bold; color: #2c3e50; }
    .metric-card .label { font-size: 12px; color: #7f8c8d; text-transform: uppercase; }
    .gap-bar-container { margin-bottom: 8px; }
    .gap-bar-label { display: inline-block; width: 100px; font-size: 13px; }
    .gap-bar-track { display: inline-block; width: calc(100% - 220px); height: 20px; background: #ecf0f1; border-radius: 4px; position: relative; vertical-align: middle; overflow: hidden; }
    .gap-bar-fill { height: 100%; border-radius: 4px; transition: width 0.3s; }
    .gap-bar-fill.underserved { background: #e74c3c; }
    .gap-bar-fill.balanced { background: #27ae60; }
    .gap-bar-fill.oversaturated { background: #3498db; }
    .gap-bar-value { display: inline-block; width: 80px; text-align: right; font-size: 13px; font-weight: bold; }
    .priority-badge { display: inline-block; padding: 2px 8px; border-radius: 12px; font-size: 11px; font-weight: bold; color: #fff; }
    .priority-badge.high { background: #e74c3c; }
    .priority-badge.medium { background: #f39c12; }
    .priority-badge.low { background: #3498db; }
    .signal-item { padding: 12px; border-left: 3px solid #9b59b6; margin-bottom: 10px; background: #fafafa; border-radius: 0 4px 4px 0; }
    .signal-category { font-size: 11px; text-transform: uppercase; color: #9b59b6; font-weight: bold; }
    .confidence-bar { display: inline-block; width: 60px; height: 6px; background: #ecf0f1; border-radius: 3px; margin-left: 8px; vertical-align: middle; }
    .confidence-fill { height: 100%; background: #9b59b6; border-radius: 3px; }
    .section-title { border-bottom: 2px solid #1a1a2e; padding-bottom: 8px; margin: 25px 0 15px; }
</style>

<div class="gap-header">
    <div class="row">
        <div class="col-md-8">
            <h1><i class="glyphicon glyphicon-search"></i> Catalog Gap Analyzer</h1>
            <p>Autonomous demand-vs-supply analysis with acquisition recommendations</p>
        </div>
        <div class="col-md-4 text-center">
            <div class="score-circle grade-@Model.CoverageGrade.ToLower()">
                <span class="score-value">@Model.OverallCoverageScore%</span>
                <span class="score-grade">Grade @Model.CoverageGrade</span>
            </div>
        </div>
    </div>
</div>

<!-- Health Summary -->
<div class="row">
    <div class="col-md-2 col-sm-4 col-xs-6">
        <div class="metric-card">
            <div class="value">@Model.Health.TotalMovies</div>
            <div class="label">Total Movies</div>
        </div>
    </div>
    <div class="col-md-2 col-sm-4 col-xs-6">
        <div class="metric-card">
            <div class="value">@Model.Health.TotalRentals</div>
            <div class="label">Total Rentals</div>
        </div>
    </div>
    <div class="col-md-2 col-sm-4 col-xs-6">
        <div class="metric-card">
            <div class="value">@Model.Health.ActiveGenres</div>
            <div class="label">Active Genres</div>
        </div>
    </div>
    <div class="col-md-2 col-sm-4 col-xs-6">
        <div class="metric-card">
            <div class="value">@Model.Health.AvgRating★</div>
            <div class="label">Avg Rating</div>
        </div>
    </div>
    <div class="col-md-2 col-sm-4 col-xs-6">
        <div class="metric-card">
            <div class="value">@Model.Health.FreshnessScore%</div>
            <div class="label">Freshness</div>
        </div>
    </div>
    <div class="col-md-2 col-sm-4 col-xs-6">
        <div class="metric-card" style="border-left-color: @(Model.Health.StaleMovies > 0 ? "#e74c3c" : "#27ae60")">
            <div class="value">@Model.Health.StaleMovies</div>
            <div class="label">Stale Movies</div>
        </div>
    </div>
</div>

<!-- Genre Gap Chart -->
<h3 class="section-title"><i class="glyphicon glyphicon-stats"></i> Genre Gap Analysis</h3>
<div class="panel panel-default">
    <div class="panel-body">
        @foreach (var gap in Model.GenreGaps)
        {
            var barWidth = Math.Min(100, Math.Abs(gap.GapScore) * 3);
            var cssClass = gap.Verdict == "Underserved" ? "underserved" : gap.Verdict == "Oversaturated" ? "oversaturated" : "balanced";
            <div class="gap-bar-container">
                <span class="gap-bar-label">@gap.Genre</span>
                <span class="gap-bar-track">
                    <span class="gap-bar-fill @cssClass" style="width: @barWidth%"></span>
                </span>
                <span class="gap-bar-value @cssClass" style="color: @(cssClass == "underserved" ? "#e74c3c" : cssClass == "oversaturated" ? "#3498db" : "#27ae60")">
                    @(gap.GapScore > 0 ? "+" : "")@gap.GapScore%
                </span>
            </div>
        }
        <div style="margin-top: 10px; font-size: 12px; color: #7f8c8d;">
            <span style="color:#e74c3c;">■</span> Underserved (high demand, low supply)
            <span style="margin-left:15px; color:#27ae60;">■</span> Balanced
            <span style="margin-left:15px; color:#3498db;">■</span> Oversaturated (low demand, high supply)
        </div>
    </div>
</div>

<!-- Acquisition Recommendations -->
@if (Model.Recommendations.Any())
{
    <h3 class="section-title"><i class="glyphicon glyphicon-shopping-cart"></i> Acquisition Recommendations</h3>
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Genre</th>
                <th>Priority</th>
                <th>Add</th>
                <th>Min Rating</th>
                <th>Impact</th>
                <th>Reason</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var rec in Model.Recommendations)
            {
                <tr>
                    <td><strong>@rec.Genre</strong></td>
                    <td><span class="priority-badge @rec.Priority.ToLower()">@rec.Priority</span></td>
                    <td>+@rec.SuggestedCount titles</td>
                    <td>@rec.MinRating★+</td>
                    <td>+@rec.ExpectedImpact% revenue</td>
                    <td><small>@rec.Reason</small></td>
                </tr>
            }
        </tbody>
    </table>
}

<!-- Demand Signals -->
@if (Model.UnmetDemand.Any())
{
    <h3 class="section-title"><i class="glyphicon glyphicon-flash"></i> Demand Signals</h3>
    @foreach (var signal in Model.UnmetDemand)
    {
        <div class="signal-item">
            <span class="signal-category">@signal.Category</span>
            <span class="confidence-bar"><span class="confidence-fill" style="width: @(signal.Confidence * 100)%"></span></span>
            <p style="margin: 5px 0 0; font-size: 14px;">@signal.Pattern</p>
            <small class="text-muted"><i class="glyphicon glyphicon-arrow-right"></i> @signal.ActionItem</small>
        </div>
    }
}

<div class="text-right" style="margin-top: 20px;">
    <small class="text-muted">Analyzed at @Model.AnalyzedAt.ToString("MMM dd, yyyy h:mm tt")</small>
    <a href="@Url.Action("Index")" class="btn btn-sm btn-default" style="margin-left: 10px;">
        <i class="glyphicon glyphicon-refresh"></i> Re-analyze
    </a>
</div>
