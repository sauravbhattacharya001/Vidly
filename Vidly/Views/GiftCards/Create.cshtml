@model Vidly.ViewModels.GiftCardCreateViewModel
@{
    ViewBag.Title = "Create Gift Card";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h2><span class="glyphicon glyphicon-gift"></span> Create Gift Card</h2>

@using (Html.BeginForm("Create", "GiftCards", FormMethod.Post, new { @class = "form-horizontal", role = "form" }))
{
    @Html.AntiForgeryToken()

    <div class="panel panel-default">
        <div class="panel-heading"><strong>Gift Card Details</strong></div>
        <div class="panel-body">
            <div class="form-group">
                <label class="col-md-3 control-label">Value ($)</label>
                <div class="col-md-4">
                    <div class="btn-group" style="margin-bottom: 10px;">
                        <button type="button" class="btn btn-default" onclick="document.getElementById('Value').value='10.00'">$10</button>
                        <button type="button" class="btn btn-default" onclick="document.getElementById('Value').value='25.00'">$25</button>
                        <button type="button" class="btn btn-default" onclick="document.getElementById('Value').value='50.00'">$50</button>
                        <button type="button" class="btn btn-default" onclick="document.getElementById('Value').value='100.00'">$100</button>
                    </div>
                    @Html.TextBoxFor(m => m.Value, new { @class = "form-control", type = "number", min = "5", max = "500", step = "0.01", id = "Value" })
                    @Html.ValidationMessageFor(m => m.Value, "", new { @class = "text-danger" })
                    <p class="help-block">Between $5.00 and $500.00</p>
                </div>
            </div>

            <div class="form-group">
                <label class="col-md-3 control-label">Purchased By *</label>
                <div class="col-md-6">
                    @Html.TextBoxFor(m => m.PurchaserName, new { @class = "form-control", placeholder = "Name of purchaser" })
                    @Html.ValidationMessageFor(m => m.PurchaserName, "", new { @class = "text-danger" })
                </div>
            </div>

            <div class="form-group">
                <label class="col-md-3 control-label">Recipient</label>
                <div class="col-md-6">
                    @Html.TextBoxFor(m => m.RecipientName, new { @class = "form-control", placeholder = "Optional — who is this for?" })
                </div>
            </div>

            <div class="form-group">
                <label class="col-md-3 control-label">Personal Message</label>
                <div class="col-md-6">
                    @Html.TextAreaFor(m => m.Message, new { @class = "form-control", rows = 3, placeholder = "Optional message for the recipient" })
                </div>
            </div>

            <div class="form-group">
                <label class="col-md-3 control-label">Expiration</label>
                <div class="col-md-6">
                    <div class="checkbox">
                        <label>
                            @Html.CheckBoxFor(m => m.HasExpiration) Set expiration date
                        </label>
                    </div>
                    <div>
                        @Html.TextBoxFor(m => m.ExpirationDays, new { @class = "form-control", type = "number", min = "30", max = "730", style = "width:120px;display:inline" })
                        <span> days from today</span>
                    </div>
                </div>
            </div>
        </div>
        <div class="panel-footer text-right">
            @Html.ActionLink("Cancel", "Index", null, new { @class = "btn btn-default" })
            <button type="submit" class="btn btn-primary">
                <span class="glyphicon glyphicon-gift"></span> Create Gift Card
            </button>
        </div>
    </div>
}
