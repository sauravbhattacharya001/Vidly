@model Vidly.ViewModels.MadLibsIndexViewModel
@{
    ViewBag.Title = "Movie Mad Libs";
}

<div class="container" style="margin-top: 20px;">
    <div class="page-header">
        <h1><span class="glyphicon glyphicon-pencil"></span> Movie Mad Libs</h1>
        <p class="lead text-muted">Fill in the blanks to create hilarious movie plot remixes!</p>
    </div>

    <div class="row" style="margin-bottom: 25px;">
        <div class="col-md-8">
            <div class="panel panel-success">
                <div class="panel-heading">
                    <h3 class="panel-title"><span class="glyphicon glyphicon-random"></span> Feeling Lucky?</h3>
                </div>
                <div class="panel-body text-center">
                    <p style="font-size: 16px;">Don't know which movie to remix? Let us pick one for you!</p>
                    <a href="@Url.Action("Random")" class="btn btn-success btn-lg">
                        <span class="glyphicon glyphicon-random"></span> Random Mad Lib
                    </a>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="panel panel-info">
                <div class="panel-heading">
                    <h3 class="panel-title"><span class="glyphicon glyphicon-stats"></span> Stats</h3>
                </div>
                <div class="panel-body text-center">
                    <h2 style="margin: 5px 0;">@Model.TotalPlays</h2>
                    <p class="text-muted">Mad Libs Created</p>
                    <hr style="margin: 8px 0;">
                    <h4 style="margin: 5px 0;">@Model.Templates.Count</h4>
                    <p class="text-muted">Movie Templates</p>
                </div>
            </div>
        </div>
    </div>

    <h3><span class="glyphicon glyphicon-film"></span> Choose a Movie to Remix</h3>
    <div class="row">
        @foreach (var t in Model.Templates)
        {
            <div class="col-md-4 col-sm-6" style="margin-bottom: 20px;">
                <div class="panel panel-default" style="height: 180px;">
                    <div class="panel-heading">
                        <h4 class="panel-title">
                            @t.MovieName <small class="text-muted">(@t.Year)</small>
                        </h4>
                    </div>
                    <div class="panel-body">
                        <span class="label label-primary">@t.Genre</span>
                        <span class="label label-default">@t.BlankCount blanks</span>
                        <div style="margin-top: 15px;">
                            <a href="@Url.Action("Play", new { id = t.Id })" class="btn btn-primary">
                                <span class="glyphicon glyphicon-play"></span> Play
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>
