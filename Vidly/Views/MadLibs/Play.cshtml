@model Vidly.ViewModels.MadLibsPlayViewModel
@{
    ViewBag.Title = "Mad Libs - " + Model.MovieName;
}

<div class="container" style="margin-top: 20px;">
    <div class="page-header">
        <h1>
            <span class="glyphicon glyphicon-pencil"></span> Mad Libs
            <small>Fill in the blanks!</small>
        </h1>
        <p class="lead">
            You're remixing a <span class="label label-primary">@Model.Genre</span> movie.
            Don't peek — just fill in the words!
        </p>
    </div>

    <div class="alert alert-info">
        <span class="glyphicon glyphicon-info-sign"></span>
        <strong>How to play:</strong> Enter a word for each blank below. The sillier, the better!
        You won't see the movie plot until you're done.
    </div>

    @using (Html.BeginForm("Generate", "MadLibs", FormMethod.Post, new { @class = "form-horizontal" }))
    {
        @Html.AntiForgeryToken()
        <input type="hidden" name="templateId" value="@Model.TemplateId" />

        <div class="panel panel-warning">
            <div class="panel-heading">
                <h3 class="panel-title"><span class="glyphicon glyphicon-list-alt"></span> Your Words (@Model.Blanks.Count blanks)</h3>
            </div>
            <div class="panel-body">
                @for (int i = 0; i < Model.Blanks.Count; i++)
                {
                    var blank = Model.Blanks[i];
                    <div class="form-group">
                        <label class="col-md-4 control-label" style="font-size: 16px;">
                            <span class="badge">@(i + 1)</span> @blank.WordType
                        </label>
                        <div class="col-md-5">
                            <input type="text" name="@blank.Placeholder" class="form-control input-lg"
                                   placeholder="Enter a @blank.WordType.ToLower()..."
                                   required maxlength="50" autocomplete="off" />
                        </div>
                    </div>
                }
            </div>
        </div>

        <div class="text-center" style="margin: 25px 0;">
            <button type="submit" class="btn btn-success btn-lg">
                <span class="glyphicon glyphicon-star"></span> Generate My Mad Lib!
            </button>
            <a href="@Url.Action("Index")" class="btn btn-default btn-lg" style="margin-left: 10px;">
                <span class="glyphicon glyphicon-arrow-left"></span> Back
            </a>
        </div>
    }
</div>
