<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2013/05/nuspec.xsd">
  <metadata>
    <id>Vidly</id>
    <version>$version$</version>
    <title>Vidly — Enterprise Video Rental Platform</title>
    <authors>sauravbhattacharya001</authors>
    <owners>sauravbhattacharya001</owners>
    <license type="expression">MIT</license>
    <projectUrl>https://github.com/sauravbhattacharya001/Vidly</projectUrl>
    <repository type="git" url="https://github.com/sauravbhattacharya001/Vidly.git" branch="master" />
    <requireLicenseAcceptance>false</requireLicenseAcceptance>
    <description>Enterprise ASP.NET MVC 5 video rental platform with 100 controllers, 100 services, 89 models, and 3690+ tests. Features include: repository pattern with thread-safe data stores, recommendation engine (genre affinity, collaborative filtering), customer lifetime value analytics, rental trends forecasting, SPC-based quality monitoring, store pulse health dashboard, parental controls, loyalty rewards, fraud detection, inventory optimization, and comprehensive security hardening (CSP, HSTS, X-Frame-Options). Built on .NET Framework 4.5.2.</description>
    <releaseNotes>See https://github.com/sauravbhattacharya001/Vidly/releases for full changelog.</releaseNotes>
    <copyright>Copyright 2017-2026 Saurav Bhattacharya</copyright>
    <tags>aspnet mvc dotnet-framework video-rental repository-pattern recommendation-engine analytics fraud-detection loyalty spc enterprise</tags>
    <dependencies>
      <group targetFramework=".NETFramework4.5.2">
        <dependency id="Microsoft.AspNet.Mvc" version="5.3.0" />
        <dependency id="Newtonsoft.Json" version="13.0.4" />
        <dependency id="Microsoft.AspNet.Web.Optimization" version="1.1.3" />
        <dependency id="Microsoft.AspNet.Razor" version="3.3.0" />
      </group>
    </dependencies>
  </metadata>
  <files>
    <file src="Vidly\bin\Vidly.dll" target="lib\net452\" />
    <file src="README.md" target="docs\" />
    <file src="LICENSE" target="" />
  </files>
</package>
